/**
 * tailwind-like.wxss - AI数智名片 工具类样式库
 */

/* 背景色 */
.bg-page     { background: var(--bg-page); }
.bg-elevated { background: var(--bg-elevated); }
.bg-overlay  { background: var(--bg-overlay); }
.bg-hover    { background: var(--bg-hover); }
.bg-active   { background: var(--bg-active); }
.bg-cyan         { background: var(--cyan); }
.bg-cyan-light   { background: var(--cyan-light); }
.bg-purple       { background: var(--purple); }
.bg-purple-light { background: var(--purple-light); }
.bg-pink         { background: var(--pink); }
.bg-pink-light   { background: var(--pink-light); }
.bg-success { background: var(--success); }
.bg-warning { background: var(--warning); }
.bg-danger  { background: var(--danger); }
.bg-transparent  { background: transparent; }
.bg-white-4  { background: rgba(255, 255, 255, 0.04); }
.bg-white-7  { background: rgba(255, 255, 255, 0.07); }
.bg-white-10 { background: rgba(255, 255, 255, 0.10); }
.bg-white-12 { background: rgba(255, 255, 255, 0.12); }
.bg-purple-12{ background: rgba(139, 92, 246, 0.12); }

/* 渐变背景 */
.gradient-primary     { background: var(--gradient-primary); }
.gradient-cyan-purple { background: var(--gradient-cyan-purple); }
.gradient-purple-pink { background: var(--gradient-purple-pink); }
.gradient-cyan-only   { background: var(--gradient-cyan-only); }
.gradient-glow        { background: var(--gradient-glow); }

/* 文字色 */
.text-primary    { color: var(--text-primary); }
.text-secondary  { color: var(--text-secondary); }
.text-tertiary   { color: var(--text-tertiary); }
.text-quaternary { color: var(--text-quaternary); }
.text-inverse    { color: var(--text-inverse); }
.text-accent     { color: var(--text-accent); }
.text-cyan         { color: var(--cyan); }
.text-cyan-light   { color: var(--cyan-light); }
.text-purple       { color: var(--purple); }
.text-purple-light { color: var(--purple-light); }
.text-pink         { color: var(--pink); }
.text-success { color: var(--success); }
.text-warning { color: var(--warning); }
.text-danger  { color: var(--danger); }

/* 字号 */
.text-xs   { font-size: var(--text-xs); line-height: var(--text-xs-lh); }
.text-sm   { font-size: var(--text-sm); line-height: var(--text-sm-lh); }
.text-base { font-size: var(--text-base); line-height: var(--text-base-lh); }
.text-lg   { font-size: var(--text-lg); line-height: var(--text-lg-lh); }
.text-xl   { font-size: var(--text-xl); line-height: var(--text-xl-lh); }
.text-2xl  { font-size: var(--text-2xl); line-height: var(--text-2xl-lh); }
.text-3xl  { font-size: var(--text-3xl); line-height: var(--text-3xl-lh); }
.text-4xl  { font-size: var(--text-4xl); line-height: var(--text-4xl-lh); }

/* 字重 */
.font-normal    { font-weight: 400; }
.font-medium    { font-weight: 500; }
.font-semibold  { font-weight: 600; }
.font-bold      { font-weight: 700; }
.font-extrabold { font-weight: 800; }

/* 字族 */
.font-sans   { font-family: var(--font-sans); }
.font-mono   { font-family: var(--font-mono); }
.font-sc     { font-family: var(--font-sc); }
.font-system { font-family: var(--font-system); }

/* 字距 */
.tracking-tight  { letter-spacing: var(--tracking-tight); }
.tracking-normal { letter-spacing: var(--tracking-normal); }
.tracking-wide   { letter-spacing: var(--tracking-wide); }
.tracking-wider  { letter-spacing: var(--tracking-wider); }

/* 玻璃层 */
.glass-1 {
  background: var(--glass-bg-1);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: var(--glass-border-1);
}
.glass-2 {
  background: var(--glass-bg-2);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border: var(--glass-border-2);
}
.glass-3 {
  background: var(--glass-bg-3);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border: var(--glass-border-3);
  box-shadow: var(--orb-md);
}
.glass-edge {
  box-shadow: var(--shadow-glass-edge);
}

/* 光晕效果 */
.orb-sm  { box-shadow: var(--orb-sm); }
.orb-md  { box-shadow: var(--orb-md); }
.orb-lg  { box-shadow: var(--orb-lg); }
.orb-xl  { box-shadow: var(--orb-xl); }
.orb-cyan{ box-shadow: var(--orb-cyan); }
.orb-pink{ box-shadow: var(--orb-pink); }
.orb-hover{ box-shadow: var(--orb-hover); }

/* 边框 */
.border-subtle { border: var(--border-subtle); }
.border-default { border: var(--border-default); }
.border-accent  { border: var(--border-accent); }
.border-cyan    { border: var(--border-cyan); }
.border-none    { border: none; }
.border-glass-1 { border: var(--glass-border-1); }
.border-glass-2 { border: var(--glass-border-2); }
.border-glass-3 { border: var(--glass-border-3); }

/* 圆角 */
.radius-xs   { border-radius: var(--radius-xs); }
.radius-sm   { border-radius: var(--radius-sm); }
.radius-md   { border-radius: var(--radius-md); }
.radius-lg   { border-radius: var(--radius-lg); }
.radius-xl   { border-radius: var(--radius-xl); }
.radius-full { border-radius: var(--radius-full); }
.radius-none { border-radius: 0; }

/* 间距 */
.p-1  { padding: var(--space-1); }
.p-2  { padding: var(--space-2); }
.p-3  { padding: var(--space-3); }
.p-4  { padding: var(--space-4); }
.p-5  { padding: var(--space-5); }
.p-6  { padding: var(--space-6); }
.p-8  { padding: var(--space-8); }
.p-10 { padding: var(--space-10); }
.p-12 { padding: var(--space-12); }
.p-16 { padding: var(--space-16); }

.px-1  { padding-left: var(--space-1); padding-right: var(--space-1); }
.px-2  { padding-left: var(--space-2); padding-right: var(--space-2); }
.px-3  { padding-left: var(--space-3); padding-right: var(--space-3); }
.px-4  { padding-left: var(--space-4); padding-right: var(--space-4); }
.px-5  { padding-left: var(--space-5); padding-right: var(--space-5); }
.px-6  { padding-left: var(--space-6); padding-right: var(--space-6); }
.px-8  { padding-left: var(--space-8); padding-right: var(--space-8); }
.px-10 { padding-left: var(--space-10); padding-right: var(--space-10); }
.px-12 { padding-left: var(--space-12); padding-right: var(--space-12); }

.py-1  { padding-top: var(--space-1); padding-bottom: var(--space-1); }
.py-2  { padding-top: var(--space-2); padding-bottom: var(--space-2); }
.py-3  { padding-top: var(--space-3); padding-bottom: var(--space-3); }
.py-4  { padding-top: var(--space-4); padding-bottom: var(--space-4); }
.py-5  { padding-top: var(--space-5); padding-bottom: var(--space-5); }
.py-6  { padding-top: var(--space-6); padding-bottom: var(--space-6); }
.py-8  { padding-top: var(--space-8); padding-bottom: var(--space-8); }
.py-10 { padding-top: var(--space-10); padding-bottom: var(--space-10); }
.py-12 { padding-top: var(--space-12); padding-bottom: var(--space-12); }

.m-1  { margin: var(--space-1); }
.m-2  { margin: var(--space-2); }
.m-3  { margin: var(--space-3); }
.m-4  { margin: var(--space-4); }
.m-5  { margin: var(--space-5); }
.m-6  { margin: var(--space-6); }
.m-8  { margin: var(--space-8); }
.m-10 { margin: var(--space-10); }
.m-12 { margin: var(--space-12); }

.mx-auto { margin-left: auto; margin-right: auto; }
.mx-1  { margin-left: var(--space-1); margin-right: var(--space-1); }
.mx-2  { margin-left: var(--space-2); margin-right: var(--space-2); }
.mx-3  { margin-left: var(--space-3); margin-right: var(--space-3); }
.mx-4  { margin-left: var(--space-4); margin-right: var(--space-4); }
.mx-5  { margin-left: var(--space-5); margin-right: var(--space-5); }
.mx-6  { margin-left: var(--space-6); margin-right: var(--space-6); }
.mx-8  { margin-left: var(--space-8); margin-right: var(--space-8); }
.mx-10 { margin-left: var(--space-10); margin-right: var(--space-10); }

.my-1  { margin-top: var(--space-1); margin-bottom: var(--space-1); }
.my-2  { margin-top: var(--space-2); margin-bottom: var(--space-2); }
.my-3  { margin-top: var(--space-3); margin-bottom: var(--space-3); }
.my-4  { margin-top: var(--space-4); margin-bottom: var(--space-4); }
.my-5  { margin-top: var(--space-5); margin-bottom: var(--space-5); }
.my-6  { margin-top: var(--space-6); margin-bottom: var(--space-6); }
.my-8  { margin-top: var(--space-8); margin-bottom: var(--space-8); }
.my-10 { margin-top: var(--space-10); margin-bottom: var(--space-10); }

.mt-1  { margin-top: var(--space-1); }
.mt-2  { margin-top: var(--space-2); }
.mt-3  { margin-top: var(--space-3); }
.mt-4  { margin-top: var(--space-4); }
.mt-5  { margin-top: var(--space-5); }
.mt-6  { margin-top: var(--space-6); }
.mt-8  { margin-top: var(--space-8); }
.mt-10 { margin-top: var(--space-10); }
.mt-12 { margin-top: var(--space-12); }

.mb-1  { margin-bottom: var(--space-1); }
.mb-2  { margin-bottom: var(--space-2); }
.mb-3  { margin-bottom: var(--space-3); }
.mb-4  { margin-bottom: var(--space-4); }
.mb-5  { margin-bottom: var(--space-5); }
.mb-6  { margin-bottom: var(--space-6); }
.mb-8  { margin-bottom: var(--space-8); }
.mb-10 { margin-bottom: var(--space-10); }
.mb-12 { margin-bottom: var(--space-12); }

.gap-1  { gap: var(--space-1); }
.gap-2  { gap: var(--space-2); }
.gap-3  { gap: var(--space-3); }
.gap-4  { gap: var(--space-4); }
.gap-5  { gap: var(--space-5); }
.gap-6  { gap: var(--space-6); }
.gap-8  { gap: var(--space-8); }
.gap-10 { gap: var(--space-10); }
.gap-12 { gap: var(--space-12); }

/* 布局 */
.flex       { display: flex; }
.flex-col   { flex-direction: column; }
.flex-row   { flex-direction: row; }
.flex-wrap  { flex-wrap: wrap; }
.flex-1     { flex: 1; }
.flex-shrink-0 { flex-shrink: 0; }
.items-center   { align-items: center; }
.items-start    { align-items: flex-start; }
.items-end      { align-items: flex-end; }
.justify-center    { justify-content: center; }
.justify-between   { justify-content: space-between; }
.justify-around    { justify-content: space-around; }
.justify-end       { justify-content: flex-end; }
.self-center  { align-self: center; }
.block   { display: block; }
.inline  { display: inline; }
.inline-flex { display: inline-flex; }
.hidden  { display: none; }
.overflow-hidden { overflow: hidden; }
.relative { position: relative; }
.absolute { position: absolute; }
.fixed    { position: fixed; }

/* 宽高 */
.w-full  { width: 100%; }
.h-full  { height: 100%; }
.w-auto  { width: auto; }
.h-auto  { height: auto; }
.min-h-screen { min-height: 100vh; }

/* 文本 */
.text-left   { text-align: left; }
.text-center { text-align: center; }
.text-right  { text-align: right; }
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.text-clamp-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.whitespace-nowrap { white-space: nowrap; }

/* 过渡 */
.transition-fade   { transition: var(--transition-fade); }
.transition-scale  { transition: var(--transition-scale); }
.transition-glass  { transition: var(--transition-glass); }
.transition-spring { transition: var(--transition-spring); }
.transition-all    { transition: all var(--duration-normal) var(--ease-out); }
.transition-opacity { transition: opacity var(--duration-normal) var(--ease-out); }
.transition-transform { transition: transform var(--duration-normal) var(--ease-spring); }

/* 动画 */
.animate-orb-float {
  animation: orb-float var(--duration-orb) var(--ease-in-out) infinite;
}
.animate-shimmer {
  animation: shimmer var(--duration-shimmer) linear infinite;
}
.animate-pulse-glow {
  animation: pulse-glow 2000ms ease-in-out infinite;
}

/* 交互态 */
.hover-lift:active {
  transform: scale(0.98);
  opacity: 0.9;
}
.hover-glow:active {
  box-shadow: var(--orb-hover);
}
.active-press {
  transition: transform var(--duration-fast) var(--ease-out);
}
.active-press:active {
  transform: scale(0.96);
}

/* 组件预设 */
.card-default {
  background: var(--card-bg);
  border: var(--card-border);
  border-radius: var(--card-radius);
  padding: var(--card-padding);
  box-shadow: var(--card-orb), var(--card-glow-edge);
  position: relative;
  overflow: hidden;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: var(--btn-primary-height);
  background: var(--btn-primary-bg);
  color: var(--btn-primary-color);
  font-size: var(--btn-primary-font-size);
  font-weight: var(--btn-primary-font-weight);
  border: none;
  border-radius: var(--btn-primary-radius);
  box-shadow: var(--btn-primary-orb);
  width: 100%;
  transition: box-shadow var(--duration-fast) var(--ease-out),
              transform var(--duration-fast) var(--ease-out);
}
.btn-primary:active {
  box-shadow: var(--btn-primary-hover-orb);
  transform: scale(0.98);
}
.btn-primary.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.btn-primary.small {
  height: var(--btn-sm-height);
  border-radius: var(--btn-sm-radius);
  font-size: var(--btn-sm-font-size);
  width: auto;
  padding: 0 var(--space-5);
}

.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  height: var(--btn-outline-height);
  background: var(--btn-outline-bg);
  color: var(--btn-outline-color);
  font-size: var(--btn-outline-font-size);
  font-weight: var(--btn-outline-font-weight);
  border: var(--btn-outline-border);
  border-radius: var(--btn-outline-radius);
  width: 100%;
  transition: background var(--duration-fast) var(--ease-out);
}
.btn-outline:active {
  background: var(--bg-hover);
}

.nav-bar {
  background: var(--nav-bg);
  backdrop-filter: blur(var(--nav-blur));
  -webkit-backdrop-filter: blur(var(--nav-blur));
  height: var(--nav-height);
  display: flex;
  align-items: center;
  padding: 0 var(--space-6);
}

.input-field {
  width: 100%;
  height: var(--input-height);
  padding: var(--input-padding);
  background: var(--input-bg);
  border: var(--input-border);
  border-radius: var(--input-radius);
  font-size: var(--text-base);
  color: var(--input-color);
  box-sizing: border-box;
  transition: border var(--duration-fast) var(--ease-out);
}
.input-field:focus {
  border: var(--input-focus-border);
}
.input-field.error {
  border: var(--input-error-border);
}
.input-field::placeholder {
  color: var(--input-placeholder);
}

.user-header-comp {
  display: flex;
  align-items: center;
  padding: var(--user-header-padding);
}
.user-header-comp .avatar {
  width: var(--user-header-avatar-size);
  height: var(--user-header-avatar-size);
  border-radius: 50%;
  border: var(--user-header-avatar-border);
  box-shadow: var(--user-header-avatar-orb);
  flex-shrink: 0;
  margin-right: var(--space-6);
}
.user-header-comp .name {
  font-size: var(--user-header-name-size);
  font-weight: 700;
  color: var(--text-primary);
}
.user-header-comp .position {
  font-size: var(--user-header-pos-size);
  color: var(--text-secondary);
  margin-top: var(--space-1);
}

.stat-group {
  display: flex;
  gap: var(--stat-gap);
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-number {
  font-size: var(--stat-number-size);
  font-weight: var(--stat-number-weight);
  color: var(--stat-number-color);
}
.stat-label {
  font-size: var(--stat-label-size);
  color: var(--stat-label-color);
}

.avatar-stack {
  display: flex;
  align-items: center;
}
.avatar-stack .avatar {
  width: var(--avatar-stack-size);
  height: var(--avatar-stack-size);
  border-radius: 50%;
  border: var(--avatar-stack-border);
  margin-right: var(--avatar-stack-overlap);
}
.avatar-stack .more {
  width: var(--avatar-stack-size);
  height: var(--avatar-stack-size);
  border-radius: 50%;
  background: var(--bg-glass-2);
  border: var(--avatar-stack-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--tabbar-color);
  font-size: var(--tabbar-font-size);
}
.tabbar-item.active {
  color: var(--tabbar-color-active);
}
.tabbar-item .icon {
  font-size: var(--tabbar-icon-size);
  margin-bottom: var(--space-1);
}

.divider {
  height: 1rpx;
  background: var(--border-subtle);
}

.skeleton {
  background: linear-gradient(90deg,
    rgba(255,255,255,0.04) 25%,
    rgba(255,255,255,0.07) 50%,
    rgba(255,255,255,0.04) 75%
  );
  background-size: 200% 100%;
  animation: shimmer var(--duration-shimmer) linear infinite;
  border-radius: var(--radius-xs);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-16) var(--space-6);
}
.empty-state .text {
  font-size: var(--text-base);
  color: var(--text-tertiary);
  text-align: center;
}

.safe-bottom {
  padding-bottom: var(--tabbar-safe-bottom, 12px);
}

/* 首页专用 */
.action-bar-comp {
  display: flex;
  justify-content: space-around;
  background: var(--home-action-bar-bg);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border: var(--home-action-bar-border);
  border-radius: var(--home-action-bar-radius);
  margin: 0 var(--home-action-bar-margin);
  padding: var(--space-6) var(--space-4);
  box-shadow: var(--shadow-glass-edge);
}

.ai-entry-comp {
  box-shadow: var(--home-ai-entry-orb);
  border-radius: var(--home-ai-entry-radius);
  overflow: hidden;
}

.recommend-gap {
  gap: var(--home-recommend-gap);
}

.upgrade-banner {
  background: var(--home-upgrade-bg);
}

.safe-area-inset-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
