.page-wrap {
  min-height: 100vh;
  background: var(--bg-page, #0A0A18);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 40rpx 60rpx;
  box-sizing: border-box;
}

.qrcode-card {
  width: 100%;
  max-width: 620rpx;
  background: var(--bg-glass-2, rgba(255,255,255,0.06));
  border-radius: 48rpx;
  padding: 60rpx 40rpx;
  margin-top: 40rpx;
  box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  border: 0.5px solid rgba(255,255,255,0.08);
}

.user-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 3px solid rgba(167, 139, 250, 0.3);
  margin-bottom: 24rpx;
}

.user-avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: rgba(255,255,255,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.avatar-emoji {
  font-size: 64rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #e4e4ed;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 26rpx;
  color: #8b8b9e;
  text-align: center;
}

.qrcode-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qrcode-wrapper {
  width: 400rpx;
  height: 400rpx;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-shadow: 0 4px 20px rgba(0,0,0,0.2);
}

.qrcode-img {
  width: 100%;
  height: 100%;
}

.qrcode-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.placeholder-icon {
  font-size: 80rpx;
}

.placeholder-text {
  font-size: 26rpx;
  color: #8b8b9e;
}

.qrcode-tip {
  font-size: 24rpx;
  color: #6b6b7e;
  margin-top: 32rpx;
  text-align: center;
}

.action-section {
  width: 100%;
  max-width: 620rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 60rpx;
}

.action-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 32rpx;
  border: none;
  padding: 0;
}

.primary-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4px 16px rgba(102, 126, 234, 0.3);
}

.primary-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.secondary-btn {
  background: rgba(255,255,255,0.06);
  color: #e4e4ed;
  border: 0.5px solid rgba(255,255,255,0.1);
}

.secondary-btn:active {
  background: rgba(255,255,255,0.1);
  transform: scale(0.98);
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-weight: 600;
}
