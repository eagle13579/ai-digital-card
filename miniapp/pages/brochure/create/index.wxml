<scroll-view class="page-scroll dark-mode" scroll-y id="pageScroll" scroll-top="{{scrollTop}}" style="padding-bottom: {{keyboardHeight}}px">
  <view class="form-container">

    <!-- 对话式编辑 - P2功能 -->
    <chat-editor 
      wx:if="{{showChatEditor}}"
      card-id="{{cardId}}"
      bind:editcomplete="onEditConfirm"
      bind:undo="onEditUndo" />

    <!-- 个人身份信息 - 玻璃中厚 -->
    <view class="section-card glass-tier-2">
      <view class="section-header">
        <view class="section-icon-wrap">
          <text class="section-icon">👤</text>
        </view>
        <text class="section-title">个人身份信息</text>
      </view>
      <view class="form-content">
        <view class="avatar-upload spring-press" hover-class="spring-scale-down" bindtap="chooseAvatar">
          <image wx:if="{{formData.avatar}}" src="{{formData.avatar}}" mode="aspectFill" />
          <view wx:else class="avatar-placeholder">
            <text class="avatar-icon">📷</text>
            <text class="avatar-text">上传头像</text>
          </view>
        </view>

        <view class="form-row">
          <view class="form-item flex-1">
            <text class="form-label">姓名<text class="required">*</text></text>
            <input class="form-input" placeholder="请输入姓名" placeholder-class="input-placeholder" value="{{formData.name}}" bindinput="onInput" data-field="name" />
          </view>
          <view class="form-item flex-1">
            <text class="form-label">职位<text class="required">*</text></text>
            <input class="form-input" placeholder="请输入职位" placeholder-class="input-placeholder" value="{{formData.title}}" bindinput="onInput" data-field="title" />
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">公司名称<text class="required">*</text></text>
          <input class="form-input" placeholder="请输入公司名称" placeholder-class="input-placeholder" value="{{formData.company}}" bindinput="onInput" data-field="company" />
        </view>

        <view class="form-row">
          <view class="form-item flex-1">
            <text class="form-label">手机号码</text>
            <input class="form-input" placeholder="请输入手机号" placeholder-class="input-placeholder" value="{{formData.phone}}" bindinput="onInput" data-field="phone" type="number" />
          </view>
          <view class="form-item flex-1">
            <text class="form-label">邮箱</text>
            <input class="form-input" placeholder="请输入邮箱" placeholder-class="input-placeholder" value="{{formData.email}}" bindinput="onInput" data-field="email" type="email" />
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">微信号</text>
          <input class="form-input" placeholder="请输入微信号" placeholder-class="input-placeholder" value="{{formData.wechat}}" bindinput="onInput" data-field="wechat" />
        </view>

        <view class="form-item">
          <text class="form-label">个人简介<text class="required">*</text></text>
          <textarea class="form-textarea" placeholder="请简要介绍您自己（50-200字）" placeholder-class="input-placeholder" value="{{formData.bio}}" bindinput="onInput" data-field="bio" maxlength="200" cursor-spacing="160" />
          <text class="char-count">{{formData.bio ? formData.bio.length : 0}}/200</text>
        </view>
      </view>
    </view>

    <!-- 资源供需信息 - 玻璃中厚 -->
    <view class="section-card glass-tier-2" id="resourceSection">
      <view class="section-header">
        <view class="section-icon-wrap">
          <text class="section-icon">💎</text>
        </view>
        <text class="section-title">资源供需信息</text>
      </view>
      <view class="form-content">
        <view class="form-item">
          <text class="form-label">我能提供的资源</text>
          <view class="resource-input-row">
            <input class="form-input resource-input" placeholder="输入资源后点击添加" placeholder-class="input-placeholder" value="{{formData.newProvide}}" bindinput="onInput" data-field="newProvide" bindfocus="onInputFocus" bindblur="onInputBlur" cursor-spacing="100" />
            <button class="btn-add spring-press" hover-class="spring-scale-down" bindtap="addProvide">添加</button>
          </view>
          <view class="tags-list" wx:if="{{formData.provides && formData.provides.length > 0}}">
            <view wx:for="{{formData.provides}}" wx:key="index" class="tag-item provides-tag spring-press" hover-class="spring-scale-mini">
              <text class="tag-text">{{item}}</text>
              <text class="tag-close" bindtap="removeProvide" data-index="{{index}}">×</text>
            </view>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">我想要的资源</text>
          <view class="resource-input-row">
            <input class="form-input resource-input" placeholder="输入需求后点击添加" placeholder-class="input-placeholder" value="{{formData.newNeed}}" bindinput="onInput" data-field="newNeed" bindfocus="onInputFocus" bindblur="onInputBlur" cursor-spacing="100" />
            <button class="btn-add spring-press" hover-class="spring-scale-down" bindtap="addNeed">添加</button>
          </view>
          <view class="tags-list" wx:if="{{formData.needs && formData.needs.length > 0}}">
            <view wx:for="{{formData.needs}}" wx:key="index" class="tag-item needs-tag spring-press" hover-class="spring-scale-mini">
              <text class="tag-text">{{item}}</text>
              <text class="tag-close" bindtap="removeNeed" data-index="{{index}}">×</text>
            </view>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">合作意向</text>
          <view class="purpose-options">
            <view wx:for="{{purposeOptions}}" wx:key="value" class="purpose-option spring-press {{formData.purpose === item.value ? 'active' : ''}}" hover-class="spring-scale-mini" bindtap="selectPurpose" data-value="{{item.value}}">
              <text class="purpose-icon">{{item.icon}}</text>
              <text class="purpose-label">{{item.label}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 公司介绍 - 玻璃中厚 -->
    <view class="section-card glass-tier-2" id="companySection">
      <view class="section-header">
        <view class="section-icon-wrap">
          <text class="section-icon">🏢</text>
        </view>
        <text class="section-title">公司介绍</text>
      </view>
      <view class="form-content">
        <view class="form-row">
          <view class="form-item flex-1">
            <text class="form-label">公司名称</text>
            <input class="form-input" placeholder="如未填写则使用个人信息中的公司" placeholder-class="input-placeholder" value="{{formData.companyName}}" bindinput="onInput" data-field="companyName" />
          </view>
          <view class="form-item flex-1">
            <text class="form-label">行业</text>
            <input class="form-input" placeholder="如：互联网、金融" placeholder-class="input-placeholder" value="{{formData.industry}}" bindinput="onInput" data-field="industry" />
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">公司规模</text>
          <view class="form-input picker-input spring-press" hover-class="spring-scale-mini" bindtap="showSizePicker">
            <text>{{formData.companySize || '请选择公司规模'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">公司简介</text>
          <textarea class="form-textarea" placeholder="请简要介绍公司（100-500字）" placeholder-class="input-placeholder" value="{{formData.companyDesc}}" bindinput="onInput" data-field="companyDesc" maxlength="500" cursor-spacing="160" bindfocus="onTextareaFocus" data-section="companySection" />
          <text class="char-count">{{formData.companyDesc ? formData.companyDesc.length : 0}}/500</text>
        </view>

        <view class="form-item">
          <text class="form-label">发展历程</text>
          <textarea class="form-textarea" placeholder="请描述公司重要里程碑（每行一个）" placeholder-class="input-placeholder" value="{{formData.development}}" bindinput="onInput" data-field="development" maxlength="300" cursor-spacing="160" bindfocus="onTextareaFocus" data-section="companySection" />
          <text class="char-count">{{formData.development ? formData.development.length : 0}}/300</text>
        </view>

        <view class="form-item">
          <text class="form-label">公司宣传图片（最多3张）</text>
          <view class="images-grid">
            <view wx:for="{{formData.companyImages || []}}" wx:key="index" class="image-item spring-press" hover-class="spring-scale-mini" bindtap="previewImage" data-url="{{item}}">
              <image src="{{item}}" mode="aspectFill" />
              <text class="image-remove" bindtap="removeCompanyImage" data-index="{{index}}">×</text>
            </view>
            <view wx:if="{{(!formData.companyImages || formData.companyImages.length < 3)}}" class="image-add spring-press" hover-class="spring-scale-mini" bindtap="chooseCompanyImage">
              <text class="image-add-icon">+</text>
              <text class="image-add-text">添加图片</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 产品案例 - 玻璃中厚 -->
    <view class="section-card glass-tier-2" id="caseSection">
      <view class="section-header">
        <view class="section-icon-wrap">
          <text class="section-icon">💼</text>
        </view>
        <text class="section-title">产品案例</text>
      </view>
      <view class="form-content">
        <view class="case-list">
          <view class="case-item" wx:for="{{formData.cases}}" wx:key="index">
            <view class="case-header">
              <text class="case-title">案例 {{index + 1}}</text>
              <text class="case-delete spring-press" hover-class="spring-scale-mini" bindtap="deleteCase" data-index="{{index}}">删除</text>
            </view>
            <view class="form-item">
              <text class="form-label">案例名称</text>
              <input class="form-input" placeholder="请输入案例名称" placeholder-class="input-placeholder" value="{{item.name}}" bindinput="onCaseInput" data-case-index="{{index}}" data-field="name" />
            </view>
            <view class="form-row">
              <view class="form-item flex-1">
                <text class="form-label">项目时间</text>
                <input class="form-input" placeholder="如：2024年" placeholder-class="input-placeholder" value="{{item.date}}" bindinput="onCaseInput" data-case-index="{{index}}" data-field="date" />
              </view>
            </view>
            <view class="form-item">
              <text class="form-label">案例描述</text>
              <textarea class="form-textarea" placeholder="请描述案例背景、目标和成果" placeholder-class="input-placeholder" value="{{item.desc}}" bindinput="onCaseInput" data-case-index="{{index}}" data-field="desc" maxlength="300" cursor-spacing="160" bindfocus="onTextareaFocus" data-section="caseSection" />
            </view>
            <view class="form-item">
              <text class="form-label">案例图片（最多3张）</text>
              <view class="images-grid">
                <view wx:for="{{item.images || []}}" wx:key="idx" class="image-item spring-press" hover-class="spring-scale-mini" bindtap="previewImage" data-url="{{item}}">
                  <image src="{{item}}" mode="aspectFill" />
                  <text class="image-remove" bindtap="removeCaseImage" data-case-index="{{index}}" data-image-index="{{idx}}">×</text>
                </view>
                <view wx:if="{{(!item.images || item.images.length < 3)}}" class="image-add spring-press" hover-class="spring-scale-mini" bindtap="chooseCaseImage" data-case-index="{{index}}">
                  <text class="image-add-icon">+</text>
                  <text class="image-add-text">添加图片</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        <button class="btn-outline btn-add-case spring-press" hover-class="spring-scale-down" bindtap="addCase">+ 添加案例</button>
      </view>
    </view>

    <!-- 画册风格 - 玻璃中厚 -->
    <view class="section-card glass-tier-2">
      <view class="section-header">
        <view class="section-icon-wrap">
          <text class="section-icon">🎨</text>
        </view>
        <text class="section-title">画册风格</text>
      </view>
      <view class="form-content">
        <view class="style-options">
          <view wx:for="{{styleOptions}}" wx:key="value" class="style-option spring-press {{formData.style === item.value ? 'active' : ''}}" hover-class="spring-scale-mini" bindtap="selectStyle" data-value="{{item.value}}">
            <view class="style-preview" style="background: {{item.preview}}"></view>
            <text class="style-name">{{item.name}}</text>
            <text class="style-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 提交区域 - 弹簧按钮 -->
    <view class="submit-area">
      <button class="btn-submit spring-press" hover-class="spring-scale-down" bindtap="submitForm">生成AI数智名片</button>
    </view>

    <view class="bottom-safe"></view>
  </view>
</scroll-view>
