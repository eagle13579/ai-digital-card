/* з”»еҶҢеҲӣе»әйЎө - v3.0 StepperзүҲ */
.page-wrap {
  min-height: 100vh;
  padding-bottom: 100px;
  position: relative;
}

/* ====== Stepper йЎ¶йғЁжҢҮзӨәеҷЁ ====== */
.stepper-header {
  padding: 20px 16px 12px;
  background: var(--surface-glass, rgba(255,255,255,0.04));
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border-subtle, rgba(255,255,255,0.06));
}

.stepper-track {
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  padding: 0 4px;
}

.step-dot {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 2;
}

.dot-inner {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  border: 2px solid rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.step-dot.active .dot-inner {
  background: linear-gradient(135deg, #4F46E5, #7C3AED);
  border-color: #7C3AED;
  box-shadow: 0 0 16px rgba(124, 58, 237, 0.4);
  transform: scale(1.1);
}

.step-dot.completed .dot-inner {
  background: linear-gradient(135deg, #10B981, #059669);
  border-color: #10B981;
}

.dot-check,
.dot-num {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.4);
  font-weight: 600;
}

.step-dot.active .dot-num {
  color: #fff;
}

.step-dot.completed .dot-check {
  color: #fff;
}

.step-line {
  flex: 1;
  min-width: 20px;
  height: 2px;
  background: rgba(255, 255, 255, 0.08);
  position: relative;
  z-index: 1;
  margin: 0 2px;
}

.step-line-fill {
  width: 0%;
  height: 100%;
  background: linear-gradient(90deg, #10B981, #059669);
  transition: width 0.4s ease;
}

.step-line-fill.filled {
  width: 100%;
}

.step-label {
  text-align: center;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.35);
  transition: color 0.3s ease;
  white-space: nowrap;
  margin-top: 6px;
}

.step-label.active {
  color: #a78bfa;
  font-weight: 500;
}

/* ====== жӯҘйӘӨеҶ…е®№ ====== */
.step-content {
  padding-top: 4px;
}

/* ====== еҚЎзүҮе®№еҷЁпјҲеӨҚз”ЁеҺҹж ·ејҸпјү ====== */
.section-card {
  background: var(--surface-glass, rgba(255,255,255,0.04));
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle, rgba(255,255,255,0.06));
  border-radius: var(--radius-lg, 16px);
  margin: var(--space-4, 16px);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: var(--space-4, 16px);
  background: var(--gradient-header, linear-gradient(135deg, rgba(139,92,246,0.08), rgba(6,182,212,0.05)));
  border-bottom: 1px solid var(--border-subtle, rgba(255,255,255,0.06));
}

.section-icon-wrap {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, rgba(139,92,246,0.2), rgba(6,182,212,0.15));
  border-radius: var(--radius-sm, 8px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-3, 12px);
}

.section-icon {
  font-size: 18px;
}

.section-title {
  font-size: var(--text-base, 16px);
  font-weight: var(--weight-semibold, 600);
  color: var(--text-primary, #fff);
  flex: 1;
}

.section-badge {
  font-size: 10px;
  padding: 2px 10px;
  border-radius: 20px;
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

.form-content {
  padding: var(--space-4, 16px);
}

.form-item {
  margin-bottom: var(--space-4, 16px);
}

.form-item.has-error .form-input,
.form-item.has-error .form-textarea {
  border-color: #ef4444;
}

.form-row {
  display: flex;
  gap: var(--space-3, 12px);
  margin-bottom: var(--space-4, 16px);
}

.flex-1 {
  flex: 1;
}

.form-label {
  font-size: var(--text-sm, 14px);
  color: var(--text-secondary, rgba(255,255,255,0.6));
  margin-bottom: 6px;
  display: block;
}

.required {
  color: var(--danger, #ef4444);
}

.error-text {
  font-size: 12px;
  color: #ef4444;
  margin-top: 4px;
  display: block;
}

.form-input {
  width: 100%;
  height: 44px;
  padding: 0 var(--space-3, 12px);
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid var(--border-default, rgba(255,255,255,0.1));
  border-radius: var(--radius-sm, 8px);
  font-size: var(--text-sm, 14px);
  color: var(--text-primary, #fff);
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--accent, #a78bfa);
  background: rgba(255, 255, 255, 0.06);
}

.form-input::placeholder {
  color: var(--text-tertiary, rgba(255,255,255,0.3));
}

.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  color: var(--text-tertiary, rgba(255,255,255,0.3));
  font-size: 18px;
}

.form-textarea {
  width: 100%;
  min-height: 80px;
  padding: var(--space-3, 12px);
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid var(--border-default, rgba(255,255,255,0.1));
  border-radius: var(--radius-sm, 8px);
  font-size: var(--text-sm, 14px);
  color: var(--text-primary, #fff);
  box-sizing: border-box;
}

.form-textarea:focus {
  border-color: var(--accent, #a78bfa);
  background: rgba(255, 255, 255, 0.06);
}

.form-textarea::placeholder {
  color: var(--text-tertiary, rgba(255,255,255,0.3));
}

.char-count {
  font-size: var(--text-xs, 12px);
  color: var(--text-tertiary, rgba(255,255,255,0.3));
  text-align: right;
  margin-top: 4px;
  display: block;
}

.more-divider {
  border: none;
  border-top: 1px dashed var(--border-subtle, rgba(255,255,255,0.06));
  margin: var(--space-4, 16px) 0;
}

/* ====== Avatar ====== */
.avatar-upload {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-md, 12px);
  overflow: hidden;
  border: 2px dashed var(--border-default, rgba(255,255,255,0.1));
  margin-bottom: var(--space-4, 16px);
}

.avatar-upload image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.03);
}

.avatar-icon {
  font-size: 24px;
  margin-bottom: 4px;
}

.avatar-text {
  font-size: var(--text-xs, 12px);
  color: var(--text-tertiary, rgba(255,255,255,0.3));
}

/* ====== ж ҮзӯҫеҲ—иЎЁ ====== */
.resource-input-row {
  display: flex;
  gap: var(--space-2, 8px);
}

.resource-input {
  flex: 1;
}

.btn-add {
  padding: 0 20px;
  height: 44px;
  background: var(--gradient-accent, linear-gradient(135deg, #4F46E5, #7C3AED));
  color: #fff;
  border-radius: var(--radius-sm, 8px);
  font-size: var(--text-sm, 14px);
  font-weight: var(--weight-medium, 500);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 44px;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: var(--space-2, 8px);
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 6px 12px;
  background: rgba(139, 92, 246, 0.12);
  border-radius: var(--radius-full, 100px);
  font-size: var(--text-sm, 14px);
  color: var(--accent-light, #c4b5fd);
}

.tag-item.needs-tag {
  background: rgba(245, 158, 11, 0.12);
  color: var(--warning, #f59e0b);
}

.tag-item.skill-tag {
  background: rgba(6, 182, 212, 0.12);
  color: #22d3ee;
}

.tag-text {
  margin-right: 6px;
}

.tag-close {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.4);
}

/* ====== еҗҲдҪңж„Ҹеҗ‘ ====== */
.purpose-options {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-2, 8px);
}

.purpose-option {
  display: flex;
  align-items: center;
  padding: 14px;
  background: rgba(255, 255, 255, 0.03);
  border: 1.5px solid transparent;
  border-radius: var(--radius-md, 12px);
}

.purpose-option.active {
  background: rgba(139, 92, 246, 0.35);
  border-color: #a78bfa;
  box-shadow: 0 0 30rpx rgba(139, 92, 246, 0.3);
}

.purpose-option-hover {
  background: rgba(255, 255, 255, 0.06) !important;
}

.purpose-icon {
  font-size: 20px;
  margin-right: 10px;
}

.purpose-label {
  font-size: var(--text-sm, 14px);
  color: var(--text-primary, #fff);
}

/* ====== иЎҢдёҡйҖүжӢ© ====== */
.industry-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.industry-option {
  display: flex;
  align-items: center;
  padding: 10px 16px;
  background: rgba(255, 255, 255, 0.04);
  border: 1.5px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-md, 12px);
  cursor: pointer;
  transition: all 0.2s ease;
}

.industry-option.active {
  background: rgba(139, 92, 246, 0.12);
  border-color: rgba(139, 92, 246, 0.35);
  box-shadow: 0 0 12px rgba(139, 92, 246, 0.15);
}

.industry-icon {
  font-size: 20px;
  margin-right: 8px;
}

.industry-label {
  font-size: var(--text-sm, 14px);
  color: var(--text-primary, #fff);
  font-weight: 500;
}

/* ====== иЎҢдёҡжЁЎжқҝдё“еұһ ====== */
.template-section {
  animation: fadeSlideIn 0.35s ease;
}

@keyframes fadeSlideIn {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.template-divider {
  border-top: 1px dashed rgba(139, 92, 246, 0.2);
  margin: var(--space-3, 12px) 0;
}

.template-header {
  margin-bottom: var(--space-3, 12px);
}

.template-title {
  font-size: var(--text-sm, 14px);
  color: #a78bfa;
  font-weight: 600;
}

/* ====== е…¬еҸёеӣҫзүҮ ====== */
.images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.image-item {
  width: calc(33.33% - 7px);
  aspect-ratio: 4/3;
  border-radius: var(--radius-sm, 8px);
  overflow: hidden;
  position: relative;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 24px;
  height: 24px;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
}

.image-add {
  width: calc(33.33% - 7px);
  aspect-ratio: 4/3;
  border: 2px dashed var(--border-default, rgba(255,255,255,0.1));
  border-radius: var(--radius-sm, 8px);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.03);
}

.image-add-icon {
  font-size: 24px;
  color: var(--text-tertiary, rgba(255,255,255,0.3));
}

.image-add-text {
  font-size: var(--text-xs, 12px);
  color: var(--text-tertiary, rgba(255,255,255,0.3));
  margin-top: 4px;
}

/* ====== ж–Үд»¶дёҠдј  ====== */
.file-card {
  display: flex;
  align-items: center;
  padding: 12px 14px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid var(--border-default, rgba(255,255,255,0.1));
  border-radius: var(--radius-sm, 8px);
  gap: 12px;
}

.file-icon {
  font-size: 28px;
  flex-shrink: 0;
}

.file-info {
  flex: 1;
  min-width: 0;
}

.file-name {
  font-size: var(--text-sm, 14px);
  color: var(--text-primary, #fff);
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.file-size {
  font-size: var(--text-xs, 12px);
  color: var(--text-tertiary, rgba(255,255,255,0.35));
  display: block;
  margin-top: 2px;
}

.file-remove {
  width: 24px;
  height: 24px;
  background: rgba(239, 68, 68, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ef4444;
  font-size: 16px;
  flex-shrink: 0;
  cursor: pointer;
}

.file-upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 16px;
  border: 2px dashed var(--border-default, rgba(255,255,255,0.1));
  border-radius: var(--radius-sm, 8px);
  background: rgba(255, 255, 255, 0.03);
  cursor: pointer;
}

.file-upload-btn:active {
  background: rgba(255, 255, 255, 0.06);
}

.file-upload-icon {
  font-size: 20px;
  color: var(--text-tertiary, rgba(255,255,255,0.3));
}

.file-upload-text {
  font-size: var(--text-sm, 14px);
  color: var(--text-tertiary, rgba(255,255,255,0.3));
}

/* ====== йЈҺж јйҖүжӢ© ====== */
.style-options {
  display: flex;
  gap: var(--space-3, 12px);
}

.style-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14px 10px;
  background: rgba(255, 255, 255, 0.03);
  border: 1.5px solid transparent;
  border-radius: var(--radius-md, 12px);
}

.style-option.active {
  background: rgba(139, 92, 246, 0.1);
  border-color: rgba(139, 92, 246, 0.3);
}

.style-preview {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-sm, 8px);
  margin-bottom: 10px;
}

.style-name {
  font-size: var(--text-sm, 14px);
  font-weight: var(--weight-medium, 500);
  color: var(--text-primary, #fff);
  margin-bottom: 4px;
}

.style-desc {
  font-size: var(--text-xs, 12px);
  color: var(--text-tertiary, rgba(255,255,255,0.3));
  text-align: center;
}

/* ====== йў„и§Ҳж‘ҳиҰҒ ====== */
.preview-summary {
  padding: 4px 0;
}

.preview-row {
  display: flex;
  align-items: flex-start;
  padding: 10px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.preview-row:last-child {
  border-bottom: none;
}

.preview-label {
  width: 80px;
  font-size: var(--text-sm, 14px);
  color: var(--text-secondary, rgba(255,255,255,0.6));
  flex-shrink: 0;
}

.preview-value {
  font-size: var(--text-sm, 14px);
  color: var(--text-primary, #fff);
  flex: 1;
}

.preview-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.mini-tag {
  font-size: 11px;
  padding: 2px 10px;
  background: rgba(139, 92, 246, 0.12);
  border-radius: 100px;
  color: #c4b5fd;
}

/* ====== еә•йғЁж“ҚдҪңж Ҹ ====== */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom, 0px));
  gap: 12px;
  background: rgba(15, 15, 26, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  z-index: 100;
}

.btn-prev {
  flex: 1;
  height: 48px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #fff;
  border-radius: var(--radius-sm, 8px);
  font-size: var(--text-base, 16px);
  font-weight: var(--weight-semibold, 600);
}

.btn-next {
  flex: 2;
  height: 48px;
  background: var(--gradient-accent, linear-gradient(135deg, #4F46E5, #7C3AED));
  color: #fff;
  border-radius: var(--radius-sm, 8px);
  font-size: var(--text-base, 16px);
  font-weight: var(--weight-semibold, 600);
  border: none;
}

.btn-submit {
  flex: 3;
  height: 48px;
  line-height: 48px;
  text-align: center;
  background: var(--gradient-accent, linear-gradient(135deg, #4F46E5, #7C3AED));
  color: #fff;
  border-radius: var(--radius-sm, 8px);
  font-size: var(--text-base, 16px);
  font-weight: var(--weight-semibold, 600);
  border: none;
  padding: 0;
}
