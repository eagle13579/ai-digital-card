/* 画册创建页 - v2.0 Dark Minimal */

.page-scroll {
  height: 100vh;
}

.section-card {
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  margin: var(--space-4);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: var(--space-4);
  background: var(--gradient-header);
  border-bottom: 1px solid var(--border-subtle);
}

.section-icon-wrap {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, rgba(139,92,246,0.2), rgba(6,182,212,0.15));
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-3);
}

.section-icon {
  font-size: 18px;
}

.section-title {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
}

.form-content {
  padding: var(--space-4);
}

.form-item {
  margin-bottom: var(--space-4);
}

.form-row {
  display: flex;
  gap: var(--space-3);
  margin-bottom: var(--space-4);
}

.flex-1 {
  flex: 1;
}

.form-label {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-bottom: 6px;
  display: block;
}

.required {
  color: var(--danger);
}

.form-input {
  width: 100%;
  height: 44px;
  padding: 0 var(--space-3);
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-sm);
  font-size: var(--text-sm);
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--accent);
  background: rgba(255, 255, 255, 0.06);
}

.form-input::placeholder {
  color: var(--text-tertiary);
}

.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  color: var(--text-tertiary);
  font-size: 18px;
}

.form-textarea {
  width: 100%;
  min-height: 80px;
  padding: var(--space-3);
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-sm);
  font-size: var(--text-sm);
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-textarea:focus {
  border-color: var(--accent);
  background: rgba(255, 255, 255, 0.06);
}

.form-textarea::placeholder {
  color: var(--text-tertiary);
}

.char-count {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  text-align: right;
  margin-top: 4px;
  display: block;
}

.more-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: var(--space-3);
  margin-top: 4px;
  cursor: pointer;
}

.more-toggle-text {
  font-size: var(--text-sm);
  color: var(--accent);
}

.more-toggle-icon {
  font-size: 12px;
  color: var(--accent);
}

.more-divider {
  border: none;
  border-top: 1px dashed var(--border-subtle);
  margin: var(--space-4) 0;
}

.avatar-upload {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 2px dashed var(--border-default);
  margin-bottom: var(--space-4);
  position: relative;
}

.avatar-upload image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.03);
}

.avatar-icon {
  font-size: 24px;
  margin-bottom: 4px;
}

.avatar-text {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
}

.images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.image-item {
  width: calc(33.33% - 7px);
  aspect-ratio: 4/3;
  border-radius: var(--radius-sm);
  overflow: hidden;
  position: relative;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 24px;
  height: 24px;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
}

.image-add {
  width: calc(33.33% - 7px);
  aspect-ratio: 4/3;
  border: 2px dashed var(--border-default);
  border-radius: var(--radius-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.03);
}

.image-add-icon {
  font-size: 24px;
  color: var(--text-tertiary);
}

.image-add-text {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 4px;
}

/* Resource Tags */
.resource-input-row {
  display: flex;
  gap: var(--space-2);
}

.resource-input {
  flex: 1;
}

.btn-add {
  padding: 0 20px;
  height: 44px;
  background: var(--gradient-accent);
  color: #fff;
  border-radius: var(--radius-sm);
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 44px;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: var(--space-2);
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 6px 12px;
  background: rgba(139, 92, 246, 0.12);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  color: var(--accent-light);
}

.tag-item.needs-tag {
  background: rgba(245, 158, 11, 0.12);
  color: var(--warning);
}

.tag-text {
  margin-right: 6px;
}

.tag-close {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.4);
}

/* Purpose Options */
.purpose-options {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-2);
}

.purpose-option {
  display: flex;
  align-items: center;
  padding: 14px;
  background: rgba(255, 255, 255, 0.03);
  border: 1.5px solid transparent;
  border-radius: var(--radius-md);
}

.purpose-option.active {
  background: rgba(139, 92, 246, 0.1);
  border-color: rgba(139, 92, 246, 0.3);
}

.purpose-icon {
  font-size: 20px;
  margin-right: 10px;
}

.purpose-label {
  font-size: var(--text-sm);
  color: var(--text-primary);
}

/* Case Items */
.case-list {
  margin-bottom: var(--space-4);
}

.case-item {
  padding: 14px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-3);
}

.case-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.case-title {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
}

.case-delete {
  font-size: var(--text-sm);
  color: var(--danger);
}

.btn-add-case {
  width: 100%;
  height: 44px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px dashed var(--border-default);
  color: var(--text-tertiary);
  border-radius: var(--radius-sm);
}

/* Style Options */
.style-options {
  display: flex;
  gap: var(--space-3);
}

.style-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14px 10px;
  background: rgba(255, 255, 255, 0.03);
  border: 1.5px solid transparent;
  border-radius: var(--radius-md);
}

.style-option.active {
  background: rgba(139, 92, 246, 0.1);
  border-color: rgba(139, 92, 246, 0.3);
}

.style-preview {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-sm);
  margin-bottom: 10px;
}

.style-name {
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  color: var(--text-primary);
  margin-bottom: 4px;
}

.style-desc {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  text-align: center;
}

/* Submit Area */
.submit-area {
  padding: var(--space-4);
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom));
  margin-top: var(--space-4);
}

.btn-submit {
  width: 100%;
  height: 48px;
  background: var(--gradient-accent);
  color: #fff;
  border-radius: var(--radius-sm);
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  border: none;
}
