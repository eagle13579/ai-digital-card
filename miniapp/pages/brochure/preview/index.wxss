.preview-container {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

.page-swiper {
  width: 100%;
  height: 100%;
}

.page-wrapper {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  box-sizing: border-box;
}

.page-content {
  width: 100%;
  max-width: 600rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
  display: block;
}

.section-subtitle {
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
  display: block;
}

.cover-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.cover-avatar image {
  width: 100%;
  height: 100%;
}

.cover-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  margin-bottom: 12rpx;
}

.cover-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  margin-bottom: 30rpx;
}

.cover-badge {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
  background: rgba(255, 255, 255, 0.1);
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin: 0 auto;
}

.profile-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
}

.profile-avatar image {
  width: 100%;
  height: 100%;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}

.profile-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 4rpx;
}

.profile-company {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.profile-bio {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.bio-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}

.contact-list {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  overflow: hidden;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.contact-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  width: 80rpx;
}

.contact-value {
  font-size: 26rpx;
  color: #fff;
  flex: 1;
}

.resources-section {
  margin-bottom: 24rpx;
}

.resources-label {
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
  display: block;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  font-size: 24rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.company-info {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.company-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.company-meta {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.meta-divider {
  margin: 0 12rpx;
  color: rgba(255, 255, 255, 0.4);
}

.company-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

.milestones {
  margin-bottom: 24rpx;
}

.milestone-list {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx;
}

.milestone-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.milestone-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #fff;
  margin-right: 16rpx;
  margin-top: 8rpx;
}

.milestone-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.case-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.case-item {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 16rpx;
}

.case-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}

.case-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.case-card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.case-card:last-child {
  margin-bottom: 0;
}

.case-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.case-card-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
}

.contact-card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  overflow: hidden;
}

.contact-card-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.contact-card-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
}

.contact-card-avatar image {
  width: 100%;
  height: 100%;
}

.contact-card-info {
  flex: 1;
}

.contact-card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}

.contact-card-company {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.contact-card-list {
  padding: 20rpx;
}

.contact-card-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.contact-card-item:last-child {
  margin-bottom: 0;
}

.contact-card-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.contact-card-value {
  font-size: 26rpx;
  color: #fff;
}

.page-indicator {
  position: absolute;
  bottom: 40rpx;
  right: 30rpx;
  background: rgba(0, 0, 0, 0.3);
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
}

.indicator-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}