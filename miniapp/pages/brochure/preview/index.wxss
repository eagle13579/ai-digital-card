/* 降级方案: 微信低版本不支持backdrop-filter时，使用 rgba(20,20,24,0.85) + filter:blur() 替代 */
.preview-container {
  height: 100vh;
  background: #1a1a2e;
  display: flex;
  flex-direction: column;
}

.preview-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 88rpx 20px 16px;
  z-index: 100;
  background: linear-gradient(to bottom, rgba(26, 26, 46, 0.95), transparent);
}

.back-btn {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  backdrop-filter: blur(10px);
}

.back-icon {
  font-size: 64rpx;
  color: #fff;
  font-weight: 300;
}

.page-indicator {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.share-btn {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  backdrop-filter: blur(10px);
}

.share-icon {
  font-size: 48rpx;
  color: #fff;
}

.brochure-swiper {
  flex: 1;
  padding-top: 160rpx;
  padding-bottom: 160rpx;
}

.brochure-page {
  width: 90%;
  height: calc(100vh - 160px);
  margin: 0 auto;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  display: flex;
  flex-direction: column;
  padding: 64rpx;
  box-sizing: border-box;
}

.cover-content {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.cover-avatar-wrap {
  margin-bottom: 48rpx;
}

.cover-avatar {
  width: 280rpx;
  height: 280rpx;
  border-radius: 140rpx;
  border: 4px solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
}

.cover-avatar-placeholder {
  width: 280rpx;
  height: 280rpx;
  border-radius: 140rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-avatar-emoji {
  font-size: 112rpx;
}

.cover-title {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 24rpx;
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
}

.cover-subtitle {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 48rpx;
}

.cover-badge-wrap {
  margin-top: auto;
}

.cover-badge {
  display: inline-block;
  padding: 16rpx 24px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #fff;
  backdrop-filter: blur(10px);
}

.profile-content {
  width: 100%;
  height: 100%;
  background: #fff;
  display: flex;
  flex-direction: column;
}

.profile-header {
  display: flex;
  align-items: center;
  margin-bottom: 48rpx;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  overflow: hidden;
  border: 3px solid #EEF2FF;
  margin-right: 32rpx;
}

.profile-avatar-placeholder {
  width: 100%;
  height: 100%;
  background: #EEF2FF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 64rpx;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
  margin-bottom: 8rpx;
}

.profile-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4F46E5;
  display: block;
  margin-bottom: 8rpx;
}

.profile-company {
  font-size: 28rpx;
  color: #64748B;
  display: block;
}

.profile-bio {
  margin-bottom: 40rpx;
}

.bio-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
  margin-bottom: 24rpx;
}

.bio-content {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.6;
}

.profile-contact {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 16px;
  background: #EEF2FF;
  border-radius: 20rpx;
}

.contact-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.contact-text {
  font-size: 26rpx;
  color: #4F46E5;
}

.resources-content {
  width: 100%;
  height: 100%;
  background: #fff;
  display: flex;
  flex-direction: column;
}

.section-title-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
  margin-bottom: 40rpx;
}

.resources-section {
  margin-bottom: 40rpx;
}

.resources-label {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 24rpx;
}

.provides-label {
  color: #3B82F6;
}

.needs-label {
  color: #F59E0B;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag {
  padding: 16rpx 16px;
  border-radius: 16rpx;
  font-size: 26rpx;
}

.provides-tag {
  background: #DBEAFE;
  color: #1D4ED8;
}

.needs-tag {
  background: #FEF3C7;
  color: #D97706;
}

.purpose-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: #F8FAFC;
  border-radius: 24rpx;
  margin-top: 24rpx;
}

.purpose-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.purpose-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #4F46E5;
}

.company-content {
  width: 100%;
  height: 100%;
  background: #fff;
  display: flex;
  flex-direction: column;
}

.company-header {
  margin-bottom: 32rpx;
}

.company-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
  margin-bottom: 16rpx;
}

.company-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  font-size: 28rpx;
  color: #64748B;
}

.meta-divider {
  margin: 0 12px;
  color: #CBD5E1;
}

.company-desc {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.development-section {
  background: #FEF3C7;
  padding: 32rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
}

.development-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #92400E;
  display: block;
  margin-bottom: 16rpx;
}

.development-content {
  font-size: 26rpx;
  color: #78350F;
  line-height: 1.6;
  white-space: pre-line;
}

.company-images {
  display: flex;
  gap: 16rpx;
}

.company-image {
  flex: 1;
  height: 200rpx;
  border-radius: 16rpx;
}

.case-content {
  width: 100%;
  height: 100%;
  background: #fff;
  display: flex;
  flex-direction: column;
}

.case-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
  margin-bottom: 16rpx;
}

.case-date {
  font-size: 26rpx;
  color: #94A3B8;
  display: block;
  margin-bottom: 32rpx;
}

.case-desc {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.case-images {
  display: flex;
  gap: 16rpx;
}

.case-image {
  flex: 1;
  height: 200rpx;
  border-radius: 16rpx;
}

.contact-content {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.contact-card {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 32rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 48rpx;
  backdrop-filter: blur(10px);
}

.contact-card-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}

.contact-card-company {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.contact-list {
  width: 100%;
}

.contact-list-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.contact-list-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.contact-list-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  flex: 1;
}

.contact-list-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.preview-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx 20px;
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(26, 26, 46, 0.95), transparent);
  z-index: 100;
}

.dots-wrap {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 8rpx;
  transition: all 0.3s;
}

.dot.active {
  width: 48rpx;
  background: #fff;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  border-radius: 40rpx;
  box-shadow: 0 8px 24px rgba(79, 70, 229, 0.4);
}

.empty-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}