/* 首页样式 - v2.0 Dark Minimal */
@import '../../app.wxss';

.page-scroll {
  height: 100vh;
}

/* ===== User Hero Header ===== */
.user-hero {
  position: relative;
  padding: 32px 20px 28px;
  background: linear-gradient(135deg, #1a1a2e 0%, #0f0f1a 100%);
  overflow: hidden;
}

.user-hero::before {
  content: '';
  position: absolute;
  top: -40%;
  right: -20%;
  width: 200px;
  height: 200px;
  background: radial-gradient(circle, rgba(139,92,246,0.15) 0%, transparent 70%);
  pointer-events: none;
}

.user-hero::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 160px;
  height: 160px;
  background: radial-gradient(circle, rgba(6,182,212,0.1) 0%, transparent 70%);
  pointer-events: none;
}

.user-hero-row {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.user-avatar-wrap {
  position: relative;
  width: 64px;
  height: 64px;
  border-radius: var(--radius-full);
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 14px;
  border: 2px solid rgba(139, 92, 246, 0.3);
  box-shadow: 0 0 16px rgba(139, 92, 246, 0.15);
}

.user-avatar-wrap image {
  width: 100%;
  height: 100%;
}

.member-badge {
  position: absolute;
  bottom: -2px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 9px;
  padding: 1px 8px;
  border-radius: 8px;
  white-space: nowrap;
  border: 2px solid var(--surface-primary);
}

.user-meta {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  margin-bottom: 2px;
}

.user-position {
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

/* Stats Row — 右上角 */
.user-stats-row {
  position: absolute;
  top: 12px;
  right: 16px;
  display: flex;
  gap: var(--space-4);
  z-index: 2;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
}

.stat-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 1px;
}

/* ===== Action Bar ===== */
.action-bar {
  display: flex;
  justify-content: space-around;
  margin: -12px 16px 0;
  padding: var(--space-4);
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  position: relative;
  z-index: 2;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4px 12px;
}

.action-item:active {
  opacity: 0.7;
}

.action-icon {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: var(--text-primary);
  margin-bottom: 4px;
  background: rgba(139, 92, 246, 0.1);
  border-radius: var(--radius-sm);
}

.action-label {
  font-size: var(--text-xs);
  color: var(--text-secondary);
}

/* ===== Glass Card Overrides ===== */
.glass-card {
  margin-bottom: 0;
}

/* Scene Mode */
.scene-mode-content {
  padding: 0 var(--space-4) var(--space-4);
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.scene-option {
  display: flex;
  align-items: center;
  padding: 14px;
  background: rgba(255, 255, 255, 0.03);
  border: 1.5px solid transparent;
  border-radius: var(--radius-md);
  transition: all 0.2s;
}

.scene-option.active {
  background: rgba(139, 92, 246, 0.1);
  border-color: rgba(139, 92, 246, 0.3);
}

.scene-icon {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(139, 92, 246, 0.1);
  border-radius: var(--radius-sm);
  font-size: 18px;
  margin-right: 12px;
  flex-shrink: 0;
}

.scene-label {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  display: block;
}

.scene-desc {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  display: block;
  margin-top: 1px;
}

/* Brochure Card */
.brochure-cover {
  position: relative;
  height: 160px;
}

.brochure-cover image {
  width: 100%;
  height: 100%;
}

.brochure-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40px 16px 12px;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
}

.brochure-name {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: #ffffff;
  display: block;
}

.brochure-stats {
  font-size: var(--text-xs);
  color: rgba(255, 255, 255, 0.7);
  margin-top: 2px;
}

/* Platform Entry */
.platform-entry-card {
  overflow: hidden;
  padding: 0 !important;
  margin-top: 4px;
}

.platform-entry-bg {
  background: linear-gradient(135deg, rgba(139,92,246,0.2) 0%, rgba(6,182,212,0.15) 100%);
  border-radius: var(--radius-md);
}

.platform-entry-content {
  display: flex;
  align-items: center;
  padding: var(--space-4);
}

.platform-entry-icon {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(139, 92, 246, 0.2);
  border-radius: var(--radius-sm);
  font-size: 20px;
  margin-right: 14px;
  flex-shrink: 0;
}

.platform-entry-text {
  flex: 1;
  min-width: 0;
}

.platform-entry-title {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  display: block;
}

.platform-entry-desc {
  font-size: var(--text-xs);
  color: var(--text-secondary);
  margin-top: 2px;
  display: block;
}

.platform-entry-arrow {
  font-size: 22px;
  color: var(--text-tertiary);
  flex-shrink: 0;
  margin-left: var(--space-2);
}

/* Trust Summary */
.trust-summary {
  padding: 0 var(--space-4) var(--space-4);
}

.trust-count {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-bottom: 10px;
  display: block;
}

.trust-avatars {
  display: flex;
  align-items: center;
}

.trust-avatar {
  width: 36px;
  height: 36px;
  border-radius: var(--radius-full);
  border: 2px solid var(--surface-primary);
  margin-right: -8px;
}

.trust-more {
  width: 36px;
  height: 36px;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  border: 2px solid var(--surface-primary);
  margin-left: 2px;
}

/* Recommend List */
.recommend-list {
  padding: 0 var(--space-4) var(--space-4);
}

.recommend-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid var(--border-subtle);
}

.recommend-item:last-child {
  border-bottom: none;
}

.rec-avatar {
  width: 44px;
  height: 44px;
  border-radius: var(--radius-full);
  flex-shrink: 0;
  margin-right: 10px;
  border: 1px solid var(--border-subtle);
}

.rec-info {
  flex: 1;
  min-width: 0;
}

.rec-name {
  font-size: var(--text-base);
  font-weight: var(--weight-medium);
  color: var(--text-primary);
  display: block;
}

.rec-company {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  display: block;
  margin-top: 1px;
}

.rec-tags {
  display: flex;
  margin-top: 4px;
}

.rec-tag {
  font-size: 10px;
  padding: 2px 8px;
  background: rgba(139, 92, 246, 0.12);
  color: var(--accent-light);
  border-radius: var(--radius-full);
  margin-right: 6px;
}

.rec-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-left: var(--space-2);
}

.score-num {
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
  color: var(--success);
}

.score-lbl {
  font-size: 10px;
  color: var(--text-tertiary);
}
