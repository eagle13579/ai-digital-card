/* 首页样式 */

.page-scroll {
  height: 100vh;
}

/* 升级提示条 */
.upgrade-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #f5a623 0%, #f7d94c 100%);
  padding: 10px 16px;
  position: relative;
}

.hint-content {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8px;
}

.hint-icon {
  font-size: 16px;
  flex-shrink: 0;
}

.hint-text {
  flex: 1;
  font-size: 13px;
  color: #fff;
  font-weight: 500;
  line-height: 1.4;
}

.hint-action {
  font-size: 13px;
  color: #fff;
  font-weight: 700;
  flex-shrink: 0;
  background: rgba(255,255,255,0.2);
  padding: 4px 12px;
  border-radius: 12px;
}

.hint-close {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8px;
  flex-shrink: 0;
}

.hint-close text {
  font-size: 14px;
  color: rgba(255,255,255,0.6);
}

/* 用户头部 */
.user-header {
  display: flex;
  align-items: center;
  padding: 24px 16px 16px;
  background: linear-gradient(135deg, #1657ff, #4a7aff);
  color: #fff;
}

.user-avatar {
  position: relative;
  width: 64px;
  height: 64px;
  border-radius: 32px;
  overflow: hidden;
  border: 2px solid rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
  margin-right: 14px;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-avatar .member-badge {
  position: absolute;
  bottom: -4px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 10px;
  padding: 1px 8px;
  border-radius: 8px;
  white-space: nowrap;
  border: 2px solid #fff;
}

.user-meta {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 2px;
}

.user-position {
  font-size: 13px;
  opacity: 0.85;
}

.user-stats {
  display: flex;
  gap: 16px;
  margin-left: 8px;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 18px;
  font-weight: 700;
}

.stat-label {
  font-size: 11px;
  opacity: 0.75;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 16px;
  background: #fff;
  margin: -8px 16px 0;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 1;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4px 12px;
}

.action-icon {
  font-size: 24px;
  margin-bottom: 4px;
}

.action-label {
  font-size: 12px;
  color: #666;
}

/* 画册封面卡片 */
.brochure-card {
  padding: 0 !important;
  overflow: hidden;
}

.brochure-cover {
  position: relative;
  height: 160px;
}

.brochure-cover image {
  width: 100%;
  height: 100%;
}

.brochure-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40px 16px 12px;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
}

.brochure-name {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
  display: block;
}

.brochure-stats {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 2px;
}

/* 信任摘要 */
.trust-summary {
  padding: 0 16px 16px;
}

.trust-count {
  font-size: 14px;
  color: #666;
  margin-bottom: 10px;
  display: block;
}

.trust-avatars {
  display: flex;
  align-items: center;
}

.trust-avatar {
  width: 36px;
  height: 36px;
  border-radius: 18px;
  border: 2px solid #fff;
  margin-right: -8px;
}

.trust-more {
  width: 36px;
  height: 36px;
  border-radius: 18px;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: #999;
  border: 2px solid #fff;
  margin-left: 2px;
}

/* 推荐列表 */
.recommend-list {
  padding: 0 16px 16px;
}

.recommend-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f5f5f5;
}

.recommend-item:last-child {
  border-bottom: none;
}

.rec-avatar {
  width: 44px;
  height: 44px;
  border-radius: 22px;
  flex-shrink: 0;
  margin-right: 10px;
}

.rec-info {
  flex: 1;
  min-width: 0;
}

.rec-name {
  font-size: 15px;
  font-weight: 500;
  color: #1a1a1a;
  display: block;
}

.rec-company {
  font-size: 12px;
  color: #999;
  display: block;
  margin-top: 1px;
}

.rec-tags {
  display: flex;
  margin-top: 4px;
}

.rec-tag {
  font-size: 10px;
  padding: 2px 8px;
  background: rgba(22, 87, 255, 0.08);
  color: #1657ff;
  border-radius: 10px;
  margin-right: 6px;
}

.rec-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-left: 8px;
}

.score-num {
  font-size: 18px;
  font-weight: 700;
  color: #07c160;
}

.score-lbl {
  font-size: 10px;
  color: #999;
}

/* 底部 */
.bottom-placeholder {
  height: 80px;
}

/* 创建资源平台入口卡片 */
.platform-entry {
  overflow: hidden;
  padding: 0 !important;
  margin-top: 4px;
}
.platform-entry-bg {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: var(--radius-md);
}
.platform-entry-content {
  display: flex;
  align-items: center;
  padding: 16px;
}
.platform-entry-icon {
  font-size: 32px;
  margin-right: 14px;
  flex-shrink: 0;
}
.platform-entry-text {
  flex: 1;
  min-width: 0;
}
.platform-entry-title {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
  display: block;
}
.platform-entry-desc {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 2px;
  display: block;
}
.platform-entry-arrow {
  font-size: 24px;
  color: rgba(255, 255, 255, 0.6);
  flex-shrink: 0;
  margin-left: 8px;
}

/* 平台推荐 */
.platform-recommend {
  display: flex;
  overflow-x: auto;
  padding: 0 16px 16px;
  gap: 12px;
  scrollbar-width: none;
}
.platform-recommend::-webkit-scrollbar {
  display: none;
}
.platform-card {
  flex: 0 0 140px;
  border-radius: 12px;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
.platform-card-top {
  height: 80px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.platform-card-emoji {
  font-size: 32px;
}
.platform-card-name {
  font-size: 14px;
  font-weight: 600;
  color: #333;
  display: block;
  padding: 8px 10px 2px;
}
.platform-card-desc {
  font-size: 11px;
  color: #999;
  display: block;
  padding: 0 10px 10px;
  line-height: 1.4;
}
