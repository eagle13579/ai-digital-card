/* 首页样式 */

.page-scroll {
  height: 100vh;
}

/* 升级提示条 */
.upgrade-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #f5a623 0%, #f7d94c 100%);
  padding: 20rpx 16px;
  position: relative;
}

.hint-content {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.hint-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.hint-text {
  flex: 1;
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
  line-height: 1.4;
}

.hint-action {
  font-size: 26rpx;
  color: #fff;
  font-weight: 700;
  flex-shrink: 0;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 12px;
  border-radius: 24rpx;
}

.hint-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.hint-close text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
}

/* 用户头部 */
.user-header {
  display: flex;
  align-items: center;
  padding: 48rpx 16px 16px;
  background: linear-gradient(135deg, #1657ff, #4a7aff);
  color: #fff;
}

.user-avatar {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  border-radius: 64rpx;
  overflow: hidden;
  border: 2px solid rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
  margin-right: 28rpx;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-avatar .member-badge {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 20rpx;
  padding: 2rpx 8px;
  border-radius: 16rpx;
  white-space: nowrap;
  border: 2px solid #fff;
}

.user-meta {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.user-position {
  font-size: 26rpx;
  opacity: 0.85;
}

.user-stats {
  display: flex;
  gap: 32rpx;
  margin-left: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.75;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
  background: #fff;
  margin: -16rpx 16px 0;
  border-radius: 24rpx;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 1;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 12px;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-label {
  font-size: 24rpx;
  color: #666;
}

/* AI能力中心入口卡片 */
.ai-entry-card {
  margin: 32rpx;
  padding: 0 !important;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(99, 102, 241, 0.15);
}
.ai-entry-bg {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}
.ai-entry-content {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}
.ai-entry-icon-wrap {
  width: 104rpx;
  height: 104rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
}
.ai-entry-icon {
  font-size: 56rpx;
}
.ai-entry-text {
  flex: 1;
  min-width: 0;
}
.ai-entry-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}
.ai-entry-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: block;
}
.ai-entry-arrow {
  font-size: 44rpx;
  color: rgba(255,255,255,0.6);
  margin-left: 16rpx;
  flex-shrink: 0;
}
.ai-entry-glow {
  position: absolute;
  top: -50%;
  right: -20%;
  width: 240rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
  animation: aiGlow 4s ease-in-out infinite;
}
@keyframes aiGlow {
  0%, 100% { transform: translateY(0); opacity: 0.5; }
  50% { transform: translateY(-10px); opacity: 1; }
}

/* 画册封面卡片 */
.brochure-card {
  padding: 0 !important;
  overflow: hidden;
}

.brochure-cover {
  position: relative;
  height: 320rpx;
}

.brochure-cover image {
  width: 100%;
  height: 100%;
}

.brochure-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 80rpx 16px 12px;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
}

.brochure-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}

.brochure-stats {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* 信任摘要 */
.trust-summary {
  padding: 0 16px 16px;
}

.trust-count {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.trust-avatars {
  display: flex;
  align-items: center;
}

.trust-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  border: 2px solid #fff;
  margin-right: -16rpx;
}

.trust-more {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
  border: 2px solid #fff;
  margin-left: 4rpx;
}

/* 推荐列表 */
.recommend-list {
  padding: 0 16px 16px;
}

.recommend-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid #f5f5f5;
}

.recommend-item:last-child {
  border-bottom: none;
}

.rec-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.rec-info {
  flex: 1;
  min-width: 0;
}

.rec-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  display: block;
}

.rec-company {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 2rpx;
}

.rec-tags {
  display: flex;
  margin-top: 8rpx;
}

.rec-tag {
  font-size: 20rpx;
  padding: 4rpx 8px;
  background: rgba(22, 87, 255, 0.08);
  color: #1657ff;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.rec-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.score-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #07c160;
}

.score-lbl {
  font-size: 20rpx;
  color: #999;
}

/* 底部 */
.bottom-placeholder {
  height: 160rpx;
}

/* 创建资源平台入口卡片 */
.platform-entry {
  overflow: hidden;
  padding: 0 !important;
  margin-top: 8rpx;
}
.platform-entry-bg {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: var(--radius-md);
}
.platform-entry-content {
  display: flex;
  align-items: center;
  padding: 32rpx;
}
.platform-entry-icon {
  font-size: 64rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}
.platform-entry-text {
  flex: 1;
  min-width: 0;
}
.platform-entry-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}
.platform-entry-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 4rpx;
  display: block;
}
.platform-entry-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.6);
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 平台推荐 */
.platform-recommend {
  display: flex;
  overflow-x: auto;
  padding: 0 16px 16px;
  gap: 24rpx;
  scrollbar-width: none;
}
.platform-recommend::-webkit-scrollbar {
  display: none;
}
.platform-card {
  flex: 0 0 140px;
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
.platform-card-top {
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.platform-card-emoji {
  font-size: 64rpx;
}
.platform-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  padding: 16rpx 10px 2px;
}
.platform-card-desc {
  font-size: 22rpx;
  color: #999;
  display: block;
  padding: 0 10px 10px;
  line-height: 1.4;
}
