/**
 * 首页样式 — AI原生暗色版
 * Token体系: tokens.wxss (山膏设计系统 v1.0)
 * 方向: 冷峻轻奢 · 玻璃三层 · 光晕Orb · 三重渐变
 * 降级方案: 微信低版本不支持backdrop-filter时，使用 rgba(20,20,24,0.85) + filter:blur() 替代
 */
@import '../../styles/tokens.wxss';

/* ========== 1. 光晕背景层 ========== */
.orb-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
  background:
    /* 主光晕 — 紫色扩散 (右上) */
    radial-gradient(ellipse 60% 50% at 80% 10%, rgba(139, 92, 246, 0.25) 0%, transparent 70%),
    /* 副光晕 — 青色扩散 (左下) */
    radial-gradient(ellipse 50% 60% at 10% 80%, rgba(6, 182, 212, 0.15) 0%, transparent 70%),
    /* 氛围光 — 粉色微光 (中下) */
    radial-gradient(ellipse 40% 40% at 50% 90%, rgba(236, 72, 153, 0.10) 0%, transparent 60%);
  animation: orb-breathe 8s ease-in-out infinite;
}

@keyframes orb-breathe {
  0%, 100% {
    opacity: 0.8;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.02);
  }
}

/* ========== 2. 页面容器 ========== */
.page-container {
  position: relative;
  z-index: 1;
}

.page-container.dark {
  background: var(--bg-page);
  min-height: 100vh;
}

.page-scroll {
  height: 100vh;
  position: relative;
  z-index: 1;
}

/* ========== 3. 升级提示条 ========== */
.upgrade-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--home-upgrade-bg);
  padding: var(--space-5) var(--space-6);
  position: relative;
}

.hint-content {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

.hint-icon {
  font-size: var(--text-xl);
  flex-shrink: 0;
}

.hint-text {
  flex: 1;
  font-size: var(--text-base);
  color: var(--text-primary);
  font-weight: 500;
  line-height: var(--text-base-lh);
  font-family: var(--font-sc);
}

.hint-action {
  font-size: var(--text-sm);
  color: var(--text-primary);
  font-weight: 600;
  flex-shrink: 0;
  background: var(--bg-glass-1);
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-full);
  backdrop-filter: blur(var(--glass-blur-1));
  -webkit-backdrop-filter: blur(var(--glass-blur-1));
}

.hint-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: var(--space-4);
  flex-shrink: 0;
}

.hint-close text {
  font-size: var(--text-base);
  color: var(--text-tertiary);
}

/* ========== 4. 用户头部 ========== */
.user-header {
  display: flex;
  align-items: center;
  padding: var(--user-header-padding);
  background: var(--bg-glass-1);
  backdrop-filter: blur(var(--glass-blur-1));
  -webkit-backdrop-filter: blur(var(--glass-blur-1));
  color: var(--text-primary);
  margin: var(--space-6);
  border-radius: var(--radius-xl);
  border: var(--glass-border-1);
  position: relative;
  box-shadow: var(--orb-sm);
}

.user-header::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: var(--radius-xl);
  background: var(--shadow-glass-edge);
  pointer-events: none;
}

.user-avatar {
  position: relative;
  width: var(--user-header-avatar-size);
  height: var(--user-header-avatar-size);
  border-radius: 50%;
  overflow: hidden;
  border: var(--user-header-avatar-border);
  flex-shrink: 0;
  margin-right: var(--space-6);
  box-shadow: var(--user-header-avatar-orb);
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-avatar .member-badge {
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: var(--text-xs);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  white-space: nowrap;
  border: 1.5px solid rgba(255, 255, 255, 0.2);
  background: var(--bg-glass-2);
  backdrop-filter: blur(var(--glass-blur-1));
  -webkit-backdrop-filter: blur(var(--glass-blur-1));
  color: var(--text-primary);
  font-family: var(--font-mono);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
}

.user-meta {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: var(--user-header-name-size);
  font-weight: 600;
  margin-bottom: var(--space-1);
  font-family: var(--font-sc);
  letter-spacing: var(--tracking-tight);
  color: var(--text-primary);
}

.user-position {
  font-size: var(--user-header-pos-size);
  color: var(--text-secondary);
  font-family: var(--font-sc);
}

.user-stats {
  display: flex;
  gap: var(--stat-gap);
  margin-left: var(--space-4);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: var(--stat-number-size);
  font-weight: var(--stat-number-weight);
  color: var(--stat-number-color);
  font-family: var(--font-mono);
  letter-spacing: var(--tracking-tight);
}

.stat-label {
  font-size: var(--stat-label-size);
  color: var(--stat-label-color);
  font-family: var(--font-sc);
}

/* ========== 5. 操作栏 ========== */
.action-bar {
  display: flex;
  justify-content: space-around;
  padding: var(--space-8);
  background: var(--home-action-bar-bg);
  margin: 0 var(--home-action-bar-margin);
  margin-top: -16rpx;
  border-radius: var(--home-action-bar-radius);
  border: var(--home-action-bar-border);
  position: relative;
  z-index: 2;
  backdrop-filter: blur(var(--glass-blur-1));
  -webkit-backdrop-filter: blur(var(--glass-blur-1));
  box-shadow: var(--orb-sm);
}

.action-bar::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: var(--home-action-bar-radius);
  background: var(--shadow-glass-edge);
  pointer-events: none;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-2) var(--space-4);
  transition: var(--transition-scale);
}

.action-item:active {
  transform: var(--card-active-scale);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: var(--space-2);
  filter: drop-shadow(0 0 6px rgba(139, 92, 246, 0.15));
}

.action-label {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  font-family: var(--font-sc);
}

/* ========== 6. AI能力中心入口卡片 ========== */
.ai-entry-card {
  margin: var(--space-8);
  padding: 0 !important;
  border-radius: var(--home-ai-entry-radius) !important;
  overflow: hidden;
  box-shadow: var(--home-ai-entry-orb);
}

.ai-entry-bg {
  background: var(--gradient-primary);
  padding: var(--space-10);
  position: relative;
  overflow: hidden;
}

.ai-entry-content {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.ai-entry-icon-wrap {
  width: 104rpx;
  height: 104rpx;
  background: var(--bg-glass-1);
  border: var(--glass-border-1);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-6);
  flex-shrink: 0;
  backdrop-filter: blur(var(--glass-blur-1));
  -webkit-backdrop-filter: blur(var(--glass-blur-1));
}

.ai-entry-icon {
  font-size: 56rpx;
  filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.2));
}

.ai-entry-text {
  flex: 1;
  min-width: 0;
}

.ai-entry-title {
  font-size: var(--text-xl);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-2);
  font-family: var(--font-sc);
  letter-spacing: var(--tracking-tight);
}

.ai-entry-desc {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  display: block;
  font-family: var(--font-sc);
}

.ai-entry-arrow {
  font-size: 44rpx;
  color: var(--text-tertiary);
  margin-left: var(--space-4);
  flex-shrink: 0;
}

.ai-entry-glow {
  position: absolute;
  top: -50%;
  right: -20%;
  width: 240rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, transparent 70%);
  border-radius: 50%;
  animation: aiGlow 4s ease-in-out infinite;
}

@keyframes aiGlow {
  0%, 100% { transform: translateY(0); opacity: 0.5; }
  50% { transform: translateY(-10px); opacity: 1; }
}

/* ========== 7. 画册封面卡片 ========== */
.brochure-card {
  padding: 0 !important;
  overflow: hidden;
  border: var(--glass-border-2);
  box-shadow: var(--orb-md);
}

.brochure-card .card-header {
  padding: var(--space-8) var(--space-6) var(--space-3);
}

.brochure-card .card-header .title {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
  font-family: var(--font-sc);
  letter-spacing: var(--tracking-tight);
}

.brochure-card .card-header .more {
  font-size: var(--text-sm);
  color: var(--text-accent);
  font-family: var(--font-sc);
}

.brochure-cover {
  position: relative;
  height: 320rpx;
}

.brochure-cover image {
  width: 100%;
  height: 100%;
}

.brochure-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 80rpx var(--space-6) var(--space-4);
  background: linear-gradient(transparent, rgba(10, 10, 24, 0.85));
}

.brochure-name {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  font-family: var(--font-sc);
}

.brochure-stats {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-top: var(--space-1);
  font-family: var(--font-mono);
}

/* ========== 8. 创建资源平台入口卡片 ========== */
.platform-entry {
  overflow: hidden;
  padding: 0 !important;
  margin-top: var(--space-2);
  border-radius: var(--radius-lg);
  box-shadow: var(--orb-md);
}

.platform-entry-bg {
  background: var(--gradient-cyan-purple);
  border-radius: var(--radius-lg);
}

.platform-entry-content {
  display: flex;
  align-items: center;
  padding: var(--space-8);
}

.platform-entry-icon {
  font-size: 64rpx;
  margin-right: var(--space-6);
  flex-shrink: 0;
  filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.15));
}

.platform-entry-text {
  flex: 1;
  min-width: 0;
}

.platform-entry-title {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  font-family: var(--font-sc);
  letter-spacing: var(--tracking-tight);
}

.platform-entry-desc {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-top: var(--space-1);
  display: block;
  font-family: var(--font-sc);
}

.platform-entry-arrow {
  font-size: 48rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
  margin-left: var(--space-4);
}

/* ========== 9. 信任网络卡片 ========== */
.trust-summary {
  padding: 0 var(--space-6) var(--space-6);
}

.trust-count {
  font-size: var(--text-base);
  color: var(--text-secondary);
  margin-bottom: var(--space-5);
  display: block;
  font-family: var(--font-sc);
}

.trust-avatars {
  display: flex;
  align-items: center;
}

.trust-avatar {
  width: var(--avatar-stack-size);
  height: var(--avatar-stack-size);
  border-radius: 50%;
  border: var(--avatar-stack-border);
  margin-right: var(--avatar-stack-overlap);
}

.trust-more {
  width: var(--avatar-stack-size);
  height: var(--avatar-stack-size);
  border-radius: 50%;
  background: var(--bg-glass-2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  border: var(--avatar-stack-border);
  margin-left: var(--space-1);
  backdrop-filter: blur(var(--glass-blur-1));
  -webkit-backdrop-filter: blur(var(--glass-blur-1));
  font-family: var(--font-mono);
}

/* ========== 10. 推荐匹配列表 ========== */
.recommend-list {
  padding: 0 var(--space-6) var(--space-6);
}

.recommend-item {
  display: flex;
  align-items: center;
  padding: var(--space-6) 0;
  border-bottom: 1px solid var(--border-subtle);
}

.recommend-item:last-child {
  border-bottom: none;
}

.rec-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: var(--space-5);
  border: var(--avatar-stack-border);
  box-shadow: var(--orb-sm);
}

.rec-info {
  flex: 1;
  min-width: 0;
}

.rec-name {
  font-size: var(--text-lg);
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  font-family: var(--font-sc);
}

.rec-company {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  display: block;
  margin-top: var(--space-1);
  font-family: var(--font-sc);
}

.rec-tags {
  display: flex;
  margin-top: var(--space-2);
}

.rec-tag {
  font-size: var(--text-xs);
  padding: var(--space-1) var(--space-3);
  background: var(--bg-glass-1);
  border: var(--glass-border-1);
  color: var(--text-accent);
  border-radius: var(--radius-full);
  margin-right: var(--space-3);
  font-family: var(--font-sc);
}

.rec-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-left: var(--space-4);
}

.score-num {
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--success);
  font-family: var(--font-mono);
  letter-spacing: var(--tracking-tight);
}

.score-lbl {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  font-family: var(--font-sc);
}

/* ========== 11. 底部占位 ========== */
.bottom-placeholder {
  height: 160rpx;
}

/* ========== 12. 玻璃质感工具类 ========== */
.glass-layer-1 {
  background: var(--bg-glass-1);
  backdrop-filter: blur(var(--glass-blur-1));
  -webkit-backdrop-filter: blur(var(--glass-blur-1));
  border: var(--glass-border-1);
  position: relative;
}

.glass-layer-1::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: var(--shadow-glass-edge);
  pointer-events: none;
}

.glass-layer-2 {
  background: var(--bg-glass-2);
  backdrop-filter: blur(var(--glass-blur-2));
  -webkit-backdrop-filter: blur(var(--glass-blur-2));
  border: var(--glass-border-2);
  position: relative;
}

.glass-layer-2::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: var(--shadow-glass-edge);
  pointer-events: none;
}

/* ========== 13. 卡片内标题覆盖（适配暗色） ========== */
.card .card-header .title {
  color: var(--text-primary);
  font-family: var(--font-sc);
  letter-spacing: var(--tracking-tight);
}

.card .card-header .more {
  color: var(--text-accent);
  font-family: var(--font-sc);
}

/* ========== 14. 平台推荐水平滚动（保留，适配暗色） ========== */
.platform-recommend {
  display: flex;
  overflow-x: auto;
  padding: 0 var(--space-6) var(--space-6);
  gap: var(--space-6);
  scrollbar-width: none;
}

.platform-recommend::-webkit-scrollbar {
  display: none;
}

.platform-card {
  flex: 0 0 140px;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--bg-glass-2);
  border: var(--glass-border-2);
  box-shadow: var(--orb-sm);
  backdrop-filter: blur(var(--glass-blur-1));
  -webkit-backdrop-filter: blur(var(--glass-blur-1));
}

.platform-card-top {
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.platform-card-emoji {
  font-size: 64rpx;
  filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.15));
}

.platform-card-name {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  padding: var(--space-4) var(--space-3) var(--space-1);
  font-family: var(--font-sc);
}

.platform-card-desc {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  display: block;
  padding: 0 var(--space-3) var(--space-3);
  line-height: var(--text-xs-lh);
  font-family: var(--font-sc);
}
