/* 我的页面样式 */

.page-scroll {
  height: 100vh;
}

/* 用户头部 */
.profile-header {
  display: flex;
  align-items: center;
  padding: 20px 16px;
  background: #fff;
}

.profile-avatar {
  position: relative;
  width: 60px;
  height: 60px;
  border-radius: 30px;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 14px;
}

.profile-avatar image {
  width: 100%;
  height: 100%;
}

.profile-avatar .member-badge {
  position: absolute;
  bottom: -3px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 9px;
  padding: 1px 6px;
  border-radius: 7px;
  white-space: nowrap;
  border: 2px solid #fff;
}

.profile-meta {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 18px;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
}

.profile-company {
  font-size: 13px;
  color: #666;
  display: block;
  margin-top: 2px;
}

.profile-edit {
  padding: 6px 16px;
  border: 1px solid #1657ff;
  border-radius: 16px;
  margin-left: 8px;
}

.edit-text {
  font-size: 13px;
  color: #1657ff;
}

/* 会员卡片 */
.member-card {
  margin-top: 0 !important;
}

.member-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.member-left {
  display: flex;
  flex-direction: column;
}

.member-level-label {
  font-size: 12px;
  color: #999;
  margin-bottom: 4px;
}

.member-level-value {
  padding: 2px 12px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  align-self: flex-start;
  margin-bottom: 4px;
}

.member-expire {
  font-size: 11px;
  color: #999;
}

.member-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.member-upgrade {
  font-size: 14px;
  color: #1657ff;
  font-weight: 500;
}

/* 升级按钮 */
.upgrade-btn {
  background: linear-gradient(135deg, #f5a623, #f7d94c);
  padding: 6px 16px;
  border-radius: 16px;
  box-shadow: 0 2px 8px rgba(245, 166, 35, 0.3);
}

.upgrade-btn-text {
  font-size: 13px;
  font-weight: 600;
  color: #fff;
}

/* 使用额度进度条 */
.usage-section {
  padding: 0 16px 16px;
}

.usage-item {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.usage-item:last-child {
  margin-bottom: 0;
}

.usage-label {
  font-size: 12px;
  color: #999;
  width: 40px;
  flex-shrink: 0;
}

.usage-bar-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8px;
}

.usage-bar {
  flex: 1;
  height: 6px;
  background: #f0f0f0;
  border-radius: 3px;
  overflow: hidden;
}

.usage-fill {
  height: 100%;
  background: linear-gradient(90deg, #1657ff, #4a7aff);
  border-radius: 3px;
  transition: width 0.3s ease;
}

.usage-text {
  font-size: 11px;
  color: #999;
  width: 50px;
  text-align: right;
  flex-shrink: 0;
}

/* 数据概览 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  padding: 0 16px 16px;
}

.stats-grid .stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-grid .stat-num {
  font-size: 22px;
  font-weight: 700;
  color: #1a1a1a;
}

.stats-grid .stat-label {
  font-size: 11px;
  color: #999;
  margin-top: 2px;
}

/* 菜单列表 */
.menu-card {
  padding: 0 !important;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 20px;
  margin-right: 12px;
}

.menu-label {
  flex: 1;
  font-size: 15px;
  color: #1a1a1a;
}

.menu-value {
  font-size: 13px;
  color: #999;
  margin-right: 8px;
}

.menu-badge {
  background: #ee0a24;
  color: #fff;
  font-size: 11px;
  padding: 1px 8px;
  border-radius: 10px;
  min-width: 20px;
  text-align: center;
  margin-right: 8px;
}

.menu-arrow {
  font-size: 16px;
  color: #ccc;
}

/* 退出登录 */
.logout-section {
  padding: 24px 16px 40px;
}

.logout-btn {
  color: #ee0a24 !important;
  border-color: #ee0a24 !important;
}

.bottom-placeholder {
  height: 60px;
}
