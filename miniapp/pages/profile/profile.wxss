/* 我的页面样式 */

.page-scroll {
  height: 100vh;
}

/* 用户头部 */
.profile-header {
  display: flex;
  align-items: center;
  padding: 40rpx 16px;
  background: #fff;
}

.profile-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 28rpx;
}

.profile-avatar image {
  width: 100%;
  height: 100%;
}

.profile-avatar .member-badge {
  position: absolute;
  bottom: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  padding: 2rpx 6px;
  border-radius: 14rpx;
  white-space: nowrap;
  border: 2px solid #fff;
}

.profile-meta {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
}

.profile-company {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-top: 4rpx;
}

.profile-edit {
  padding: 12rpx 16px;
  border: 1px solid #1657ff;
  border-radius: 32rpx;
  margin-left: 16rpx;
}

.edit-text {
  font-size: 26rpx;
  color: #1657ff;
}

/* 会员卡片 */
.member-card {
  margin-top: 0 !important;
}

.member-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.member-left {
  display: flex;
  flex-direction: column;
}

.member-level-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.member-level-value {
  padding: 4rpx 12px;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  align-self: flex-start;
  margin-bottom: 8rpx;
}

.member-expire {
  font-size: 22rpx;
  color: #999;
}

.member-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.member-upgrade {
  font-size: 28rpx;
  color: #1657ff;
  font-weight: 500;
}

/* 升级按钮 */
.upgrade-btn {
  background: linear-gradient(135deg, #f5a623, #f7d94c);
  padding: 12rpx 16px;
  border-radius: 32rpx;
  box-shadow: 0 2px 8px rgba(245, 166, 35, 0.3);
}

.upgrade-btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

/* 使用额度进度条 */
.usage-section {
  padding: 0 16px 16px;
}

.usage-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.usage-item:last-child {
  margin-bottom: 0;
}

.usage-label {
  font-size: 24rpx;
  color: #999;
  width: 80rpx;
  flex-shrink: 0;
}

.usage-bar-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.usage-bar {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.usage-fill {
  height: 100%;
  background: linear-gradient(90deg, #1657ff, #4a7aff);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.usage-text {
  font-size: 22rpx;
  color: #999;
  width: 100rpx;
  text-align: right;
  flex-shrink: 0;
}

/* 数据概览 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  padding: 0 16px 16px;
}

.stats-grid .stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-grid .stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.stats-grid .stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 菜单列表 */
.menu-card {
  padding: 0 !important;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1px solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
}

.menu-value {
  font-size: 26rpx;
  color: #999;
  margin-right: 16rpx;
}

.menu-badge {
  background: #ee0a24;
  color: #fff;
  font-size: 22rpx;
  padding: 2rpx 8px;
  border-radius: 20rpx;
  min-width: 40rpx;
  text-align: center;
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 退出登录 */
.logout-section {
  padding: 48rpx 16px 40px;
}

.logout-btn {
  color: #ee0a24 !important;
  border-color: #ee0a24 !important;
}

.bottom-placeholder {
  height: 120rpx;
}
