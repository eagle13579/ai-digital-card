/* 我的页面样式 - v2.0 Dark Minimal */

.page-scroll {
  height: 100vh;
}

/* ===== Profile Header ===== */
.profile-header {
  display: flex;
  align-items: center;
  padding: var(--space-5) var(--space-4);
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border-subtle);
}

.profile-avatar {
  position: relative;
  width: 60px;
  height: 60px;
  border-radius: var(--radius-full);
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 14px;
  border: 2px solid rgba(139, 92, 246, 0.2);
}

.profile-avatar image {
  width: 100%;
  height: 100%;
}

.profile-avatar .member-badge {
  position: absolute;
  bottom: -3px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 9px;
  padding: 1px 6px;
  border-radius: 7px;
  white-space: nowrap;
  border: 2px solid var(--surface-primary);
}

.profile-meta {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  display: block;
}

.profile-company {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  display: block;
  margin-top: 2px;
}

.profile-edit {
  padding: 6px 16px;
  border: 1px solid var(--accent);
  border-radius: var(--radius-full);
  margin-left: var(--space-2);
  flex-shrink: 0;
}

.edit-text {
  font-size: var(--text-sm);
  color: var(--accent);
}

/* ===== Member Card ===== */
.member-card {
  background: var(--gradient-card);
  border: 1px solid rgba(139, 92, 246, 0.15);
}

.member-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.member-left {
  display: flex;
  flex-direction: column;
}

.member-level-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-bottom: 4px;
}

.member-level-value {
  padding: 2px 12px;
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  align-self: flex-start;
  margin-bottom: 4px;
}

.member-expire {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
}

.member-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.member-upgrade {
  font-size: var(--text-sm);
  color: var(--accent);
  font-weight: var(--weight-medium);
}

/* ===== Menu Card ===== */
.menu-card {
  padding: 0 !important;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  margin: var(--space-3) var(--space-4);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--space-4);
  border-bottom: 1px solid var(--border-subtle);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: var(--text-primary);
  margin-right: 12px;
  background: rgba(139, 92, 246, 0.08);
  border-radius: var(--radius-sm);
}

.menu-label {
  flex: 1;
  font-size: var(--text-base);
  color: var(--text-primary);
}

.menu-value {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  margin-right: var(--space-2);
}

.menu-badge {
  background: var(--danger);
  color: #fff;
  font-size: var(--text-xs);
  padding: 1px 8px;
  border-radius: var(--radius-full);
  min-width: 20px;
  text-align: center;
  margin-right: var(--space-2);
}

.menu-arrow {
  font-size: 16px;
  color: var(--text-tertiary);
}

/* ===== Logout ===== */
.logout-section {
  padding: var(--space-6) var(--space-4) var(--space-10);
}

.logout-btn {
  color: var(--danger) !important;
  border-color: var(--danger) !important;
}
