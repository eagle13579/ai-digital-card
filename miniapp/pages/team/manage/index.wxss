/* ===== 团队管理页 - 深色磨砂玻璃风格 ===== */

.page-container {
  min-height: 100vh;
  background: var(--surface-primary);
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: var(--surface-primary);
  border-bottom: 1px solid var(--border-subtle);
  position: sticky;
  top: 0;
  z-index: 10;
}

.back {
  font-size: 28px;
  color: var(--text-primary);
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title {
  font-size: 17px;
  font-weight: 600;
  color: var(--text-primary);
}

.invite-btn {
  font-size: 14px;
  color: #fff;
  background: var(--gradient-accent);
  padding: 6px 16px;
  border-radius: 20px;
}

.invite-btn.disabled {
  visibility: hidden;
  width: 60px;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
  gap: 12px;
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid rgba(139, 92, 246, 0.2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 14px;
  color: var(--text-tertiary);
}

/* 团队信息头 */
.team-header-card {
  display: flex;
  align-items: center;
  gap: 16px;
  margin: 16px;
  padding: 20px;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
}

.team-logo {
  width: 56px;
  height: 56px;
  border-radius: 14px;
  background: var(--gradient-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.logo-text {
  font-size: 24px;
  font-weight: 700;
  color: #fff;
}

.team-info {
  flex: 1;
  min-width: 0;
}

.team-name {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  line-height: 1.3;
}

.team-meta-text {
  font-size: 13px;
  color: var(--text-tertiary);
  display: block;
  margin-top: 4px;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  margin: 0 16px 12px;
  background: var(--surface-glass);
  border: 1px solid var(--border-subtle);
  border-radius: 10px;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  font-size: 14px;
  color: var(--text-tertiary);
  font-weight: 500;
}

.tab-item.active {
  color: var(--accent);
  background: rgba(139, 92, 246, 0.1);
  font-weight: 600;
}

/* Tab 内容 */
.tab-content {
  padding: 0 16px 80px;
}

/* 成员列表 */
.member-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  overflow: hidden;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background: var(--surface-glass);
  border-bottom: 1px solid var(--border-subtle);
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(6, 182, 212, 0.2));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 12px;
}

.avatar-text {
  font-size: 16px;
  font-weight: 600;
  color: var(--accent-light);
}

.member-detail {
  flex: 1;
  min-width: 0;
}

.member-name-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.member-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
}

.role-badge {
  font-size: 11px;
  padding: 1px 8px;
  border-radius: 4px;
  font-weight: 500;
}

.member-sub {
  font-size: 13px;
  color: var(--text-tertiary);
  display: block;
  margin-top: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-actions {
  flex-shrink: 0;
  margin-left: 8px;
}

.action-btn {
  font-size: 12px;
  padding: 4px 12px;
  border-radius: 6px;
  font-weight: 500;
}

.action-btn.danger {
  color: #ef4444;
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.2);
}

.action-btn.approve {
  color: #22c55e;
  background: rgba(34, 197, 94, 0.1);
  border: 1px solid rgba(34, 197, 94, 0.2);
  margin-right: 8px;
}

.action-btn.reject {
  color: #ef4444;
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.2);
}

/* 邀请列表 */
.invite-list {
  background: var(--surface-glass);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  overflow: hidden;
}

.invite-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid var(--border-subtle);
}

.invite-item:last-child {
  border-bottom: none;
}

.invite-icon {
  font-size: 20px;
  margin-right: 12px;
}

.invite-detail {
  flex: 1;
}

.invite-target {
  font-size: 14px;
  color: var(--text-primary);
  display: block;
}

.invite-role {
  font-size: 12px;
  color: var(--text-tertiary);
  display: block;
  margin-top: 2px;
}

.invite-status {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 4px;
}

.invite-status.pending {
  color: #f59e0b;
  background: rgba(245, 158, 11, 0.1);
}

.invite-status.accepted {
  color: #22c55e;
  background: rgba(34, 197, 94, 0.1);
}

/* 审批列表 */
.approval-list {
  background: var(--surface-glass);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  overflow: hidden;
}

.approval-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid var(--border-subtle);
}

.approval-item:last-child {
  border-bottom: none;
}

.approval-icon {
  font-size: 20px;
  margin-right: 12px;
}

.approval-detail {
  flex: 1;
}

.approval-action {
  font-size: 14px;
  color: var(--text-primary);
  display: block;
}

.approval-reason {
  font-size: 12px;
  color: var(--text-tertiary);
  display: block;
  margin-top: 2px;
}

.approval-actions {
  display: flex;
  gap: 6px;
  flex-shrink: 0;
}

.approval-status {
  font-size: 12px;
  color: var(--text-tertiary);
}

/* 空状态 */
.empty-invite,
.empty-approval {
  padding: 40px;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  color: var(--text-tertiary);
}

/* 模态框（复用） */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  background: var(--surface-glass-strong);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 16px 16px 0 0;
  overflow-y: auto;
  border-top: 1px solid var(--border-subtle);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid var(--border-subtle);
}

.modal-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: 20px;
  color: var(--text-tertiary);
  padding: 4px;
}

.modal-body {
  padding: 16px;
}

.form-group {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6px;
}

.form-input {
  width: 100%;
  padding: 10px 12px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid var(--border-subtle);
  border-radius: 8px;
  font-size: 14px;
  color: var(--text-primary);
  box-sizing: border-box;
}

.picker-value {
  padding: 10px 12px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid var(--border-subtle);
  border-radius: 8px;
  font-size: 14px;
  color: var(--text-primary);
}

.submit-btn {
  width: 100%;
  padding: 12px;
  background: var(--gradient-accent);
  border: none;
  border-radius: 10px;
  font-size: 16px;
  font-weight: 600;
  color: #fff;
  margin-top: 8px;
  text-align: center;
}

.submit-btn[disabled] {
  opacity: 0.6;
}
