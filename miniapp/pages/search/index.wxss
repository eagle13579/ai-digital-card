/* 搜索页 - 暗色磨砂玻璃风格 */
@import '../../app.wxss';

.search-page {
  min-height: 100vh;
  background: var(--surface-primary);
}

/* ===== 搜索框 ===== */
.search-bar-wrap {
  padding: var(--space-3) var(--space-4);
  background: var(--surface-primary);
  position: sticky;
  top: 0;
  z-index: var(--z-sticky);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  height: 44px;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-full);
  padding: 0 var(--space-4);
}

.search-input-wrap:focus-within {
  border-color: var(--accent);
  box-shadow: 0 0 0 2px rgba(139, 92, 246, 0.15);
}

.search-icon {
  font-size: 16px;
  margin-right: var(--space-2);
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: var(--text-base);
  color: var(--text-primary);
  background: transparent;
  border: none;
  outline: none;
}

.search-input::placeholder {
  color: var(--text-tertiary);
}

.search-clear {
  font-size: 14px;
  color: var(--text-tertiary);
  padding: 4px;
  flex-shrink: 0;
}

/* ===== 筛选栏 ===== */
.filter-bar {
  display: flex;
  align-items: center;
  padding: 0 var(--space-4) var(--space-3);
  gap: var(--space-2);
}

.filter-picker {
  flex: 1;
}

.picker-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 36px;
  padding: 0 var(--space-3);
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  color: var(--text-tertiary);
}

.picker-trigger.active {
  color: var(--accent-light);
  border-color: rgba(139, 92, 246, 0.3);
  background: rgba(139, 92, 246, 0.08);
}

.picker-arrow {
  font-size: 10px;
  margin-left: 4px;
}

.filter-search-btn {
  height: 36px;
  padding: 0 var(--space-5);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gradient-accent);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: #fff;
  flex-shrink: 0;
}

.filter-search-btn:active {
  opacity: 0.85;
}

/* ===== 加载态 ===== */
.search-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-10) 0;
  gap: var(--space-3);
}

.loading-text {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
}

/* ===== 结果列表 ===== */
.result-list {
  height: calc(100vh - 140px);
  padding: 0 var(--space-4);
}

.result-item {
  display: flex;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid var(--border-subtle);
}

.result-item:active {
  opacity: 0.7;
}

.item-avatar {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-full);
  flex-shrink: 0;
  margin-right: 12px;
  border: 1px solid var(--border-subtle);
  background: var(--surface-tertiary);
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name-row {
  display: flex;
  align-items: center;
  gap: 6px;
}

.item-name {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
}

.item-tag {
  font-size: 9px;
  padding: 1px 8px;
  background: var(--gradient-accent);
  color: #fff;
  border-radius: var(--radius-full);
  text-transform: uppercase;
}

.item-company {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  display: block;
  margin-top: 2px;
}

.item-title {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  display: block;
  margin-top: 1px;
}

.item-intro {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  display: block;
  margin-top: 1px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200px;
}

.item-arrow {
  font-size: 20px;
  color: var(--text-tertiary);
  flex-shrink: 0;
  margin-left: var(--space-2);
}

/* ===== 加载更多 ===== */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-5) 0;
  gap: var(--space-2);
  font-size: var(--text-sm);
  color: var(--text-tertiary);
}

.load-more .spinner.small {
  width: 16px;
  height: 16px;
  border-width: 2px;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-10) var(--space-5);
  margin-top: var(--space-6);
}

.empty-icon {
  font-size: 48px;
  margin-bottom: var(--space-4);
  opacity: 0.6;
}

.empty-text {
  font-size: var(--text-base);
  color: var(--text-secondary);
  margin-bottom: var(--space-2);
}

.empty-hint {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
}