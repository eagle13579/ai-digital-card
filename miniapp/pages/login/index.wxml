<view class="page-container login-page">
  <view class="login-header">
    <text class="login-logo">AI数智名片</text>
    <text class="login-slogan">让每一次连接都有价值</text>
  </view>
  
  <view class="feature-list">
    <view class="feature-item">
      <view class="feature-icon">◇</view>
      <text class="feature-text">智能对话</text>
    </view>
    <view class="feature-item">
      <view class="feature-icon">◎</view>
      <text class="feature-text">信任网络</text>
    </view>
    <view class="feature-item">
      <view class="feature-icon">✦</view>
      <text class="feature-text">精准匹配</text>
    </view>
  </view>

  <view class="login-form">
    <button class="btn-wechat" bindtap="wxLogin" loading="{{loading}}">
      <view class="wechat-icon">💚</view>
      <text class="wechat-text">{{loading ? '登录中...' : '一键登录'}}</text>
    </button>
    <view class="login-alternative" bindtap="skipLogin">
      <text>暂不登录，先看看</text>
    </view>
  </view>

  <view class="login-footer">
    <text>登录即代表同意</text>
    <text class="link" bindtap="goAgreement">《用户协议》</text>
    <text class="link" bindtap="goPrivacy">《隐私政策》</text>
  </view>

  <!-- 调试用：清除登录态回到登录页 -->
  <view class="dev-tools" bindtap="clearLogin">
    <text style="font-size:24rpx;color:#999;margin-top:20rpx;display:block;text-align:center;">清除登录态</text>
  </view>

  <view class="error-modal" wx:if="{{showError}}" catchtap="hideError">
    <view class="error-card" catchtap="">
      <view class="error-icon">⚠️</view>
      <text class="error-title">{{errorTitle}}</text>
      <text class="error-desc">{{errorDesc}}</text>
      <view class="error-actions">
        <button class="btn-error-secondary" bindtap="hideError">取消</button>
        <button class="btn-error-primary" bindtap="retryLogin">重试</button>
      </view>
    </view>
  </view>
</view>
