/**
 * 登录页 — AI原生暗色适配
 * 基于 tokens.wxss 设计Token系统
 * 基底: #0A0A18 | 玻璃三层 | Orb光晕 | spring弹簧动效
 */
.login-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  background: var(--bg-page);
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

/* 背景Orb光晕 */
.login-container::before {
  content: '';
  position: absolute;
  width: 600rpx;
  height: 600rpx;
  top: -120rpx;
  right: -180rpx;
  background: radial-gradient(circle, rgba(6, 182, 212, 0.15), transparent 70%);
  pointer-events: none;
}
.login-container::after {
  content: '';
  position: absolute;
  width: 500rpx;
  height: 500rpx;
  bottom: -100rpx;
  left: -150rpx;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.12), transparent 70%);
  pointer-events: none;
}

.login-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: 60rpx 40rpx;
  width: 100%;
  max-width: 600rpx;
  box-shadow: var(--orb-md), var(--shadow-glass-edge);
  border: var(--glass-border-2);
  position: relative;
  z-index: 1;
}

.logo-area {
  text-align: center;
  margin-bottom: 50rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  border-radius: var(--radius-full);
  box-shadow: var(--orb-cyan);
}

.title {
  display: block;
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 10rpx;
  letter-spacing: var(--tracking-tight);
  font-family: var(--font-system);
}

.subtitle {
  display: block;
  font-size: var(--text-base);
  color: var(--text-secondary);
  letter-spacing: var(--tracking-wide);
}

.features {
  margin-bottom: 50rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 0.5px solid var(--border-subtle);
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.feature-text {
  font-size: var(--text-base);
  color: var(--text-secondary);
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: var(--btn-primary-height);
  background: var(--btn-primary-bg);
  color: var(--btn-primary-color);
  font-size: var(--btn-primary-font-size);
  font-weight: var(--btn-primary-font-weight);
  border-radius: var(--btn-primary-radius);
  border: none;
  box-shadow: var(--btn-primary-orb);
  margin-bottom: 30rpx;
  transition: box-shadow var(--duration-fast) var(--ease-out),
              transform var(--duration-fast) var(--ease-out);
}

.login-btn:active {
  box-shadow: var(--btn-primary-hover-orb);
  transform: scale(0.98);
}

.login-btn[disabled] {
  opacity: 0.5;
  box-shadow: none;
}

.wechat-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.skip-btn {
  text-align: center;
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  padding: 20rpx;
  transition: color var(--duration-fast) var(--ease-out);
}

.skip-btn:active {
  color: var(--text-accent);
}

.agreement {
  text-align: center;
  font-size: var(--text-xs);
  color: var(--text-quaternary);
  margin-top: 40rpx;
}

.link {
  color: var(--text-accent);
  transition: color var(--duration-fast) var(--ease-out);
}

.link:active {
  color: var(--purple-light);
}
