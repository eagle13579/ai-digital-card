/* 登录页 - v2.0 Dark Minimal (使用设计Token) */

.login-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--surface-primary);
  padding: 60px 32px 40px;
  box-sizing: border-box;
}

.login-header {
  text-align: center;
  margin-bottom: 48px;
}

.login-logo {
  font-size: 28px;
  font-weight: var(--weight-bold);
  background: var(--gradient-accent);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
}

.login-slogan {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  margin-top: var(--space-2);
  display: block;
}

.feature-list {
  display: flex;
  justify-content: center;
  gap: var(--space-8);
  margin-bottom: 60px;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(139, 92, 246, 0.1);
  border-radius: var(--radius-md);
  font-size: 22px;
  margin-bottom: var(--space-2);
}

.feature-text {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
}

.login-form {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.btn-wechat {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 48px;
  background: linear-gradient(135deg, #07c160, #10b981);
  border-radius: var(--radius-full);
  border: none;
  box-shadow: 0 4px 20px rgba(7, 193, 96, 0.3);
}

.btn-wechat:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.wechat-icon {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  font-size: 16px;
  margin-right: var(--space-2);
}

.wechat-text {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: #fff;
}

.login-alternative {
  margin-top: var(--space-5);
  font-size: var(--text-sm);
  color: var(--text-tertiary);
}

.login-alternative:active {
  color: var(--text-secondary);
}

.login-footer {
  margin-top: auto;
  text-align: center;
  font-size: var(--text-xs);
  color: rgba(255, 255, 255, 0.25);
}

.login-footer .link {
  color: var(--accent);
  display: inline;
}

.btn-test {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 40px;
  background: rgba(139, 92, 246, 0.1);
  border-radius: var(--radius-full);
  border: 1px solid rgba(139, 92, 246, 0.3);
  margin-top: var(--space-3);
}

.btn-test:active {
  background: rgba(139, 92, 246, 0.2);
}

.test-text {
  font-size: var(--text-sm);
  color: var(--accent);
}

.error-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.error-card {
  width: 80%;
  max-width: 320px;
  background: var(--surface-secondary);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  text-align: center;
}

.error-icon {
  font-size: 48px;
  margin-bottom: var(--space-3);
}

.error-title {
  font-size: var(--text-lg);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-2);
}

.error-desc {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  display: block;
  margin-bottom: var(--space-5);
}

.error-actions {
  display: flex;
  gap: var(--space-3);
}

.btn-error-secondary {
  flex: 1;
  height: 40px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-md);
  color: var(--text-secondary);
  font-size: var(--text-sm);
}

.btn-error-primary {
  flex: 1;
  height: 40px;
  background: var(--gradient-accent);
  border: none;
  border-radius: var(--radius-md);
  color: #fff;
  font-size: var(--text-sm);
}

/* ===== 登录后完善信息弹窗 ===== */
.nickname-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.nickname-overlay.visible {
  opacity: 1;
  pointer-events: auto;
}

.nickname-card {
  width: 85%;
  max-width: 320px;
  background: var(--surface-secondary, #1e1e2e);
  border: 1px solid var(--border-subtle, rgba(255,255,255,0.08));
  border-radius: var(--radius-lg, 16px);
  padding: 32px 24px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nickname-title {
  font-size: var(--text-lg, 17px);
  font-weight: var(--weight-bold, 600);
  color: var(--text-primary, #ffffff);
  margin-bottom: 6px;
}

.nickname-desc {
  font-size: var(--text-sm, 13px);
  color: var(--text-tertiary, rgba(255,255,255,0.4));
  margin-bottom: 24px;
}

/* 头像选择 */
.avatar-choose-btn {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 20px;
  padding: 0;
  border: none;
  background: transparent;
  line-height: 1;
}
.avatar-choose-btn::after {
  border: none;
}

  opacity: 0.7;
}

.setup-avatar {
  width: 100%;
  height: 100%;
}

.setup-avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(139, 92, 246, 0.1);
  border: 2px dashed rgba(139, 92, 246, 0.3);
  border-radius: 50%;
}

.setup-avatar-icon {
  font-size: 22px;
  margin-bottom: 2px;
}

.setup-avatar-text {
  font-size: 10px;
  color: var(--accent-light);
}

/* 昵称输入 */
.nickname-input-area {
  width: 100%;
  margin-bottom: 20px;
}

.input-label {
  font-size: var(--text-sm, 13px);
  color: var(--text-secondary, rgba(255,255,255,0.6));
  display: block;
  margin-bottom: 8px;
}

.nickname-input {
  width: 100%;
  height: 40px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border-subtle, rgba(255,255,255,0.08));
  border-radius: var(--radius-md, 10px);
  padding: 0 12px;
  color: var(--text-primary, #ffffff);
  font-size: var(--text-base, 15px);
  box-sizing: border-box;
}

/* 操作按钮 */
.nickname-actions {
  display: flex;
  gap: 12px;
  width: 100%;
}

.btn-nickname-primary {
  flex: 1;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gradient-accent, linear-gradient(135deg, #8b5cf6, #6366f1));
  border: none;
  border-radius: var(--radius-md, 10px);
  color: #fff;
  font-size: var(--text-sm, 13px);
  font-weight: var(--weight-medium, 500);
}

.btn-nickname-primary:active {
  opacity: 0.8;
}

.btn-nickname-secondary {
  flex: 0 0 auto;
  height: 40px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border-subtle, rgba(255,255,255,0.08));
  border-radius: var(--radius-md, 10px);
  color: var(--text-secondary, rgba(255,255,255,0.6));
  font-size: var(--text-sm, 13px);
}
