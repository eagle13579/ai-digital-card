<!-- 人脉图谱 — Canvas 2D 力导向图（暗色玻璃质感版） -->
<view class="graph-page dark">

  <!-- ===== 顶部信息栏 玻璃层2 + spring入场 ===== -->
  <view class="graph-header glass-2 glass-edge animate-spring-in-down">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="header-center">
      <text class="header-title">人脉网络图谱</text>
      <text class="header-subtitle">{{nodeCount}}个联系人 · {{edgeCount}}条关系</text>
    </view>
    <view class="header-right">
      <view class="legend-dot orb-cyan"></view>
      <text class="legend-text">我</text>
    </view>
  </view>

  <!-- ===== 加载状态 玻璃层 + spring ===== -->
  <view class="loading-layer animate-spring-in" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载人脉数据...</text>
  </view>

  <!-- ===== Canvas 画布 ===== -->
  <canvas
    wx:if="{{!loading}}"
    class="graph-canvas animate-spring-in-scale"
    type="2d"
    id="graphCanvas"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  />

  <!-- ===== 底部操作提示 玻璃层2 + spring入场 ===== -->
  <view class="graph-footer glass-1 glass-edge animate-spring-in-up" wx:if="{{!loading}}">
    <text class="footer-hint">👆 拖拽移动节点 · 双指缩放</text>
    <text class="footer-count">{{nodeCount}} 人</text>
  </view>

  <!-- ===== 背景Orb装饰（光晕替代阴影）= -->
  <view class="orb-bg-deco orb-bg-1"></view>
  <view class="orb-bg-deco orb-bg-2"></view>

</view>
