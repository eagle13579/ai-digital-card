<view class="graph-page">
  <view class="graph-header">
    <text class="graph-title">🤝 信任网络图谱</text>
    <text class="graph-subtitle">{{nodeCount}} 位联系人</text>
  </view>

  <view class="graph-container">
    <canvas 
      type="2d"
      id="graphCanvas" 
      class="graph-canvas"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    ></canvas>
    <view class="graph-tips" wx:if="{{!hasData}}">
      <text class="tips-icon">🔗</text>
      <text class="tips-text">暂无联系人数据</text>
      <text class="tips-hint">添加联系人后可查看图谱</text>
    </view>
  </view>

  <view class="graph-actions">
    <view class="action-btn add-btn" bindtap="addContact">
      <text class="action-icon">+</text>
      <text class="action-text">添加联系人</text>
    </view>
    <view class="action-btn import-btn" bindtap="openPathSearch">
      <text class="action-icon">🔍</text>
      <text class="action-text">触达路径</text>
    </view>
    <view class="action-btn refresh-btn" bindtap="refreshGraph">
      <text class="action-icon">🔄</text>
      <text class="action-text">刷新图谱</text>
    </view>
  </view>

  <view class="legend">
    <view class="legend-item">
      <view class="legend-dot self"></view>
      <text class="legend-text">自己</text>
    </view>
    <view class="legend-item">
      <view class="legend-dot contact"></view>
      <text class="legend-text">联系人</text>
    </view>
    <view class="legend-item">
      <view class="legend-line"></view>
      <text class="legend-text">关系连线</text>
    </view>
  </view>

  <!-- BFS 路径搜索面板 -->
  <view class="search-panel" wx:if="{{showPathSearch}}">
    <view class="search-overlay" bindtap="closePathSearch"></view>
    <view class="search-card">
      <view class="search-header">
        <text class="search-title">🔍 触达路径查找</text>
        <text class="search-close" bindtap="closePathSearch">✕</text>
      </view>
      <view class="search-body">
        <view class="input-row">
          <input class="search-input" placeholder="输入目标用户ID" value="{{targetUserId}}" bindinput="onTargetInput" />
          <button class="search-btn" bindtap="searchPath" wx:if="{{!searchingPath}}">查找</button>
          <view class="search-spinner" wx:if="{{searchingPath}}">
            <view class="mini-spinner"></view>
          </view>
        </view>

        <!-- 快速选择好友 -->
        <view class="friend-hint" wx:if="{{loadingFriends}}">加载好友列表...</view>
        <view class="friend-list" wx:if="{{friendList.length > 0 && !loadingFriends}}">
          <text class="friend-list-title">快速选择好友</text>
          <scroll-view scroll-x class="friend-scroll">
            <view
              class="friend-chip {{targetUserId === item.id ? 'selected' : ''}}"
              wx:for="{{friendList}}"
              wx:key="id"
              bindtap="selectFriendTarget"
              data-id="{{item.id}}"
              data-name="{{item.name}}"
            >
              <text class="chip-name">{{item.name}}</text>
            </view>
          </scroll-view>
        </view>
      </view>
    </view>
  </view>

  <!-- 路径结果显示 -->
  <path-display
    visible="{{showPathResult}}"
    path="{{pathResult.path}}"
    distance="{{pathResult.distance}}"
    message="{{pathResult.message}}"
    bind:close="closePathResult"
    bind:nodetap="onPathNodeTap"
  />
</view>
