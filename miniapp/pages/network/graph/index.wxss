.graph-page {
  min-height: 100vh;
  background: #0f0f1a;
  display: flex;
  flex-direction: column;
}

.graph-header {
  padding: 20px 16px;
  text-align: center;
}

.header-top {
  display: flex;
  align-items: center;
  gap: 12px;
}

.header-back-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  background: rgba(139, 92, 246, 0.15);
  border-radius: 20px;
  border: 1px solid rgba(139, 92, 246, 0.2);
  flex-shrink: 0;
}

.header-back-btn:active {
  background: rgba(139, 92, 246, 0.25);
}

.back-arrow {
  font-size: 16px;
  color: #a78bfa;
}

.back-text {
  font-size: 13px;
  color: #a78bfa;
  font-weight: 500;
}

.header-title-area {
  flex: 1;
}

.graph-title {
  font-size: 18px;
  font-weight: 600;
  color: #fff;
  display: block;
}

.graph-subtitle {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4px;
  display: block;
}

.graph-container {
  flex: 1;
  position: relative;
  margin: 0 16px;
  background: rgba(30, 30, 50, 0.5);
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.graph-canvas {
  width: 100%;
  height: 100%;
  min-height: 400px;
}

.graph-tips {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.tips-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
}

.tips-text {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.7);
  display: block;
}

.tips-hint {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 6px;
  display: block;
}

.graph-actions {
  display: flex;
  gap: 12px;
  padding: 16px;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 12px;
  background: rgba(30, 30, 50, 0.7);
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.action-btn:active {
  background: rgba(50, 50, 80, 0.8);
}

.action-icon {
  font-size: 24px;
  margin-bottom: 6px;
  line-height: 1;
  display: inline-block;
  vertical-align: middle;
}

.action-text {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.7);
}

.add-btn {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(6, 182, 212, 0.2));
  border-color: rgba(139, 92, 246, 0.3);
}

.import-btn {
  background: linear-gradient(135deg, rgba(6, 182, 212, 0.15), rgba(139, 92, 246, 0.15));
  border-color: rgba(6, 182, 212, 0.25);
}

.search-btn {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(6, 182, 212, 0.2));
  border-color: rgba(139, 92, 246, 0.3);
}

.legend {
  display: flex;
  justify-content: center;
  gap: 24px;
  padding: 12px 16px 32px;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
}

.legend-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}

.legend-dot.self {
  background: linear-gradient(135deg, #a78bfa, #8b5cf6);
}

.legend-dot.contact {
  background: rgba(30, 30, 50, 0.8);
  border: 1px solid rgba(139, 92, 246, 0.3);
}

.legend-line {
  width: 20px;
  height: 2px;
  background: rgba(139, 92, 246, 0.4);
}

.legend-text {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.5);
}

/* BFS路径搜索面板 */
.search-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.search-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.search-card {
  position: relative;
  width: 100%;
  background: rgba(30, 30, 50, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 16px 16px 0 0;
  overflow: hidden;
}

.search-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.search-title {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
}

.search-close {
  font-size: 20px;
  color: rgba(255, 255, 255, 0.5);
  padding: 4px;
}

.search-body {
  padding: 16px;
}

.input-row {
  display: flex;
  gap: 10px;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 44px;
  padding: 0 14px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  font-size: 15px;
  color: #fff;
}

.search-btn {
  flex-shrink: 0;
  height: 44px;
  padding: 0 24px;
  background: linear-gradient(135deg, #8b5cf6, #06b6d4);
  color: #fff;
  font-size: 14px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.search-spinner {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid rgba(139, 92, 246, 0.2);
  border-top-color: #8b5cf6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.friend-hint {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12px;
  text-align: center;
}

.friend-list {
  margin-top: 12px;
}

.friend-list-title {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 8px;
  display: block;
}

.friend-scroll {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  white-space: nowrap;
  padding-bottom: 4px;
}

.friend-chip {
  display: inline-flex;
  align-items: center;
  padding: 6px 14px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  margin-right: 8px;
}

.friend-chip.selected {
  background: rgba(139, 92, 246, 0.2);
  border-color: rgba(139, 92, 246, 0.4);
}

.chip-name {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.7);
}

.friend-chip.selected .chip-name {
  color: #a78bfa;
}

/* ====== 联系人信息弹窗 ====== */
.info-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.info-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.info-card {
  position: relative;
  width: 100%;
  background: rgba(30, 30, 50, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 16px 16px 0 0;
  overflow: hidden;
}

.info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.info-title {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
}

.info-close {
  font-size: 20px;
  color: rgba(255, 255, 255, 0.5);
  padding: 4px;
}

.info-body {
  padding: 16px;
}

.info-avatar-row {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 8px;
}

.info-avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.3), rgba(6, 182, 212, 0.3));
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid rgba(139, 92, 246, 0.4);
  flex-shrink: 0;
}

.info-avatar.avatar-self {
  background: linear-gradient(135deg, #a78bfa, #8b5cf6);
  border-color: rgba(139, 92, 246, 0.6);
}

.avatar-text {
  font-size: 22px;
  font-weight: 600;
  color: #fff;
}

.info-name-area {
  flex: 1;
}

.info-name {
  font-size: 18px;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 4px;
}

.info-relation-tag {
  display: inline-block;
  padding: 2px 10px;
  background: rgba(139, 92, 246, 0.2);
  border: 1px solid rgba(139, 92, 246, 0.3);
  border-radius: 12px;
  font-size: 12px;
  color: #a78bfa;
}

.info-divider {
  height: 1px;
  background: rgba(255, 255, 255, 0.06);
  margin: 14px 0;
}

.info-detail-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.detail-label {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.5);
  width: 56px;
  flex-shrink: 0;
}

.detail-value {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.85);
}

.trust-score-bar {
  flex: 1;
  height: 6px;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 3px;
  overflow: hidden;
}

.trust-score-fill {
  height: 100%;
  background: linear-gradient(90deg, #8b5cf6, #06b6d4);
  border-radius: 3px;
  transition: width 0.3s ease;
}

.trust-score-value {
  width: 44px;
  text-align: right;
  font-weight: 600;
  color: #a78bfa;
}

.info-footer {
  padding: 0 16px 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.info-action-btn {
  width: 100%;
  height: 44px;
  background: linear-gradient(135deg, #8b5cf6, #06b6d4);
  color: #fff;
  font-size: 15px;
  font-weight: 500;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.info-action-btn:active {
  opacity: 0.8;
}

.info-close-btn {
  width: 100%;
  height: 40px;
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.6);
  font-size: 14px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.info-close-btn:active {
  background: rgba(255, 255, 255, 0.1);
}

/* ====== 路径步骤列表 ====== */
.path-steps {
  padding: 0;
}

.path-step-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 0;
  position: relative;
}

.path-step-item:not(:last-child) {
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.step-node {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.3), rgba(6, 182, 212, 0.3));
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid rgba(139, 92, 246, 0.4);
  flex-shrink: 0;
}

.step-node.step-self {
  background: linear-gradient(135deg, #a78bfa, #8b5cf6);
  border-color: rgba(139, 92, 246, 0.6);
}

.step-node-text {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
}

.step-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.step-name {
  font-size: 15px;
  font-weight: 500;
  color: #fff;
}

.step-tag {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.45);
}

.step-arrow {
  font-size: 24px;
  color: rgba(139, 92, 246, 0.5);
  padding: 0 4px;
  flex-shrink: 0;
}