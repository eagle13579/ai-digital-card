.graph-page {
  min-height: 100vh;
  background: #0f0f1a;
  display: flex;
  flex-direction: column;
}

.graph-header {
  padding: 20px 16px;
  text-align: center;
}

.graph-title {
  font-size: 18px;
  font-weight: 600;
  color: #fff;
  display: block;
}

.graph-subtitle {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4px;
  display: block;
}

.graph-container {
  flex: 1;
  position: relative;
  margin: 0 16px;
  background: rgba(30, 30, 50, 0.5);
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.graph-canvas {
  width: 100%;
  height: 100%;
}

.graph-tips {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.tips-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
}

.tips-text {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.7);
  display: block;
}

.tips-hint {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 6px;
  display: block;
}

.graph-actions {
  display: flex;
  gap: 12px;
  padding: 16px;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 12px;
  background: rgba(30, 30, 50, 0.7);
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.action-btn:active {
  background: rgba(50, 50, 80, 0.8);
}

.action-icon {
  font-size: 24px;
  margin-bottom: 6px;
}

.action-text {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.7);
}

.add-btn {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(6, 182, 212, 0.2));
  border-color: rgba(139, 92, 246, 0.3);
}

.legend {
  display: flex;
  justify-content: center;
  gap: 24px;
  padding: 12px 16px 32px;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
}

.legend-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}

.legend-dot.self {
  background: linear-gradient(135deg, #a78bfa, #8b5cf6);
}

.legend-dot.contact {
  background: rgba(30, 30, 50, 0.8);
  border: 1px solid rgba(139, 92, 246, 0.3);
}

.legend-line {
  width: 20px;
  height: 2px;
  background: rgba(139, 92, 246, 0.4);
}

.legend-text {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.5);
}