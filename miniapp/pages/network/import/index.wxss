/* 联系人导入页 - Dark Minimal */
.import-page {
  min-height: 100vh;
  padding-bottom: 40px;
}

/* ====== 头部 ====== */
.import-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 16px 8px;
}

.header-back {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 20px;
  color: var(--text-secondary, rgba(255,255,255,0.6));
}

.header-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary, #fff);
}

.header-spacer {
  width: 36px;
}

/* ====== 通用卡片 ====== */
.section-card {
  background: var(--surface-glass, rgba(255,255,255,0.04));
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle, rgba(255,255,255,0.06));
  border-radius: var(--radius-lg, 16px);
  margin: var(--space-4, 16px);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: var(--space-4, 16px);
  background: var(--gradient-header, linear-gradient(135deg, rgba(139,92,246,0.08), rgba(6,182,212,0.05)));
  border-bottom: 1px solid var(--border-subtle, rgba(255,255,255,0.06));
}

.section-icon-wrap {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, rgba(139,92,246,0.2), rgba(6,182,212,0.15));
  border-radius: var(--radius-sm, 8px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-3, 12px);
}

.section-icon {
  font-size: 18px;
}

.section-title {
  font-size: var(--text-base, 16px);
  font-weight: var(--weight-semibold, 600);
  color: var(--text-primary, #fff);
}

.form-content {
  padding: var(--space-4, 16px);
}

.form-item {
  margin-bottom: var(--space-4, 16px);
}

.form-label {
  font-size: var(--text-sm, 14px);
  color: var(--text-secondary, rgba(255,255,255,0.6));
  margin-bottom: 6px;
  display: block;
}

.required {
  color: var(--danger, #ef4444);
}

.form-input {
  width: 100%;
  height: 44px;
  padding: 0 var(--space-3, 12px);
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid var(--border-default, rgba(255,255,255,0.1));
  border-radius: var(--radius-sm, 8px);
  font-size: var(--text-sm, 14px);
  color: var(--text-primary, #fff);
  box-sizing: border-box;
}

.form-input::placeholder {
  color: var(--text-tertiary, rgba(255,255,255,0.3));
}

/* ====== 选择导入方式 ====== */
.methods-section {
  padding: 0 16px;
  margin-top: 8px;
}

.methods-section .section-title {
  font-size: var(--text-sm, 14px);
  color: var(--text-secondary, rgba(255,255,255,0.6));
  margin-bottom: 12px;
  display: block;
  padding-left: 4px;
}

.method-card {
  display: flex;
  align-items: center;
  padding: 16px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: var(--radius-md, 12px);
  margin-bottom: 12px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.method-card:active {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(139, 92, 246, 0.3);
}

.method-icon-wrap {
  width: 44px;
  height: 44px;
  background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(6,182,212,0.1));
  border-radius: var(--radius-sm, 8px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14px;
}

.method-icon {
  font-size: 22px;
}

.method-info {
  flex: 1;
}

.method-name {
  font-size: var(--text-base, 16px);
  color: var(--text-primary, #fff);
  font-weight: 600;
  margin-bottom: 2px;
}

.method-desc {
  font-size: var(--text-xs, 12px);
  color: var(--text-tertiary, rgba(255,255,255,0.3));
}

.method-arrow {
  font-size: 20px;
  color: var(--text-tertiary, rgba(255,255,255,0.3));
}

/* ====== 按钮 ====== */
.btn-save {
  width: 100%;
  height: 48px;
  background: var(--gradient-accent, linear-gradient(135deg, #4F46E5, #7C3AED));
  color: #fff;
  border-radius: var(--radius-sm, 8px);
  font-size: var(--text-base, 16px);
  font-weight: var(--weight-semibold, 600);
  border: none;
  margin-top: 8px;
}

.btn-share {
  width: 100%;
  height: 48px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #a78bfa;
  border-radius: var(--radius-sm, 8px);
  font-size: var(--text-base, 16px);
  font-weight: var(--weight-semibold, 600);
}

.share-tip {
  background: rgba(139, 92, 246, 0.08);
  border: 1px solid rgba(139, 92, 246, 0.15);
  border-radius: var(--radius-sm, 8px);
  padding: 12px 16px;
  margin-bottom: 16px;
}

.share-tip-text {
  font-size: var(--text-sm, 14px);
  color: #c4b5fd;
  line-height: 1.5;
}

/* ====== 联系人列表 ====== */
.contacts-section {
  margin-top: 8px;
  padding: 0 16px;
}

.contacts-header {
  display: flex;
  align-items: center;
  padding: 12px 4px;
}

.contacts-title {
  font-size: var(--text-sm, 14px);
  color: var(--text-secondary, rgba(255,255,255,0.6));
  flex: 1;
}

.contacts-count {
  font-size: var(--text-sm, 14px);
  color: var(--text-tertiary, rgba(255,255,255,0.3));
  margin-right: 12px;
}

.contacts-clear {
  font-size: var(--text-sm, 14px);
  color: var(--danger, #ef4444);
}

.contact-list {
  margin-top: 4px;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-md, 12px);
  margin-bottom: 8px;
}

.contact-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(139,92,246,0.3), rgba(6,182,212,0.2));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
}

.contact-avatar-text {
  font-size: 16px;
  color: #fff;
  font-weight: 600;
}

.contact-info {
  flex: 1;
}

.contact-name {
  font-size: var(--text-sm, 14px);
  color: var(--text-primary, #fff);
  font-weight: 600;
  margin-bottom: 2px;
}

.contact-meta {
  font-size: var(--text-xs, 12px);
  color: var(--text-tertiary, rgba(255,255,255,0.3));
  margin-right: 8px;
}

.contact-source {
  font-size: 11px;
  padding: 1px 8px;
  background: rgba(139, 92, 246, 0.1);
  border-radius: 100px;
  color: #a78bfa;
}

.contact-delete {
  font-size: var(--text-sm, 14px);
  color: var(--danger, #ef4444);
  padding: 8px;
}

/* ====== 空状态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 40px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: var(--text-base, 16px);
  color: var(--text-secondary, rgba(255,255,255,0.6));
  margin-bottom: 8px;
}

.empty-hint {
  font-size: var(--text-sm, 14px);
  color: var(--text-tertiary, rgba(255,255,255,0.3));
  text-align: center;
}
