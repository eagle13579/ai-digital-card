<view class="page-container"><view class="membership-header"><text class="m-title">会员中心</text><text class="m-subtitle">当前等级：{{currentLevel}}</text></view>
<view class="level-list"><view class="level-card {{item.popular ? 'level-popular' : ''}}" wx:for="{{levels}}" wx:key="id" data-id="{{item.id}}" bindtap="upgrade">
<view class="level-name">{{item.name}}</view><view class="level-price">{{item.price}}</view>
<view class="level-tag" wx:if="{{item.popular}}">推荐</view>
<view class="level-features"><text class="level-feature" wx:for="{{item.features}}" wx:key="index">✓ {{item}}</text></view>
</view></view></view>
