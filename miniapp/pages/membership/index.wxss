.membership-header {
  text-align: center;
  padding: 32px 16px;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(6, 182, 212, 0.15));
}

.m-title {
  font-size: 24px;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8px;
}

.m-subtitle {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.6);
}

.level-list {
  padding: 16px;
}

.level-card {
  background: rgba(30, 30, 50, 0.6);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  position: relative;
}

.level-card.level-popular {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(6, 182, 212, 0.2));
  border-color: rgba(139, 92, 246, 0.4);
}

.level-name {
  font-size: 18px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4px;
}

.level-price {
  font-size: 24px;
  font-weight: 700;
  color: #8b5cf6;
  margin-bottom: 12px;
}

.level-card.level-popular .level-price {
  color: #a78bfa;
}

.level-tag {
  position: absolute;
  top: -1px;
  right: 16px;
  background: linear-gradient(135deg, #8b5cf6, #06b6d4);
  color: #fff;
  font-size: 11px;
  padding: 2px 10px;
  border-radius: 0 0 8px 8px;
}

.level-features {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.level-feature {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.7);
}

.student-discount-card {
  display: flex;
  align-items: center;
  padding: 16px 20px;
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.2), rgba(245, 158, 11, 0.2));
  border-radius: 16px;
  border: 1px solid rgba(251, 191, 36, 0.3);
  margin-top: 8px;
}

.student-discount-icon {
  font-size: 36px;
  margin-right: 14px;
  flex-shrink: 0;
}

.student-discount-content {
  flex: 1;
  min-width: 0;
}

.student-discount-title {
  font-size: 15px;
  font-weight: 600;
  color: #fbbf24;
  display: block;
  margin-bottom: 4px;
}

.student-discount-desc {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
  display: block;
}