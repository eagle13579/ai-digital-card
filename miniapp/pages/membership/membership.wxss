/**
 * 会员中心 — AI原生暗色适配
 * 基于 tokens.wxss 设计Token系统
 * 基底: #0A0A18 | 玻璃三层 | Orb光晕 | spring弹簧动效 | 三重渐变
 * 降级方案: 微信低版本不支持backdrop-filter时，使用 rgba(20,20,24,0.85) + filter:blur() 替代
 */

.page-scroll {
  height: 100vh;
}

/* ===== 当前层级卡片 ===== */
.current-level-card {
  margin: var(--space-8);
  border-radius: var(--radius-lg);
  overflow: hidden;
  position: relative;
  color: #fff;
  box-shadow: var(--orb-lg);
}

.current-level-card::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0.15;
  pointer-events: none;
}

.current-level-card.level-free {
  background: var(--gradient-cyan-purple);
}

.current-level-card.level-pro {
  background: var(--gradient-purple-pink);
}

.current-level-card.level-enterprise {
  background: linear-gradient(135deg, #06b6d4 0%, #8b5cf6 50%, #ec4899 100%);
}

.level-content {
  padding: 40rpx 40rpx 12rpx;
  position: relative;
  z-index: 1;
}

.level-label {
  font-size: var(--text-sm);
  opacity: 0.8;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: var(--tracking-wide);
}

.level-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.level-name {
  font-size: var(--text-4xl);
  font-weight: 700;
  margin-right: 20rpx;
}

.level-badge {
  padding: 4rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 600;
}

.level-badge.badge-pro {
  background: rgba(255,255,255,0.25);
  color: #fff;
}

.level-expire {
  font-size: var(--text-sm);
  opacity: 0.75;
  display: block;
}

/* 使用额度 */
.usage-section {
  padding: var(--space-6) 40rpx var(--space-5);
  background: rgba(255,255,255,0.10);
  position: relative;
  z-index: 1;
  backdrop-filter: blur(10px);
}

.usage-item {
  margin-bottom: 20rpx;
}

.usage-item:last-child {
  margin-bottom: 0;
}

.usage-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.usage-label {
  font-size: var(--text-xs);
  opacity: 0.85;
}

.usage-value {
  font-size: var(--text-xs);
  font-weight: 600;
  opacity: 0.95;
}

.progress-bar {
  height: 8rpx;
  background: rgba(255,255,255,0.15);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, rgba(255,255,255,0.6), rgba(255,255,255,0.9));
  border-radius: var(--radius-full);
  transition: width 0.3s ease;
}

/* ===== 段落标题 ===== */
.section-title {
  font-size: var(--text-xl);
  font-weight: 600;
  color: var(--text-primary);
  padding: var(--space-8) var(--space-6) var(--space-2);
  letter-spacing: var(--tracking-tight);
}

/* ===== 套餐卡片 ===== */
.plans-container {
  display: flex;
  overflow-x: auto;
  padding: 0 var(--space-6) var(--space-2);
  gap: var(--space-6);
  scrollbar-width: none;
}

.plans-container::-webkit-scrollbar {
  display: none;
}

.plan-card {
  flex: 0 0 420rpx;
  background: var(--bg-glass-2);
  border-radius: var(--radius-md);
  box-shadow: var(--orb-sm), var(--shadow-glass-edge);
  padding: 40rpx var(--space-6);
  position: relative;
  display: flex;
  flex-direction: column;
  border: 1px solid var(--glass-border-2);
  transition: all var(--duration-normal) var(--ease-out);
}

.plan-card:active {
  transform: scale(0.98);
}

.plan-highlighted {
  border-color: var(--border-accent);
  box-shadow: var(--orb-md), var(--shadow-glass-edge);
  background: var(--bg-glass-3);
}

.plan-badge {
  position: absolute;
  top: -2rpx;
  right: 32rpx;
  background: var(--gradient-purple-pink);
  color: #fff;
  font-size: var(--text-xs);
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 0 0 var(--radius-sm) var(--radius-sm);
  box-shadow: var(--orb-sm);
}

.plan-header {
  text-align: center;
  margin-bottom: var(--space-8);
}

.plan-name {
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-4);
}

.plan-price-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.plan-price {
  font-size: var(--text-4xl);
  font-weight: 700;
  color: var(--text-primary);
}

.plan-period {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  margin-left: 8rpx;
}

.plan-original {
  display: block;
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  text-decoration: line-through;
  margin-top: 4rpx;
}

.plan-features {
  flex: 1;
  margin-bottom: var(--space-8);
}

.plan-feature {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.feature-icon {
  width: 36rpx;
  height: 36rpx;
  background: var(--success);
  color: #fff;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-4);
  flex-shrink: 0;
}

.feature-text {
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

.plan-btn {
  margin-top: auto;
}

/* ===== 功能对比表 ===== */
.comparison-card {
  background: var(--bg-glass-2);
  border-radius: var(--radius-md);
  box-shadow: var(--orb-sm), var(--shadow-glass-edge);
  margin: 0 var(--space-6) var(--space-4);
  overflow: hidden;
  border: var(--glass-border-2);
}

.comparison-header {
  display: flex;
  background: var(--bg-glass-3);
  padding: var(--space-6) var(--space-3);
  font-weight: 600;
  font-size: var(--text-sm);
  border-bottom: 0.5px solid var(--border-subtle);
}

.comparison-row {
  display: flex;
  padding: var(--space-6) var(--space-3);
  font-size: var(--text-sm);
  border-bottom: 0.5px solid var(--border-subtle);
}

.comparison-row:last-child {
  border-bottom: none;
}

.comp-col {
  flex: 1;
  text-align: center;
  color: var(--text-primary);
}

.comp-feature {
  flex: 1.5;
  text-align: left;
  color: var(--text-secondary);
}

.comp-disabled {
  color: var(--text-quaternary);
}

.comp-pro {
  color: var(--pink);
  font-weight: 500;
}

.comp-enterprise {
  color: var(--cyan);
  font-weight: 500;
}

/* 底部 */
.bottom-placeholder {
  height: 120rpx;
}
