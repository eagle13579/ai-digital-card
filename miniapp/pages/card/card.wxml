<view class="page-container">
  <loading visible="{{loading}}" text="{{_t.loading}}" />

  <!-- ==================== 列表模式（Tab直入） ==================== -->
  <scroll-view scroll-y class="page-scroll" wx:if="{{!loading && mode === 'list'}}">

    <!-- 列表头部 -->
    <view class="section-header">
      <text class="section-title">{{_t.myAlbums}}</text>
      <text class="section-subtitle">{{_t.tabCard}}</text>
    </view>

    <!-- 名片列表 -->
    <view class="card-list">
      <view
        class="card-list-item"
        wx:for="{{myCards}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="selectCard"
      >
        <!-- 封面 -->
        <view class="card-list-cover">
          <image src="{{item.cover || '/images/default-cover.png'}}" mode="aspectFill" />
          <view class="card-list-cover-overlay" wx:if="{{item.status === 'draft'}}">
            <text class="card-list-status">{{_t.draft}}</text>
          </view>
        </view>
        <!-- 信息 -->
        <view class="card-list-info">
          <text class="card-list-name">{{item.title || _t.aiCardTitle}}</text>
          <text class="card-list-desc" wx:if="{{item.user_name}}">{{item.user_name}} · {{item.user_company || ''}}</text>
          <text class="card-list-desc" wx:else>{{item.user_company || item.user_title || ''}}</text>
          <view class="card-list-meta">
            <text class="card-list-views">👁 {{item.view_count || 0}}</text>
            <text class="card-list-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{myCards.length === 0}}">
      <text class="empty-icon">{{listError ? '⚠️' : '📇'}}</text>
      <text class="text">{{listError ? (_t.loadError || '加载失败') : _t.noData}}</text>
      <button class="btn-primary small" style="margin-top: 16px; width: auto; padding: 0 24px;" bindtap="handleEmptyAction">
        {{listError ? (_t.retry || '重试') : _t.editCard}}
      </button>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>

  <!-- ==================== 详情模式（有 id 参数） ==================== -->
  <scroll-view scroll-y class="page-scroll" wx:if="{{!loading && mode === 'detail'}}">

    <!-- 返回按钮 -->
    <view class="detail-back" bindtap="backToList">
      <text class="detail-back-icon">‹</text>
      <text class="detail-back-label">{{_t.back}}</text>
    </view>

    <!-- 名片头部 -->
    <view class="card-hero">
      <view class="hero-bg">
        <image src="{{card.cover || '/images/default-cover.png'}}" mode="aspectFill" />
      </view>
      <view class="hero-overlay">
        <view class="hero-avatar">
          <image src="{{card.user_avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
        </view>
        <text class="hero-name">{{card.user_name || _t.unknownUser}}</text>
        <text class="hero-company">{{card.user_company}} · {{card.user_title}}</text>
        <text class="hero-title">{{card.title || _t.aiCardTitle}}</text>
      </view>
    </view>

    <!-- 名片信息 -->
    <view class="glass-card info-card">
      <view class="glass-card-header">
        <text class="title">{{_t.basicInfo}}</text>
      </view>
      <view class="glass-card-body info-body">
        <view class="info-row" wx:if="{{card.user_company}}">
          <text class="info-label">{{_t.company}}</text>
          <text class="info-value">{{card.user_company}}</text>
        </view>
        <view class="info-row" wx:if="{{card.user_title}}">
          <text class="info-label">{{_t.position}}</text>
          <text class="info-value">{{card.user_title}}</text>
        </view>
        <view class="info-row" wx:if="{{card.purpose}}">
          <text class="info-label">{{_t.coopIntention}}</text>
          <text class="info-value tag provide">{{purposeText}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">{{_t.statusInfo}}</text>
          <text class="info-value badge badge-{{card.status === 'published' ? 'gold' : 'free'}}">
            {{card.status === 'published' ? _t.published : _t.draft}}
          </text>
        </view>
        <view class="info-row">
          <text class="info-label">{{_t.viewsInfo}}</text>
          <text class="info-value">{{card.view_count || 0}} {{_t.times}}</text>
        </view>
      </view>
    </view>

    <!-- 统计数据 -->
    <view class="glass-card">
      <view class="glass-card-header">
        <text class="title">{{_t.dataOverviewCard}}</text>
      </view>
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-num">{{stats.views || 0}}</text>
          <text class="stat-label">{{_t.viewCount}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{stats.visitors || 0}}</text>
          <text class="stat-label">{{_t.visitorCount}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{stats.matches || 0}}</text>
          <text class="stat-label">{{_t.matchLabel}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{stats.trust || 0}}</text>
          <text class="stat-label">{{_t.trustCount}}</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="btn-primary" bindtap="goPreview">{{_t.previewAlbum}}</button>
      <button class="btn-secondary" bindtap="shareCard" style="margin-top: 12px;">{{_t.shareCard}}</button>
      <button class="btn-secondary" bindtap="generateQRCode" style="margin-top: 12px; border-color: var(--success); color: var(--success);">{{_t.generateQR}}</button>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>

  <!-- 自定义TabBar -->
  <custom-tab-bar selected="{{1}}" />
</view>
