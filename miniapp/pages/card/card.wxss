/* 名片详情页样式 - v2.0 Dark Minimal */

.page-scroll {
  height: 100vh;
}

/* ===== Hero Section ===== */
.card-hero {
  position: relative;
  height: 280px;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
}

.hero-bg image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 16px 24px;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
  color: #fff;
}

.hero-avatar {
  width: 72px;
  height: 72px;
  border-radius: var(--radius-full);
  overflow: hidden;
  border: 3px solid rgba(255, 255, 255, 0.4);
  margin-bottom: 10px;
  box-shadow: 0 0 20px rgba(139, 92, 246, 0.15);
}

.hero-avatar image {
  width: 100%;
  height: 100%;
}

.hero-name {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  margin-bottom: 4px;
}

.hero-company {
  font-size: var(--text-sm);
  opacity: 0.85;
  margin-bottom: 2px;
}

.hero-title {
  font-size: var(--text-sm);
  opacity: 0.65;
}

/* ===== Info Card ===== */
.glass-card.info-card {
  margin-top: 0 !important;
}

.info-body {
  padding-bottom: var(--space-2);
}

/* ===== Action Buttons ===== */
.action-buttons {
  padding: var(--space-5) var(--space-4);
}

/* ===== 底部占位（为自定义TabBar留空间） ===== */
.bottom-placeholder {
  height: 60px;
}

/* 状态标签行 */
.status-row {
  display: flex;
  align-items: center;
}
.status-badge-wrap {
  display: inline-flex;
  align-items: center;
  margin-left: 0;
}
