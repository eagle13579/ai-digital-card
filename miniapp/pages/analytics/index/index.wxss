/* 增长看板 - Dark Minimal v1.0 */

/* ===== Page Container ===== */
.page-scroll {
  height: 100vh;
  background: #0f0f13;
  padding: 0 var(--space-4);
  box-sizing: border-box;
}

/* ===== Section Headers ===== */
.section-header {
  padding: var(--space-5) 0 var(--space-3);
}

.section-title {
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  display: block;
}

.section-subtitle {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 4px;
  display: block;
}

/* ===== Funnel Card ===== */
.funnel-card {
  background: var(--surface-secondary);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-5);
}

.funnel-step {
  display: flex;
  align-items: center;
  padding: var(--space-3) 0;
  border-bottom: 1px solid var(--border-subtle);
}

.step-info {
  flex: 1;
  min-width: 0;
  margin-right: var(--space-2);
}

.step-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 2px;
}

.step-value {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  display: block;
}

.progress-track {
  flex: 2;
  height: 8px;
  background: rgba(255, 255, 255, 0.06);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin: 0 var(--space-2);
  max-width: 160px;
}

.progress-fill {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 0.6s ease;
}

.step-rate {
  width: 48px;
  text-align: right;
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--accent-light);
  flex-shrink: 0;
}

/* ===== Metrics Section ===== */
.metrics-section {
  margin-bottom: var(--space-5);
}

.metrics-section .section-title {
  margin-bottom: var(--space-3);
}

.metrics-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.metric-card {
  flex: 0 0 calc(50% - 6px);
  background: var(--surface-secondary);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  padding: var(--space-4);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
}

.metric-card-wide {
  flex: 0 0 100%;
}

.metric-icon {
  font-size: 24px;
  margin-bottom: var(--space-2);
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(139, 92, 246, 0.1);
  border-radius: var(--radius-sm);
}

.metric-num {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  display: block;
}

.metric-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 4px;
  display: block;
}

/* ===== Conversion Section ===== */
.conversion-section {
  margin-bottom: var(--space-5);
}

.conversion-section .section-title {
  margin-bottom: var(--space-3);
}

.conversion-card {
  background: var(--surface-secondary);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.conversion-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4);
  border-bottom: 1px solid var(--border-subtle);
}

.conversion-left {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.conversion-dot {
  width: 8px;
  height: 8px;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.conversion-label {
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

.conversion-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  min-width: 100px;
}

.conversion-value {
  font-size: var(--text-base);
  font-weight: var(--weight-bold);
}

.conversion-value.accent {
  color: var(--accent-light);
}

.conversion-bar-mini {
  width: 100%;
  height: 4px;
  background: rgba(255, 255, 255, 0.06);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-top: 4px;
}

.conversion-bar-fill {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 0.6s ease;
}

/* ===== Conversion Summary ===== */
.conversion-summary {
  margin-top: var(--space-4);
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.12), rgba(6, 182, 212, 0.08));
  border: 1px solid rgba(139, 92, 246, 0.15);
  border-radius: var(--radius-lg);
  padding: var(--space-5);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-text {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-bottom: var(--space-1);
}

.summary-value {
  font-size: var(--text-2xl);
  font-weight: var(--weight-bold);
  color: var(--accent-light);
  line-height: 1.2;
}

.summary-sub {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 4px;
}

/* ===== Bottom Placeholder ===== */
.bottom-placeholder {
  height: 40px;
}
