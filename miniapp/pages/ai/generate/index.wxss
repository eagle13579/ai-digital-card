.type-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
  overflow-x: auto;
}

.type-tab {
  flex-shrink: 0;
  padding: 8px 16px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20px;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.type-tab.active {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.3), rgba(6, 182, 212, 0.3));
  color: #fff;
  border-color: rgba(139, 92, 246, 0.5);
}

.subtype-chips {
  display: flex;
  gap: 6px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}

.subtype-chip {
  padding: 4px 12px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.6);
}

.subtype-chip.active {
  background: rgba(139, 92, 246, 0.2);
  color: #a78bfa;
}

.result-text {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
  display: block;
  white-space: pre-wrap;
  padding: 4px 0;
}

.card-actions {
  display: flex;
  gap: 12px;
}

.action-btn {
  font-size: 13px;
  color: #8b5cf6;
}