<view class="page-container abtest-page">
  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载实验数据...</text>
  </view>

  <block wx:if="{{!loading}}">
    <!-- 头部 -->
    <view class="ab-header">
      <text class="ab-title">🧪 A/B测试管理</text>
      <text class="ab-subtitle">数据驱动的产品优化实验</text>
    </view>

    <!-- 状态筛选 -->
    <view class="filter-tabs">
      <view class="filter-tab {{filterStatus === 'all' ? 'active' : ''}}" data-status="all" bindtap="filterByStatus">全部</view>
      <view class="filter-tab {{filterStatus === 'running' ? 'active' : ''}}" data-status="running" bindtap="filterByStatus">运行中</view>
      <view class="filter-tab {{filterStatus === 'completed' ? 'active' : ''}}" data-status="completed" bindtap="filterByStatus">已完成</view>
      <view class="filter-tab {{filterStatus === 'paused' ? 'active' : ''}}" data-status="paused" bindtap="filterByStatus">已暂停</view>
      <view class="filter-tab {{filterStatus === 'draft' ? 'active' : ''}}" data-status="draft" bindtap="filterByStatus">草稿</view>
    </view>

    <!-- 实验列表 -->
    <view class="experiment-list">
      <view class="experiment-card" wx:for="{{experiments}}" wx:key="id"
        wx:if="{{filterStatus === 'all' || item.status === filterStatus}}"
        data-id="{{item.id}}" bindtap="viewDetail">
        <!-- 头部 -->
        <view class="exp-header">
          <view class="exp-title-row">
            <text class="exp-name">{{item.name}}</text>
            <view class="exp-status" style="background:{{statusColors[item.status]}}20;color:{{statusColors[item.status]}};">
              <view class="exp-status-dot" style="background:{{statusColors[item.status]}}"></view>
              <text>{{statusLabels[item.status]}}</text>
            </view>
          </view>
          <text class="exp-desc">{{item.description}}</text>
        </view>

        <!-- 变体对比 -->
        <view class="exp-variants">
          <view class="variant" wx:for="{{item.variants}}" wx:key="name">
            <view class="variant-header">
              <text class="variant-name">{{item.name}}</text>
              <text class="variant-value" wx:if="{{item.conversion > 0}}">{{item.conversion}}%</text>
            </view>
            <view class="variant-bar-track">
              <view class="variant-bar" style="width:{{item.conversion > 0 ? (item.conversion / 30 * 100) : 0}}%;background:{{item.winner === 'B' && index === 1 ? 'linear-gradient(90deg,#0EA5E9,#22C55E)' : 'linear-gradient(90deg,#8b5cf6,#0EA5E9)'}}"></view>
            </view>
            <view class="variant-stats">
              <text class="variant-traffic">{{item.traffic}}% 流量</text>
              <text class="variant-users">{{item.users}} 用户</text>
            </view>
          </view>
        </view>

        <!-- 开始时间和结果 -->
        <view class="exp-footer">
          <text class="exp-date">📅 {{item.startedAt}} · {{item.duration}}</text>
          <text class="exp-winner" wx:if="{{item.winner}}">🏆 胜出: {{item.winner}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{experiments.length === 0}}">
      <text class="empty-icon">🧪</text>
      <text class="empty-text">暂无实验数据</text>
      <button class="btn-primary small" bindtap="createExperiment">创建实验</button>
    </view>

    <!-- 创建按钮 -->
    <view class="create-area">
      <button class="btn-primary" bindtap="createExperiment">+ 创建新实验</button>
    </view>

    <view class="bottom-placeholder"></view>
  </block>
</view>
