.chat-header {
  display: flex;
  align-items: center;
  padding: 20px 16px;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
}

.back-btn .icon {
  width: 24px;
  height: 24px;
  color: #fff;
}

.header-title {
  flex: 1;
}

.header-title .title {
  font-size: 18px;
  font-weight: var(--font-weight-bold);
  display: block;
}

.header-title .subtitle {
  font-size: 12px;
  opacity: 0.8;
  margin-top: 2px;
  display: block;
}

.ai-badge {
  display: flex;
  align-items: center;
  gap: 4px;
  background: rgba(255, 255, 255, 0.2);
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: var(--font-weight-bold);
}

.ai-dot {
  width: 8px;
  height: 8px;
  background: #10B981;
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.chat-content {
  flex: 1;
  height: calc(100vh - 140px);
  padding: 16px;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.message-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 40px;
  height: 40px;
  border-radius: 20px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-avatar {
  background: linear-gradient(135deg, var(--primary-100), var(--primary-200));
}

.ai-icon {
  font-size: 20px;
}

.user-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.message-content {
  max-width: 75%;
}

.message-text {
  padding: 12px 16px;
  border-radius: var(--radius-lg);
  font-size: var(--font-body);
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
  display: block;
}

.message-item.ai .message-text {
  background: var(--surface-1);
  color: var(--text-primary);
  border-radius: 4px 16px 16px 16px;
  box-shadow: var(--shadow-sm);
}

.message-item.user .message-text {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
  border-radius: 16px 4px 16px 16px;
}

.message-time {
  font-size: 10px;
  color: var(--text-muted);
  margin-top: 4px;
  display: block;
}

.message-item.user .message-time {
  text-align: right;
}

.typing-indicator {
  display: flex;
  gap: 6px;
  padding: 12px 16px;
  background: var(--surface-1);
  border-radius: 4px 16px 16px 16px;
}

.typing-dot {
  width: 8px;
  height: 8px;
  background: var(--text-muted);
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(1) { animation-delay: 0s; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.quick-questions {
  padding: 0 16px 16px;
}

.quick-title {
  font-size: 13px;
  color: var(--text-muted);
  margin-bottom: 10px;
  display: block;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.quick-item {
  padding: 8px 14px;
  background: var(--surface-2);
  border-radius: var(--radius-full);
  font-size: 12px;
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
  transition: all var(--transition-fast);
}

.quick-item:active {
  background: var(--primary-50);
  border-color: var(--primary);
  color: var(--primary);
}

.input-area {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background: var(--surface-1);
  border-top: 1px solid var(--border-subtle);
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
}

.chat-input {
  flex: 1;
  height: 44px;
  padding: 0 16px;
  background: var(--surface-2);
  border-radius: var(--radius-full);
  font-size: var(--font-body);
}

.send-btn {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  border-radius: var(--radius-full);
  margin-left: 10px;
  box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
}

.send-btn .icon {
  width: 20px;
  height: 20px;
  color: #fff;
}