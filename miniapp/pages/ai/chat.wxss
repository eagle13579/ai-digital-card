.chat-header {
  display: flex;
  align-items: center;
  padding: 40rpx 16px;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.back-btn .icon {
  width: 48rpx;
  height: 48rpx;
  color: #fff;
}

.header-title {
  flex: 1;
}

.header-title .title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  display: block;
}

.header-title .subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 4rpx;
  display: block;
}

.ai-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 12px;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: var(--font-weight-bold);
}

.ai-dot {
  width: 16rpx;
  height: 16rpx;
  background: #10B981;
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.chat-content {
  flex: 1;
  height: calc(100vh - 140px);
  padding: 32rpx;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.message-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-avatar {
  background: linear-gradient(135deg, var(--primary-100), var(--primary-200));
}

.ai-icon {
  font-size: 40rpx;
}

.user-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.message-content {
  max-width: 75%;
}

.message-text {
  padding: 24rpx 16px;
  border-radius: var(--radius-lg);
  font-size: var(--font-body);
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
  display: block;
}

.message-item.ai .message-text {
  background: var(--surface-1);
  color: var(--text-primary);
  border-radius: 8rpx 16px 16px 16px;
  box-shadow: var(--shadow-sm);
}

.message-item.user .message-text {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
  border-radius: 32rpx 4px 16px 16px;
}

.message-time {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  display: block;
}

.message-item.user .message-time {
  text-align: right;
}

.typing-indicator {
  display: flex;
  gap: 12rpx;
  padding: 24rpx 16px;
  background: var(--surface-1);
  border-radius: 8rpx 16px 16px 16px;
}

.typing-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--text-muted);
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(1) { animation-delay: 0s; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.quick-questions {
  padding: 0 16px 16px;
}

.quick-title {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 20rpx;
  display: block;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-item {
  padding: 16rpx 14px;
  background: var(--surface-2);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
  transition: all var(--transition-fast);
}

.quick-item:active {
  background: var(--primary-50);
  border-color: var(--primary);
  color: var(--primary);
}

.input-area {
  display: flex;
  align-items: center;
  padding: 24rpx 16px;
  background: var(--surface-1);
  border-top: 1px solid var(--border-subtle);
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
}

.chat-input {
  flex: 1;
  height: 88rpx;
  padding: 0 16px;
  background: var(--surface-2);
  border-radius: var(--radius-full);
  font-size: var(--font-body);
}

.send-btn {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  border-radius: var(--radius-full);
  margin-left: 20rpx;
  box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
}

.send-btn .icon {
  width: 40rpx;
  height: 40rpx;
  color: #fff;
}