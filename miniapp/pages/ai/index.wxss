.hero-section {
  position: relative;
  padding: 60px 32px 40px;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 50%, #8B5CF6 100%);
}

.hero-glow {
  position: absolute;
  top: -50%;
  left: -20%;
  width: 140%;
  height: 140%;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.15) 0%, transparent 50%);
  animation: rotateGlow 20s linear infinite;
}

@keyframes rotateGlow {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-icon {
  position: relative;
  width: 80px;
  height: 80px;
  margin-bottom: 20px;
}

.hero-icon .icon {
  width: 100%;
  height: 100%;
  background: #fff;
}

.ai-pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3px solid rgba(255, 255, 255, 0.4);
  animation: aiPulse 2s ease-out infinite;
}

@keyframes aiPulse {
  0% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
  }
  100% {
    transform: translate(-50%, -50%) scale(1.5);
    opacity: 0;
  }
}

.hero-title {
  font-size: 32px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8px;
}

.hero-subtitle {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 32px;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 32px;
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-stat .stat-num {
  font-size: 28px;
  font-weight: 700;
  color: #fff;
}

.hero-stat .stat-label {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4px;
}

.hero-divider {
  width: 1px;
  height: 40px;
  background: rgba(255, 255, 255, 0.3);
}

.ai-capabilities {
  padding: 0 16px;
  margin-top: -20px;
  position: relative;
  z-index: 2;
}

.capability-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 20px;
  margin-bottom: 12px;
  box-shadow: var(--shadow-md);
  transition: all var(--transition-normal);
}

.capability-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.cap-icon-wrap {
  width: 56px;
  height: 56px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16px;
  flex-shrink: 0;
}

.cap-icon-wrap .icon {
  width: 28px;
  height: 28px;
  background: #fff;
}

.cap-content {
  flex: 1;
  min-width: 0;
}

.cap-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4px;
}

.cap-desc {
  font-size: 13px;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 8px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cap-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.cap-tag {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: var(--radius-full);
}

.cap-arrow {
  width: 24px;
  height: 24px;
  color: var(--text-muted);
  margin-left: 8px;
}

.feature-showcase {
  padding: 32px 16px;
}

.section-header {
  margin-bottom: 24px;
}

.section-title {
  font-size: 22px;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.section-subtitle {
  font-size: 14px;
  color: var(--text-muted);
  display: block;
  margin-top: 4px;
}

.showcase-grid {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.showcase-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 20px;
  box-shadow: var(--shadow-sm);
}

.showcase-header {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
}

.showcase-icon-wrap {
  width: 36px;
  height: 36px;
  background: var(--primary-50);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
}

.showcase-icon-wrap .icon {
  width: 18px;
  height: 18px;
  color: var(--primary);
}

.showcase-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.graph-visual {
  position: relative;
  height: 160px;
  background: linear-gradient(135deg, #EEF2FF 0%, #F3E8FF 100%);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 16px;
}

.graph-nodes {
  position: relative;
  width: 100%;
  height: 100%;
}

.graph-node {
  position: absolute;
  width: 48px;
  height: 48px;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  transition: all var(--transition-normal);
}

.graph-node.central {
  width: 56px;
  height: 56px;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
}

.graph-node.central .node-label {
  color: #fff;
}

.node-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-secondary);
}

.graph-edges {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 120px;
  height: 120px;
  transform: translate(-50%, -50%);
}

.edge-line {
  position: absolute;
  top: 50%;
  left: 0;
  width: 50%;
  height: 2px;
  background: linear-gradient(90deg, var(--primary), transparent);
  transform-origin: right center;
}

.showcase-stats {
  display: flex;
  justify-content: space-around;
}

.mini-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mini-num {
  font-size: 22px;
  font-weight: 700;
  color: var(--primary);
}

.mini-label {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 2px;
}

.vector-card {
  background: linear-gradient(135deg, #F0FDF4 0%, #ECFDF5 100%);
}

.vector-card .showcase-icon-wrap {
  background: var(--success-50);
}

.vector-card .showcase-icon-wrap .icon {
  color: var(--success);
}

.vector-visual {
  margin-bottom: 16px;
}

.query-box {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 12px 16px;
  margin-bottom: 12px;
  box-shadow: var(--shadow-sm);
}

.query-label {
  font-size: 11px;
  color: var(--text-muted);
  display: block;
  margin-bottom: 4px;
}

.query-text {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
}

.vector-arrows {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-bottom: 12px;
}

.arrow-up {
  width: 0;
  height: 0;
  border-left: 8px solid transparent;
  border-right: 8px solid transparent;
  border-bottom: 12px solid var(--success);
  animation: arrowFloat 1.5s ease-in-out infinite;
}

.arrow-up:nth-child(2) {
  animation-delay: 0.3s;
}

.arrow-up:nth-child(3) {
  animation-delay: 0.6s;
}

@keyframes arrowFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

.match-results {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.match-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 10px 14px;
  border-radius: var(--radius-sm);
}

.match-name {
  font-size: 14px;
  color: var(--text-primary);
}

.match-score {
  font-size: 14px;
  font-weight: 600;
  color: var(--success);
}

.showcase-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.showcase-tag {
  font-size: 11px;
  padding: 4px 10px;
  background: rgba(16, 185, 129, 0.1);
  color: var(--success);
  border-radius: var(--radius-full);
}

.ai-workflow {
  padding: 0 16px 32px;
}

.workflow-steps {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 20px;
  box-shadow: var(--shadow-sm);
}

.workflow-step {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid var(--surface-3);
}

.workflow-step:last-child {
  border-bottom: none;
}

.step-number {
  width: 28px;
  height: 28px;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
  font-size: 14px;
  font-weight: 600;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14px;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  min-width: 0;
}

.step-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.step-desc {
  font-size: 12px;
  color: var(--text-muted);
  display: block;
  margin-top: 2px;
}

.step-icon {
  width: 24px;
  height: 24px;
  color: var(--text-muted);
  margin-left: 8px;
}

.bottom-placeholder {
  height: 120px;
}