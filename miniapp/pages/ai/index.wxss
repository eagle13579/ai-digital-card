.hero-section {
  position: relative;
  padding: 120rpx 32px 40px;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 50%, #8B5CF6 100%);
}

.hero-glow {
  position: absolute;
  top: -50%;
  left: -20%;
  width: 140%;
  height: 140%;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.15) 0%, transparent 50%);
  animation: rotateGlow 20s linear infinite;
}

@keyframes rotateGlow {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-icon {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
}

.hero-icon .icon {
  width: 100%;
  height: 100%;
  background: #fff;
}

.ai-pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3px solid rgba(255, 255, 255, 0.4);
  animation: aiPulse 2s ease-out infinite;
}

@keyframes aiPulse {
  0% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
  }
  100% {
    transform: translate(-50%, -50%) scale(1.5);
    opacity: 0;
  }
}

.hero-title {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 64rpx;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 64rpx;
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-stat .stat-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.hero-stat .stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.hero-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
}

.ai-capabilities {
  padding: 0 16px;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.capability-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  transition: all var(--transition-normal);
}

.capability-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.cap-icon-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.cap-icon-wrap .icon {
  width: 56rpx;
  height: 56rpx;
  background: #fff;
}

.cap-content {
  flex: 1;
  min-width: 0;
}

.cap-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.cap-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cap-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cap-tag {
  font-size: 22rpx;
  padding: 4rpx 8px;
  border-radius: var(--radius-full);
}

.cap-arrow {
  width: 48rpx;
  height: 48rpx;
  color: var(--text-muted);
  margin-left: 16rpx;
}

.feature-showcase {
  padding: 64rpx 16px;
}

.section-header {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.section-subtitle {
  font-size: 28rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 8rpx;
}

.showcase-grid {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.showcase-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-sm);
}

.showcase-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.showcase-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  background: var(--primary-50);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.showcase-icon-wrap .icon {
  width: 36rpx;
  height: 36rpx;
  color: var(--primary);
}

.showcase-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.graph-visual {
  position: relative;
  height: 320rpx;
  background: linear-gradient(135deg, #EEF2FF 0%, #F3E8FF 100%);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 32rpx;
}

.graph-nodes {
  position: relative;
  width: 100%;
  height: 100%;
}

.graph-node {
  position: absolute;
  width: 96rpx;
  height: 96rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  transition: all var(--transition-normal);
}

.graph-node.central {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
}

.graph-node.central .node-label {
  color: #fff;
}

.node-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.graph-edges {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 240rpx;
  height: 240rpx;
  transform: translate(-50%, -50%);
}

.edge-line {
  position: absolute;
  top: 50%;
  left: 0;
  width: 50%;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary), transparent);
  transform-origin: right center;
}

.showcase-stats {
  display: flex;
  justify-content: space-around;
}

.mini-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mini-num {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary);
}

.mini-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.vector-card {
  background: linear-gradient(135deg, #F0FDF4 0%, #ECFDF5 100%);
}

.vector-card .showcase-icon-wrap {
  background: var(--success-50);
}

.vector-card .showcase-icon-wrap .icon {
  color: var(--success);
}

.vector-visual {
  margin-bottom: 32rpx;
}

.query-box {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx 16px;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.query-label {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 8rpx;
}

.query-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.vector-arrows {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 24rpx;
}

.arrow-up {
  width: 0;
  height: 0;
  border-left: 8px solid transparent;
  border-right: 8px solid transparent;
  border-bottom: 12px solid var(--success);
  animation: arrowFloat 1.5s ease-in-out infinite;
}

.arrow-up:nth-child(2) {
  animation-delay: 0.3s;
}

.arrow-up:nth-child(3) {
  animation-delay: 0.6s;
}

@keyframes arrowFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

.match-results {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.match-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 20rpx 14px;
  border-radius: var(--radius-sm);
}

.match-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.match-score {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--success);
}

.showcase-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.showcase-tag {
  font-size: 22rpx;
  padding: 8rpx 10px;
  background: rgba(16, 185, 129, 0.1);
  color: var(--success);
  border-radius: var(--radius-full);
}

.ai-workflow {
  padding: 0 16px 32px;
}

.workflow-steps {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-sm);
}

.workflow-step {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid var(--surface-3);
}

.workflow-step:last-child {
  border-bottom: none;
}

.step-number {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  min-width: 0;
}

.step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.step-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 4rpx;
}

.step-icon {
  width: 48rpx;
  height: 48rpx;
  color: var(--text-muted);
  margin-left: 16rpx;
}

.bottom-placeholder {
  height: 240rpx;
}

/* ===== Section layout for AI index ===== */

.feature-section {
  padding: 0 20px;
  margin-bottom: 64rpx;
}

.feature-section:last-child {
  margin-bottom: 80rpx;
}

.feature-section .section-header {
  margin-bottom: 32rpx;
  padding-left: 8rpx;
}

.feature-section .section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  position: relative;
  padding-left: 28rpx;
}

.feature-section .section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 8rpx;
  bottom: 8rpx;
  width: 8rpx;
  border-radius: 8rpx;
  background: linear-gradient(180deg, var(--primary), var(--primary-light));
}

.feature-section .section-subtitle {
  font-size: 26rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 8rpx;
  padding-left: 36rpx;
}

/* Feature card list */
.feature-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feature-card {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.feature-card:active {
  transform: scale(0.98);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.card-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(8px);
}

.card-icon {
  font-size: 64rpx;
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 28rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.card-text {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-arrow {
  font-size: 48rpx;
  color: var(--text-muted);
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* Section divider accent */
.feature-section + .feature-section {
  position: relative;
}

.feature-section + .feature-section::before {
  content: '';
  display: block;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--surface-3), transparent);
  margin: 0 20px 32px;
}