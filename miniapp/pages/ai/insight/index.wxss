.insight-header {
  display: flex;
  align-items: center;
  padding: 40rpx 16px;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.back-btn .icon {
  width: 48rpx;
  height: 48rpx;
  color: #fff;
}

.header-title {
  flex: 1;
}

.header-title .title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  display: block;
}

.header-title .subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 4rpx;
  display: block;
}

.insight-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 12px;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: var(--font-weight-bold);
}

.stats-overview {
  display: flex;
  gap: 20rpx;
  padding: 40rpx 16px;
}

.stat-card {
  flex: 1;
  background: var(--surface-1);
  border-radius: var(--radius-lg);
  padding: 32rpx 12px;
  text-align: center;
  box-shadow: var(--shadow-sm);
  border-top: 3px solid #6366F1;
}

.stat-card:nth-child(2) {
  border-top-color: #8B5CF6;
}

.stat-card:nth-child(3) {
  border-top-color: #A78BFA;
}

.stat-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  display: block;
}

.chart-section {
  margin: 0 16px 20px;
  background: var(--surface-1);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.chart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.chart-title {
  font-size: 30rpx;
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
}

.chart-unit {
  font-size: 22rpx;
  color: var(--text-muted);
}

.chart-container {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 360rpx;
  padding-top: 16rpx;
}

.chart-bar-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
  justify-content: flex-end;
}

.chart-bar {
  width: 56rpx;
  background: linear-gradient(180deg, #6366F1, #8B5CF6);
  border-radius: 12rpx 6px 2px 2px;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 8rpx;
  min-height: 40rpx;
  transition: height 0.3s ease;
  position: relative;
}

.chart-bar-value {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
}

.chart-bar-label {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
  text-align: center;
}

.insight-list-section {
  padding: 0 16px 24px;
}

.insight-list-section .section-title {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: 28rpx;
}

.insight-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.insight-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  background: var(--surface-1);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}

.insight-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(139, 92, 246, 0.1));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.insight-content {
  flex: 1;
}

.insight-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.insight-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  display: block;
}

.insight-tag {
  font-size: 20rpx;
  padding: 6rpx 8px;
  border-radius: 20rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.insight-tag.positive {
  background: rgba(16, 185, 129, 0.1);
  color: #10B981;
}

.insight-tag.suggestion {
  background: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
}

.loading-mask {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: var(--text-muted);
}
