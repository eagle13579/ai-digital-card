/* ============================================================
 * AI洞察页 — 深色适配 + 玻璃卡片 + spring动效 + orb光晕
 * 设计系统: tokens.wxss + tailwind-like.wxss (全局注入)
 * 降级方案: 微信低版本不支持backdrop-filter时，使用 rgba(20,20,24,0.85) + filter:blur() 替代
 * ============================================================ */

/* ── 页面基底 — 深色 + 光晕背景 ── */
.insight-page {
  min-height: 100vh;
  background: var(--bg-page);
}

/* ── 顶部导航栏 — 玻璃层3 + orb光晕 ── */
.insight-header {
  display: flex;
  align-items: center;
  padding: 40rpx var(--space-6);
  background: var(--glass-bg-3);
  backdrop-filter: blur(var(--glass-blur-3));
  -webkit-backdrop-filter: blur(var(--glass-blur-3));
  border-bottom: var(--glass-border-3);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: var(--orb-md), var(--shadow-glass-edge);
}

.insight-header .back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-6);
  border-radius: var(--radius-full);
  background: var(--bg-glass-1);
  border: var(--glass-border-1);
  transition: all var(--duration-normal) var(--ease-spring);
}
.insight-header .back-btn:active {
  transform: scale(0.9);
  background: var(--bg-hover);
}
.insight-header .back-btn .icon {
  font-size: var(--text-2xl);
  color: var(--text-primary);
  line-height: 1;
}

.insight-header .header-title {
  flex: 1;
}
.insight-header .header-title .title {
  font-size: var(--text-xl);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  letter-spacing: var(--tracking-tight);
}
.insight-header .header-title .subtitle {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-top: 4rpx;
  display: block;
}

/* 刷新按钮 — 玻璃胶囊 */
.insight-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--bg-glass-2);
  padding: var(--space-3) var(--space-5);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  color: var(--text-secondary);
  border: var(--glass-border-1);
  transition: all var(--duration-normal) var(--ease-spring);
}
.insight-badge:active {
  transform: scale(0.95);
  background: var(--bg-hover);
}

/* ── 加载状态 ── */
.loading-mask {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-16) 0;
  font-size: var(--text-base);
  color: var(--text-tertiary);
}

/* ── 统计概览 — 三玻璃卡片 ── */
.stats-overview {
  display: flex;
  gap: var(--space-5);
  padding: var(--space-8) var(--space-6);
}

.stat-card {
  flex: 1;
  background: var(--glass-bg-2);
  backdrop-filter: blur(var(--glass-blur-2));
  -webkit-backdrop-filter: blur(var(--glass-blur-2));
  border: var(--glass-border-2);
  border-radius: var(--radius-md);
  padding: var(--space-8) var(--space-4);
  text-align: center;
  box-shadow: var(--orb-sm), var(--shadow-glass-edge);
  transition: all var(--duration-normal) var(--ease-spring);
}
.stat-card:active {
  transform: scale(0.96);
  box-shadow: var(--orb-md);
}
/* 三重渐变顶部光边 */
.stat-card:nth-child(1) {
  border-top: 2px solid var(--cyan);
}
.stat-card:nth-child(2) {
  border-top: 2px solid var(--purple);
}
.stat-card:nth-child(3) {
  border-top: 2px solid var(--pink);
}

.stat-icon {
  font-size: 48rpx;
  margin-bottom: var(--space-3);
}
.stat-value {
  font-size: var(--text-3xl);
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  letter-spacing: var(--tracking-tight);
}
.stat-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: var(--space-2);
  display: block;
  letter-spacing: var(--tracking-wide);
}

/* ── 趋势图 — 玻璃卡片 ── */
.chart-section {
  margin: 0 var(--space-6) var(--space-6);
  background: var(--glass-bg-2);
  backdrop-filter: blur(var(--glass-blur-2));
  -webkit-backdrop-filter: blur(var(--glass-blur-2));
  border: var(--glass-border-2);
  border-radius: var(--radius-md);
  padding: var(--space-8);
  box-shadow: var(--orb-sm), var(--shadow-glass-edge);
}

.chart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-8);
}
.chart-title {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: var(--tracking-tight);
}
.chart-unit {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
}

.chart-container {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 360rpx;
  padding-top: var(--space-4);
}

.chart-bar-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
  justify-content: flex-end;
}

.chart-bar {
  width: 56rpx;
  background: var(--gradient-cyan-purple);
  border-radius: var(--radius-xs) 4rpx 2rpx 2rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: var(--space-2);
  min-height: 40rpx;
  transition: height var(--duration-slow) var(--ease-spring);
  position: relative;
  box-shadow: var(--orb-cyan);
}

.chart-bar-value {
  font-size: var(--text-xs);
  color: #fff;
  font-weight: 500;
}
.chart-bar-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: var(--space-3);
  text-align: center;
}

/* ── 洞察列表 — 玻璃卡片项 ── */
.insight-list-section {
  padding: 0 var(--space-6) var(--space-8);
}
.insight-list-section .section-title {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-6);
  letter-spacing: var(--tracking-tight);
}

.insight-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

.insight-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-5);
  background: var(--glass-bg-2);
  backdrop-filter: blur(var(--glass-blur-2));
  -webkit-backdrop-filter: blur(var(--glass-blur-2));
  border: var(--glass-border-2);
  border-radius: var(--radius-md);
  padding: var(--space-6);
  box-shadow: var(--orb-sm), var(--shadow-glass-edge);
  transition: all var(--duration-normal) var(--ease-spring);
}
.insight-item:active {
  transform: scale(0.98);
  box-shadow: var(--orb-md);
  background: var(--bg-hover);
}

.insight-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-glass-1);
  border: var(--glass-border-1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  box-shadow: var(--orb-sm);
}

.insight-content {
  flex: 1;
}
.insight-title {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-2);
}
.insight-desc {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  line-height: var(--text-sm-lh);
  display: block;
}

/* 洞察标签 — 语义色 */
.insight-tag {
  font-size: var(--text-xs);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  flex-shrink: 0;
  font-weight: 500;
  letter-spacing: var(--tracking-wide);
}
.insight-tag.positive {
  background: rgba(16, 185, 129, 0.15);
  color: var(--success);
  border: 0.5px solid rgba(16, 185, 129, 0.25);
}
.insight-tag.suggestion {
  background: rgba(245, 158, 11, 0.15);
  color: var(--warning);
  border: 0.5px solid rgba(245, 158, 11, 0.25);
}

/* ── spring 过渡工具 ── */
.spring-hover {
  transition: all var(--duration-normal) var(--ease-spring);
}
