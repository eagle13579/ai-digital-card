.insight-header { text-align: center; padding: 24px 16px 16px; }
.insight-title { font-size: 20px; font-weight: 700; color: #1a1a1a; display: block; }
.insight-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; padding: 0 16px 20px; }
.insight-card { background: #fff; border-radius: 12px; padding: 16px; text-align: center; box-shadow: 0 2px 6px rgba(0,0,0,0.04); }
.insight-num { font-size: 24px; font-weight: 700; color: #1657ff; display: block; }
.insight-label { font-size: 11px; color: #999; display: block; margin-top: 4px; }
.insight-tip { font-size: 13px; color: #666; display: block; padding: 6px 0; line-height: 1.6; }

.chart-card { background: #fff; border-radius: 12px; margin: 0 16px 20px; padding: 16px; box-shadow: 0 2px 6px rgba(0,0,0,0.04); }
.trend-canvas { width: 100%; height: 200px; display: block; }

.card { background: #fff; border-radius: 12px; margin: 0 16px 32px; padding: 16px; box-shadow: 0 2px 6px rgba(0,0,0,0.04); }
.card-header { margin-bottom: 12px; }
.card-header .title { font-size: 15px; font-weight: 600; color: #1a1a1a; }
.card-body { }

.loading-state { text-align: center; padding: 60px 16px; }
.loading-text { font-size: 14px; color: #999; }
