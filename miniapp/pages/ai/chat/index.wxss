/**
 * ============================================================
 *  pages/ai/chat/index.wxss — AI聊天页
 *  设计体系: AI原生暗色 | 玻璃三层 | 弹簧动效 | Orb光晕
 *  基底 #0A0A18 | 三重渐变 #06b6d4→#8b5cf6→#ec4899
 *  弹簧曲线 cubic-bezier(0.34, 1.56, 0.64, 1)
 *  字体: Geist + Noto Sans SC (via token)
 * ============================================================
 * 降级方案: 微信低版本不支持backdrop-filter时，使用 rgba(20,20,24,0.85) + filter:blur() 替代
 */

/* ══════════════════════════════════════════════
   页面容器 — 深色基底 + Orb光晕背景
   ══════════════════════════════════════════════ */
.chat-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg-page);
  position: relative;
  overflow: hidden;
}

/* Orb 光晕大气层 — 三层辐射渐变 */
.chat-page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  background:
    radial-gradient(ellipse 700rpx 500rpx at 15% 10%, rgba(6, 182, 212, 0.10), transparent),
    radial-gradient(ellipse 600rpx 600rpx at 75% 25%, rgba(139, 92, 246, 0.08), transparent),
    radial-gradient(ellipse 500rpx 400rpx at 50% 85%, rgba(236, 72, 153, 0.06), transparent);
}

/* 让所有直接子级在z-index上层 */
.chat-page > view,
.chat-page > scroll-view {
  position: relative;
  z-index: 1;
}

/* 模式信息内联布局 */
.mode-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
}

/* ══════════════════════════════════════════════
   顶部导航 — 玻璃导航栏
   ══════════════════════════════════════════════ */
.chat-header {
  display: flex;
  align-items: center;
  padding: 40rpx var(--space-6);
  background: rgba(15, 15, 19, 0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 0.5px solid rgba(255, 255, 255, 0.06);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: inset 0 0.5px 0 rgba(255, 255, 255, 0.04);
}

/* 返回按钮 — spring 动效 */
.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-4);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 0.5px solid rgba(255, 255, 255, 0.06);
  transition: transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1),
              background 200ms ease-out;
}

.back-btn:active {
  transform: scale(0.90);
  background: rgba(255, 255, 255, 0.10);
}

.back-btn .icon {
  font-size: 48rpx;
  color: var(--text-primary);
  line-height: 1;
}

.header-title {
  flex: 1;
}

.header-title .title {
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  letter-spacing: var(--tracking-tight);
}

.header-title .subtitle {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  margin-top: 4rpx;
  display: block;
}

/* AI在线徽章 — 玻璃质感 */
.ai-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(16, 185, 129, 0.12);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  padding: 8rpx var(--space-4);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: 500;
  color: #10B981;
  border: 0.5px solid rgba(16, 185, 129, 0.20);
  box-shadow: var(--orb-sm);
}

.ai-dot {
  width: 14rpx;
  height: 14rpx;
  background: #10B981;
  border-radius: 50%;
  animation: pulse-dot 2s ease-in-out infinite;
  box-shadow: var(--orb-sm);
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.85); }
}

/* ══════════════════════════════════════════════
   模式切换栏 — 玻璃卡片双选项卡
   ══════════════════════════════════════════════ */
.mode-switch {
  display: flex;
  padding: var(--space-4) var(--space-6);
  gap: var(--space-4);
  background: rgba(255, 255, 255, 0.02);
  border-bottom: 0.5px solid rgba(255, 255, 255, 0.04);
}

.mode-tab {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-4) var(--space-4);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 0.5px solid rgba(255, 255, 255, 0.04);
  transition: all 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
  cursor: pointer;
  position: relative;
  overflow: hidden;
}

.mode-tab:active {
  transform: scale(0.97);
}

/* 选项卡激活态 — 紫/青渐变 + orb光晕 */
.mode-tab.active.rag {
  background: rgba(6, 182, 212, 0.08);
  border-color: rgba(6, 182, 212, 0.30);
  box-shadow: var(--orb-cyan), inset 0 0.5px 0 rgba(6, 182, 212, 0.15);
}

.mode-tab.active.deepseek {
  background: rgba(139, 92, 246, 0.08);
  border-color: rgba(139, 92, 246, 0.30);
  box-shadow: var(--orb-md), inset 0 0.5px 0 rgba(139, 92, 246, 0.15);
}

/* 激活指示条 */
.mode-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 3rpx;
  border-radius: 2rpx;
}

.mode-tab.active.rag::after {
  background: var(--gradient-cyan-only);
  box-shadow: 0 0 10px rgba(6, 182, 212, 0.4);
}

.mode-tab.active.deepseek::after {
  background: var(--gradient-cyan-purple);
  box-shadow: 0 0 10px rgba(139, 92, 246, 0.4);
}

.mode-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.mode-label {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--text-secondary);
  transition: color 250ms ease-out;
}

.mode-tab.active .mode-label {
  color: var(--text-primary);
}

.mode-tab.active.rag .mode-label {
  color: var(--cyan-light);
}

.mode-tab.active.deepseek .mode-label {
  color: var(--purple-light);
}

.mode-desc {
  font-size: var(--text-xs);
  color: var(--text-quaternary);
  white-space: nowrap;
}

.mode-tab.active .mode-desc {
  color: var(--text-tertiary);
}

/* ══════════════════════════════════════════════
   聊天内容区 — 透明基底
   ══════════════════════════════════════════════ */
.chat-content {
  flex: 1;
  height: calc(100vh - 280rpx);
  padding: var(--space-6);
  background: transparent;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
  padding-bottom: var(--space-4);
}

/* ══════════════════════════════════════════════
   消息气泡 — 玻璃卡片 vs 渐变气泡
   ══════════════════════════════════════════════ */
.message-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
  animation: message-in 350ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

@keyframes message-in {
  0% { opacity: 0; transform: translateY(20rpx) scale(0.97); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

.message-item.user {
  flex-direction: row-reverse;
}

/* 头像 — orb光晕 */
.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-avatar {
  background: rgba(139, 92, 246, 0.12);
  border: 1px solid rgba(139, 92, 246, 0.20);
  box-shadow: var(--orb-md);
}

.ai-icon {
  font-size: 36rpx;
}

.user-avatar {
  background: rgba(6, 182, 212, 0.08);
  border: 1px solid rgba(6, 182, 212, 0.15);
  box-shadow: var(--orb-cyan);
  overflow: hidden;
}

.user-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* 消息气泡容器 */
.message-content {
  max-width: 75%;
  display: flex;
  flex-direction: column;
}

/* AI消息气泡 — 玻璃卡片 */
.message-item.ai .message-content {
  align-items: flex-start;
}

.message-item.ai .message-text {
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 0.5px solid rgba(255, 255, 255, 0.06);
  border-radius: 4rpx var(--radius-lg) var(--radius-lg) var(--radius-lg);
  padding: var(--space-5) var(--space-5);
  font-size: var(--text-base);
  line-height: 1.65;
  color: var(--text-primary);
  white-space: pre-wrap;
  word-break: break-all;
  display: block;
  box-shadow: var(--orb-md), inset 0 0.5px 0 rgba(255, 255, 255, 0.04);
  position: relative;
  overflow: hidden;
}

/* 玻璃气泡顶部微光 */
.message-item.ai .message-text::before {
  content: '';
  position: absolute;
  top: -1px;
  left: 10%;
  right: 50%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.10), transparent);
  pointer-events: none;
}

/* 用户消息气泡 — 渐变背景 */
.message-item.user .message-content {
  align-items: flex-end;
}

.message-item.user .message-text {
  background: var(--gradient-cyan-purple);
  color: #fff;
  border-radius: var(--radius-lg) 4rpx var(--radius-lg) var(--radius-lg);
  padding: var(--space-5) var(--space-5);
  font-size: var(--text-base);
  line-height: 1.65;
  white-space: pre-wrap;
  word-break: break-all;
  display: block;
  box-shadow: var(--orb-md);
}

/* 消息时间 */
.message-time {
  font-size: var(--text-xs);
  color: var(--text-quaternary);
  margin-top: var(--space-2);
  display: block;
  letter-spacing: var(--tracking-wide);
}

.message-item.user .message-time {
  text-align: right;
}

/* ══════════════════════════════════════════════
   打字中指示器 — 紫色玻璃点
   ══════════════════════════════════════════════ */
.typing-indicator {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: var(--space-5) var(--space-6);
  background: rgba(139, 92, 246, 0.06);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-radius: 4rpx var(--radius-lg) var(--radius-lg) var(--radius-lg);
  border: 0.5px solid rgba(139, 92, 246, 0.10);
  min-width: 120rpx;
}

.typing-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--purple);
  border-radius: 50%;
  animation: typing 1.4s infinite var(--ease-in-out);
  box-shadow: 0 0 8px rgba(139, 92, 246, 0.3);
}

.typing-dot:nth-child(1) { animation-delay: 0s; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1.1); opacity: 1; }
}

/* ══════════════════════════════════════════════
   快捷问题 — 玻璃标签
   ══════════════════════════════════════════════ */
.quick-questions {
  padding: var(--space-4) var(--space-6) var(--space-6);
  position: relative;
  z-index: 1;
}

.quick-title {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  margin-bottom: var(--space-4);
  display: block;
  letter-spacing: var(--tracking-wide);
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
}

.quick-item {
  padding: var(--space-3) var(--space-5);
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  color: var(--text-secondary);
  border: 0.5px solid rgba(255, 255, 255, 0.06);
  transition: all 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
  cursor: pointer;
}

.quick-item:active {
  background: rgba(139, 92, 246, 0.10);
  border-color: rgba(139, 92, 246, 0.20);
  color: var(--purple-light);
  transform: scale(0.96);
  box-shadow: var(--orb-md);
}

/* ══════════════════════════════════════════════
   底部输入区 — 玻璃面板
   ══════════════════════════════════════════════ */
.input-area {
  display: flex;
  align-items: center;
  padding: var(--space-4) var(--space-6);
  background: rgba(20, 20, 24, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 0.5px solid rgba(255, 255, 255, 0.06);
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  position: relative;
  z-index: 2;
  box-shadow: inset 0 0.5px 0 rgba(255, 255, 255, 0.04);
}

.chat-input {
  flex: 1;
  height: 88rpx;
  padding: 0 var(--space-6);
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-radius: var(--radius-full);
  font-size: var(--text-base);
  color: var(--text-primary);
  border: 0.5px solid rgba(255, 255, 255, 0.06);
  transition: border 200ms ease-out, box-shadow 200ms ease-out;
}

.chat-input:focus {
  border-color: rgba(139, 92, 246, 0.25);
  box-shadow: 0 0 16px rgba(139, 92, 246, 0.06), inset 0 0.5px 0 rgba(139, 92, 246, 0.08);
}

.chat-input::placeholder {
  color: var(--text-quaternary);
  font-size: var(--text-base);
}

/* 发送按钮 — Spring动效 + Orb光晕 */
.send-btn {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gradient-cyan-purple);
  border-radius: 50%;
  margin-left: var(--space-4);
  flex-shrink: 0;
  box-shadow: var(--orb-md);
  transition: transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1),
              box-shadow 250ms ease-out;
  cursor: pointer;
  border: none;
}

.send-btn:active {
  transform: scale(0.90);
  box-shadow: 0 4px 20px rgba(6, 182, 212, 0.30), 0 0 30px rgba(139, 92, 246, 0.15);
}

.send-btn.disabled {
  opacity: 0.35;
  pointer-events: none;
}

.send-btn .icon {
  width: 40rpx;
  height: 40rpx;
  filter: brightness(10);
}

/* ══════════════════════════════════════════════
   滚动条 — 暗色极细
   ══════════════════════════════════════════════ */
.chat-content::-webkit-scrollbar {
  width: 3rpx;
  background: transparent;
}

.chat-content::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.10);
  border-radius: 2rpx;
}

/* ══════════════════════════════════════════════
   工具类 — 页面内复用
   ══════════════════════════════════════════════ */
/* Spring按压基类（用于WXML class组合） */
.spring-tap {
  transition: transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
}
.spring-tap:active {
  transform: scale(0.95);
}

/* Orb脉冲 */
.orb-pulse {
  animation: orb-pulse 4s var(--ease-in-out) infinite;
}
@keyframes orb-pulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}
