.chat-page { display: flex; flex-direction: column; height: 100vh; background: #0f0f1a; }
.chat-scroll { flex: 1; padding: 16px; }
.msg-list { display: flex; flex-direction: column; gap: 12px; }
.msg { display: flex; align-items: flex-start; }
.msg-user { justify-content: flex-end; }
.msg-ai { justify-content: flex-start; }
.msg-avatar { width: 36px; height: 36px; border-radius: 18px; flex-shrink: 0; background: rgba(255,255,255,0.1); }
.msg-user .msg-avatar { margin-left: 8px; }
.msg-ai .msg-avatar { margin-right: 8px; }
.msg-bubble { max-width: 80%; }
.msg-content { padding: 10px 14px; border-radius: 12px; font-size: 14px; line-height: 1.6; }
.msg-user .msg-content { background: #8b5cf6; color: #fff; border-radius: 12px 4px 12px 12px; }
.msg-ai .msg-content { background: rgba(30,30,50,0.8); color: #fff; border-radius: 4px 12px 12px 12px; }
.chat-input { display: flex; align-items: center; padding: 12px 16px; background: rgba(20,20,35,0.95); border-top: 1px solid rgba(255,255,255,0.08); gap: 8px; }
.chat-input-field { flex: 1; height: 40px; background: rgba(255,255,255,0.05); border-radius: 20px; padding: 0 16px; font-size: 14px; color: #fff; }
.chat-input-field::placeholder { color: rgba(255,255,255,0.3); }
.chat-send-btn { height: 36px; padding: 0 16px; background: linear-gradient(135deg, #06b6d4, #8b5cf6); color: #fff; border-radius: 18px; font-size: 13px; border: none; flex-shrink: 0; }
.chat-send-btn[disabled] { opacity: 0.5; }