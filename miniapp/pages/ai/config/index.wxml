<view class="page-container">
  <view class="glass-card">
    <view class="glass-card-header">
      <text class="title">AI 功能配置</text>
    </view>
    <view class="glass-card-body">
      <view class="config-item">
        <view class="config-info">
          <text class="config-name">智能匹配</text>
          <text class="config-desc">自动推荐匹配联系人</text>
        </view>
        <switch checked="{{autoMatch}}" data-key="autoMatch" bindchange="toggle" color="#8b5cf6" />
      </view>
      <view class="config-item">
        <view class="config-info">
          <text class="config-name">智能回复</text>
          <text class="config-desc">AI自动回复访客咨询</text>
        </view>
        <switch checked="{{smartReply}}" data-key="smartReply" bindchange="toggle" color="#8b5cf6" />
      </view>
      <view class="config-item">
        <view class="config-info">
          <text class="config-name">数据同步</text>
          <text class="config-desc">同步名片数据到云端</text>
        </view>
        <switch checked="{{dataSync}}" data-key="dataSync" bindchange="toggle" color="#8b5cf6" />
      </view>
      <view class="config-item">
        <view class="config-info">
          <text class="config-name">每日简报</text>
          <text class="config-desc">每天推送数据摘要</text>
        </view>
        <switch checked="{{dailyDigest}}" data-key="dailyDigest" bindchange="toggle" color="#8b5cf6" />
      </view>
    </view>
  </view>
</view>
