.config-header {
  display: flex;
  align-items: center;
  padding: 40rpx 16px;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.back-btn .icon {
  width: 48rpx;
  height: 48rpx;
  color: #fff;
}

.header-title {
  flex: 1;
}

.header-title .title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  display: block;
}

.header-title .subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 4rpx;
  display: block;
}

.config-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 12px;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: var(--font-weight-bold);
}

.settings-section {
  padding: 40rpx 16px 8px;
}

.settings-section .section-title {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: 28rpx;
}

.settings-list {
  background: var(--surface-1);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 16px;
  border-bottom: 1px solid var(--border-subtle);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

.setting-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: rgba(249, 115, 22, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.setting-text {
  flex: 1;
}

.setting-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
}

.setting-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
  display: block;
}

.setting-switch {
  transform: scale(0.8);
  flex-shrink: 0;
}

.setting-value {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.welcome-section {
  padding: 0 16px;
}

.welcome-section .section-title {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: 28rpx;
  padding-top: 40rpx;
}

.welcome-card {
  background: var(--surface-1);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.welcome-preview {
  margin-bottom: 28rpx;
}

.preview-label {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 16rpx;
}

.preview-bubble {
  background: linear-gradient(135deg, rgba(249, 115, 22, 0.08), rgba(251, 146, 60, 0.08));
  border-radius: 8rpx 16px 16px 16px;
  padding: 24rpx 16px;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
  max-width: 85%;
}

.welcome-input {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  background: var(--surface-2);
  border-radius: var(--radius-lg);
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.5;
  box-sizing: border-box;
  border: 1px solid var(--border-subtle);
}

.welcome-count {
  font-size: 22rpx;
  color: var(--text-muted);
  text-align: right;
  display: block;
  margin-top: 12rpx;
}

.save-section {
  padding: 48rpx 16px 32px;
}

.save-btn {
  background: linear-gradient(135deg, #F97316, #FB923C);
  padding: 28rpx;
  border-radius: var(--radius-lg);
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  box-shadow: 0 4px 16px rgba(249, 115, 22, 0.35);
}

.save-btn:active {
  opacity: 0.85;
}
