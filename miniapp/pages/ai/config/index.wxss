.config-item { display: flex; align-items: center; justify-content: space-between; padding: 14px 0; border-bottom: 1px solid #f5f5f5; }
.config-item:last-child { border-bottom: none; }
.config-name { font-size: 15px; font-weight: 500; color: #1a1a1a; display: block; }
.config-desc { font-size: 12px; color: #999; display: block; margin-top: 2px; }
