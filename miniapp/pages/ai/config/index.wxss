/* ============================================================
 * AI配置页 — 深色适配 + 玻璃卡片 + spring动效 + orb光晕
 * 设计系统: tokens.wxss + tailwind-like.wxss (全局注入)
 * 降级方案: 微信低版本不支持backdrop-filter时，使用 rgba(20,20,24,0.85) + filter:blur() 替代
 * ============================================================ */

/* ── 页面基底 — 深色 + 光晕背景 ── */
.config-page {
  min-height: 100vh;
  background: var(--bg-page);
}

/* ── 顶部导航栏 — 玻璃层3 + orb光晕 ── */
.config-header {
  display: flex;
  align-items: center;
  padding: 40rpx var(--space-6);
  background: var(--glass-bg-3);
  backdrop-filter: blur(var(--glass-blur-3));
  -webkit-backdrop-filter: blur(var(--glass-blur-3));
  border-bottom: var(--glass-border-3);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: var(--orb-md), var(--shadow-glass-edge);
}

/* 返回按钮 — 圆形玻璃 */
.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-6);
  border-radius: var(--radius-full);
  background: var(--bg-glass-1);
  border: var(--glass-border-1);
  transition: all var(--duration-normal) var(--ease-spring);
}
.back-btn:active {
  transform: scale(0.9);
  background: var(--bg-hover);
}
.back-btn .icon {
  font-size: var(--text-2xl);
  color: var(--text-primary);
  line-height: 1;
}

/* 标题区 */
.header-title {
  flex: 1;
}
.header-title .title {
  font-size: var(--text-xl);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  letter-spacing: var(--tracking-tight);
}
.header-title .subtitle {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-top: 4rpx;
  display: block;
}

/* 设置徽章 — 玻璃胶囊 */
.config-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--bg-glass-2);
  padding: var(--space-3) var(--space-5);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  color: var(--text-secondary);
  border: var(--glass-border-1);
  transition: all var(--duration-normal) var(--ease-spring);
}
.config-badge:active {
  transform: scale(0.95);
  background: var(--bg-hover);
}

/* ── 分区标题 ── */
.section-title {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-6);
  letter-spacing: var(--tracking-tight);
}

/* ── 设置区域 ── */
.settings-section {
  padding: var(--space-8) var(--space-6) var(--space-4);
}

/* 设置列表 — 玻璃卡片层2 */
.settings-list {
  background: var(--glass-bg-2);
  backdrop-filter: blur(var(--glass-blur-2));
  -webkit-backdrop-filter: blur(var(--glass-blur-2));
  border: var(--glass-border-2);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--orb-sm), var(--shadow-glass-edge);
}

/* 设置项 */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-6) var(--space-6);
  border-bottom: var(--glass-border-1);
  transition: background var(--duration-fast) var(--ease-out);
}
.setting-item:last-child {
  border-bottom: none;
}
.setting-item:active {
  background: var(--bg-hover);
}

.setting-info {
  display: flex;
  align-items: center;
  gap: var(--space-5);
  flex: 1;
}
.setting-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-glass-1);
  border: var(--glass-border-1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  box-shadow: var(--orb-cyan);
}

.setting-text {
  flex: 1;
}
.setting-label {
  font-size: var(--text-base);
  font-weight: 500;
  color: var(--text-primary);
  display: block;
}
.setting-desc {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 4rpx;
  display: block;
}

/* Switch — 紫色主题适配 */
.setting-switch {
  transform: scale(0.8);
  flex-shrink: 0;
}

.setting-value {
  font-size: var(--text-base);
  color: var(--text-accent);
  font-weight: 500;
}

/* ── 欢迎语设置 — 玻璃卡片层2 ── */
.welcome-section {
  padding: 0 var(--space-6);
}
.welcome-section .section-title {
  padding-top: var(--space-8);
}
.welcome-card {
  background: var(--glass-bg-2);
  backdrop-filter: blur(var(--glass-blur-2));
  -webkit-backdrop-filter: blur(var(--glass-blur-2));
  border: var(--glass-border-2);
  border-radius: var(--radius-md);
  padding: var(--space-8);
  box-shadow: var(--orb-md), var(--shadow-glass-edge);
}

.welcome-preview {
  margin-bottom: var(--space-6);
}
.preview-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  display: block;
  margin-bottom: var(--space-4);
  letter-spacing: var(--tracking-wide);
  text-transform: uppercase;
}
.preview-bubble {
  background: var(--glass-bg-3);
  backdrop-filter: blur(var(--glass-blur-1));
  -webkit-backdrop-filter: blur(var(--glass-blur-1));
  border: var(--glass-border-3);
  border-radius: var(--radius-sm);
  border-bottom-left-radius: var(--radius-lg);
  padding: var(--space-5) var(--space-6);
  font-size: var(--text-base);
  color: var(--text-primary);
  line-height: var(--text-base-lh);
  max-width: 85%;
  box-shadow: var(--orb-cyan);
}

/* 欢迎语输入框 — 暗色适配玻璃输入 */
.welcome-input {
  width: 100%;
  min-height: 160rpx;
  padding: var(--space-6);
  background: var(--bg-glass-1);
  border: var(--glass-border-2);
  border-radius: var(--radius-sm);
  font-size: var(--text-base);
  color: var(--text-primary);
  line-height: var(--text-base-lh);
  box-sizing: border-box;
  transition: border var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out);
}
.welcome-input:focus {
  border-color: var(--border-accent);
  box-shadow: var(--orb-sm);
}

.welcome-count {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  text-align: right;
  display: block;
  margin-top: var(--space-3);
}

/* ── 保存按钮 — 三重渐变主按钮 + spring动效 ── */
.save-section {
  padding: var(--space-10) var(--space-6) var(--space-8);
}
.save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: var(--btn-primary-height);
  background: var(--gradient-primary);
  border: none;
  border-radius: var(--btn-primary-radius);
  color: #fff;
  font-size: var(--btn-primary-font-size);
  font-weight: 600;
  box-shadow: var(--btn-primary-orb);
  transition: all var(--duration-slow) var(--ease-spring);
  position: relative;
  overflow: hidden;
}
.save-btn:active {
  transform: scale(0.97);
  box-shadow: var(--btn-primary-hover-orb);
}

/* ── 加载骨架（备） ── */
.loading-mask {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-16) 0;
  font-size: var(--text-base);
  color: var(--text-tertiary);
}

/* ── spring 过渡工具 ── */
.spring-hover {
  transition: all var(--duration-normal) var(--ease-spring);
}
