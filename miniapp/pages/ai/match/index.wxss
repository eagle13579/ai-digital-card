/* AI匹配页 - v2.0 Dark Minimal */

/* ===== Filter Bar ===== */
.filter-bar {
  display: flex;
  align-items: center;
  margin: 0 var(--space-4) var(--space-4);
  padding: var(--space-2) var(--space-4);
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
}

.filter-label {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  margin-right: var(--space-2);
  flex-shrink: 0;
}

.filter-select {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 1;
  padding: var(--space-2) 0;
}

.filter-value {
  font-size: var(--text-base);
  color: var(--text-primary);
  font-weight: var(--weight-medium);
}

.filter-arrow {
  font-size: 10px;
  color: var(--text-tertiary);
  margin-left: 4px;
}

.filter-divider {
  width: 1px;
  height: 24px;
  background: var(--border-subtle);
  margin: 0 var(--space-3);
}

/* ===== Match List ===== */
.match-list {
  padding: 0 var(--space-4) var(--space-8);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.match-item {
  display: flex;
  align-items: center;
  padding: 14px;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
}

.match-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.match-avatar {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-full);
  flex-shrink: 0;
  margin-right: var(--space-3);
  border: 1px solid var(--border-subtle);
}

.match-info {
  flex: 1;
  min-width: 0;
}

.match-name {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  display: block;
}

.match-company {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  display: block;
}

.match-position {
  font-size: var(--text-xs);
  color: var(--text-secondary);
  display: block;
  margin-top: 1px;
}

.match-tags {
  display: flex;
  gap: 4px;
  margin-top: 4px;
  flex-wrap: wrap;
}

.match-tag {
  font-size: 10px;
  padding: 2px 8px;
  background: rgba(139, 92, 246, 0.12);
  color: var(--accent-light);
  border-radius: var(--radius-full);
}

.match-score-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-left: var(--space-2);
}

.match-score-num {
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
  color: var(--success);
}

.match-score-label {
  font-size: 10px;
  color: var(--text-tertiary);
}

/* ===== Unlock Detail ===== */
.unlock-detail {
  padding: 0 var(--space-4);
}

.detail-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-4);
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  text-align: center;
}

.detail-avatar {
  width: 64px;
  height: 64px;
  border-radius: var(--radius-full);
  margin-bottom: var(--space-3);
  border: 2px solid rgba(139, 92, 246, 0.2);
}

.detail-name {
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  display: block;
}

.detail-company {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  display: block;
  margin-top: 2px;
}

.detail-title {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  display: block;
  margin-top: 2px;
}

.detail-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: var(--space-3);
}

.detail-score-num {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  color: var(--success);
}

.detail-score-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: var(--space-3);
  padding: 0 4px;
}

.detail-tag {
  padding: 4px 12px;
  background: rgba(139, 92, 246, 0.12);
  color: var(--accent-light);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
}

.detail-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  margin-top: var(--space-4);
}

/* ===== Loading ===== */
.loading-state {
  text-align: center;
  padding: 60px 16px;
}

/* ===== 直接交换名片按钮 (列表卡片) ===== */
.match-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-left: var(--space-2);
  gap: 6px;
}

.btn-connect-mini {
  font-size: 11px;
  padding: 4px 12px;
  background: linear-gradient(135deg, #7c3aed, #a855f7);
  color: #ffffff;
  border-radius: var(--radius-full);
  border: none;
  line-height: 1.8;
  min-width: 74px;
  text-align: center;
  font-weight: var(--weight-medium);
}

.btn-connect-mini::after {
  border: none;
}

.request-sent-tag {
  font-size: 10px;
  color: var(--success);
  white-space: nowrap;
}
