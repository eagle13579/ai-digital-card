.match-header {
  display: flex;
  align-items: center;
  padding: 20px 16px;
  background: linear-gradient(135deg, #A855F7 0%, #D946EF 100%);
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
}

.back-btn .icon {
  width: 24px;
  height: 24px;
  color: #fff;
}

.header-title {
  flex: 1;
}

.header-title .title {
  font-size: 18px;
  font-weight: var(--font-weight-bold);
  display: block;
}

.header-title .subtitle {
  font-size: 12px;
  opacity: 0.8;
  margin-top: 2px;
  display: block;
}

.match-badge {
  display: flex;
  align-items: center;
  gap: 4px;
  background: rgba(255, 255, 255, 0.2);
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: var(--font-weight-bold);
}

.preference-section {
  padding: 20px 16px 12px;
}

.preference-section .section-title {
  font-size: 16px;
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: 14px;
}

.preference-list {
  background: var(--surface-1);
  border-radius: var(--radius-lg);
  padding: 16px;
  box-shadow: var(--shadow-sm);
}

.preference-item {
  margin-bottom: 16px;
}

.preference-item:last-child {
  margin-bottom: 0;
}

.pref-label {
  font-size: 13px;
  color: var(--text-muted);
  display: block;
  margin-bottom: 8px;
  font-weight: 500;
}

.pref-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.pref-tag {
  padding: 6px 14px;
  border-radius: var(--radius-full);
  font-size: 12px;
  color: var(--text-secondary);
  background: var(--surface-2);
  border: 1px solid var(--border-subtle);
  transition: all var(--transition-fast);
}

.pref-tag.active {
  background: rgba(168, 85, 247, 0.1);
  border-color: #A855F7;
  color: #A855F7;
  font-weight: 500;
}

.pref-tag:active {
  transform: scale(0.95);
}

.recommend-section {
  padding: 0 16px 24px;
}

.recommend-section .section-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 16px;
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
  margin-bottom: 14px;
}

.match-count {
  font-size: 12px;
  color: var(--text-muted);
  font-weight: normal;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.recommend-card {
  background: var(--surface-1);
  border-radius: var(--radius-lg);
  padding: 16px;
  box-shadow: var(--shadow-sm);
}

.card-top {
  display: flex;
  align-items: center;
  gap: 12px;
}

.card-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(168, 85, 247, 0.15), rgba(217, 70, 239, 0.15));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
}

.card-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.card-title {
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 2px;
  display: block;
}

.card-company {
  font-size: 11px;
  color: var(--text-muted);
  margin-top: 1px;
  display: block;
}

.match-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, rgba(168, 85, 247, 0.1), rgba(217, 70, 239, 0.1));
  padding: 8px 12px;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}

.score-value {
  font-size: 18px;
  font-weight: var(--font-weight-bold);
  color: #A855F7;
}

.score-label {
  font-size: 10px;
  color: var(--text-muted);
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--border-subtle);
}

.card-tag {
  padding: 4px 10px;
  background: var(--surface-2);
  border-radius: var(--radius-full);
  font-size: 11px;
  color: var(--text-secondary);
}

.card-actions {
  display: flex;
  gap: 10px;
  margin-top: 14px;
}

.card-action {
  flex: 1;
  text-align: center;
  padding: 10px;
  border-radius: var(--radius-lg);
  font-size: 13px;
  font-weight: 500;
}

.connect-btn {
  background: linear-gradient(135deg, #A855F7, #D946EF);
  color: #fff;
  box-shadow: 0 4px 12px rgba(168, 85, 247, 0.3);
}

.chat-btn {
  background: var(--surface-2);
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
}

.card-action:active {
  opacity: 0.85;
}
