<view class="match-page">
  <!-- 顶部导航 — 玻璃层3 -->
  <view class="match-header" style="padding-top: {{statusBarHeight}}px">
    <view class="back-btn" bindtap="goBack">
      <text class="icon">‹</text>
    </view>
    <view class="header-title">
      <text class="title">人脉匹配</text>
      <text class="subtitle">AI智能推荐 · 精准连接</text>
    </view>
    <view class="match-badge">
      <text>🤝 匹配</text>
    </view>
  </view>

  <!-- 匹配偏好设置 — 玻璃卡片 -->
  <view class="preference-section">
    <text class="section-title">匹配偏好</text>
    <view class="preference-list">
      <view class="preference-item">
        <text class="pref-label">行业</text>
        <view class="pref-tags">
          <view class="pref-tag {{preferences.industry === 'tech' ? 'active' : ''}}" data-type="industry" data-value="tech" bindtap="onPreferenceChange">科技</view>
          <view class="pref-tag {{preferences.industry === 'finance' ? 'active' : ''}}" data-type="industry" data-value="finance" bindtap="onPreferenceChange">金融</view>
          <view class="pref-tag {{preferences.industry === 'edu' ? 'active' : ''}}" data-type="industry" data-value="edu" bindtap="onPreferenceChange">教育</view>
          <view class="pref-tag {{preferences.industry === 'medical' ? 'active' : ''}}" data-type="industry" data-value="medical" bindtap="onPreferenceChange">医疗</view>
        </view>
      </view>
      <view class="preference-item">
        <text class="pref-label">地区</text>
        <view class="pref-tags">
          <view class="pref-tag {{preferences.region === 'bj' ? 'active' : ''}}" data-type="region" data-value="bj" bindtap="onPreferenceChange">北京</view>
          <view class="pref-tag {{preferences.region === 'sh' ? 'active' : ''}}" data-type="region" data-value="sh" bindtap="onPreferenceChange">上海</view>
          <view class="pref-tag {{preferences.region === 'sz' ? 'active' : ''}}" data-type="region" data-value="sz" bindtap="onPreferenceChange">深圳</view>
          <view class="pref-tag {{preferences.region === 'hz' ? 'active' : ''}}" data-type="region" data-value="hz" bindtap="onPreferenceChange">杭州</view>
        </view>
      </view>
      <view class="preference-item">
        <text class="pref-label">职位</text>
        <view class="pref-tags">
          <view class="pref-tag {{preferences.position === 'manager' ? 'active' : ''}}" data-type="position" data-value="manager" bindtap="onPreferenceChange">经理</view>
          <view class="pref-tag {{preferences.position === 'director' ? 'active' : ''}}" data-type="position" data-value="director" bindtap="onPreferenceChange">总监</view>
          <view class="pref-tag {{preferences.position === 'ceo' ? 'active' : ''}}" data-type="position" data-value="ceo" bindtap="onPreferenceChange">CEO</view>
          <view class="pref-tag {{preferences.position === 'cto' ? 'active' : ''}}" data-type="position" data-value="cto" bindtap="onPreferenceChange">CTO</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-section" wx:if="{{loading && !refreshing}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在为您智能匹配...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-section" wx:if="{{error && !loading}}">
    <view class="error-icon">⚠️</view>
    <text class="error-text">{{errorMsg || '获取推荐失败'}}</text>
    <view class="retry-btn" bindtap="onRetry">
      <text>点击重试</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-section" wx:if="{{empty && !loading && !error}}">
    <view class="empty-icon">🔍</view>
    <text class="empty-text">暂无匹配推荐</text>
    <text class="empty-hint">调整偏好或稍后再来</text>
  </view>

  <!-- 推荐人脉列表 — 玻璃卡片 -->
  <view class="recommend-section" wx:if="{{!loading && !error && !empty}}">
    <view class="section-title">
      <text>推荐人脉</text>
      <text class="match-count">共 {{recommendations.length}} 位</text>
    </view>
    <scroll-view class="recommend-scroll" scroll-y="true" refresher-enabled="true" bindrefresherrefresh="onPullDownRefresh" refresher-triggered="{{refreshing}}">
      <view class="recommend-list">
        <view class="recommend-card" wx:for="{{recommendations}}" wx:key="id">
          <view class="card-top">
            <view class="card-avatar">
              <image wx:if="{{item.avatar}}" src="{{item.avatar}}" mode="aspectFill" />
              <text wx:else>{{item.name ? item.name[0] : '?'}}</text>
            </view>
            <view class="card-info">
              <text class="card-name">{{item.name}}</text>
              <text class="card-title" wx:if="{{item.title}}">{{item.title}}</text>
              <text class="card-company" wx:if="{{item.company}}">{{item.company}}</text>
            </view>
            <view class="match-score">
              <view class="score-bar">
                <view class="score-fill" style="height: {{item.matchScore}}%;"></view>
              </view>
              <text class="score-value">{{item.matchScore}}%</text>
            </view>
          </view>
          <view class="card-tags" wx:if="{{item.tags && item.tags.length > 0}}">
            <text class="card-tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
          </view>
          <view class="card-actions">
            <view class="card-action connect-btn {{item.connected ? 'connected' : ''}}" data-id="{{item.id}}" bindtap="onConnect">
              <text>{{item.connected ? '已连接' : '交换名片'}}</text>
            </view>
            <view class="card-action chat-btn {{!item.connected ? 'disabled' : ''}}" data-id="{{item.id}}" bindtap="onChat">
              <text>在线沟通</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
