/* A/B测试页面样式 - 暗色磨砂玻璃风格 */

page {
  background: #0f0f1a;
}

.abtest-page {
  min-height: 100vh;
  padding-bottom: 32px;
}

/* 头部 */
.ab-header {
  text-align: center;
  padding: 28px 16px 16px;
}

.ab-title {
  font-size: 24px;
  font-weight: 700;
  color: #fff;
  display: block;
}

.ab-subtitle {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.4);
  display: block;
  margin-top: 4px;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 8px;
  padding: 0 16px 16px;
  overflow-x: auto;
}

.filter-tab {
  flex-shrink: 0;
  padding: 6px 16px;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20px;
  font-size: 13px;
  color: rgba(255, 255, 255, 0.5);
  transition: all 0.2s;
}

.filter-tab.active {
  background: rgba(139, 92, 246, 0.2);
  color: #a78bfa;
  font-weight: 600;
}

/* 实验卡片 */
.experiment-list {
  padding: 0 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.experiment-card {
  background: rgba(30, 30, 50, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  padding: 16px;
}

.exp-header {
  margin-bottom: 14px;
}

.exp-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6px;
}

.exp-name {
  font-size: 15px;
  font-weight: 600;
  color: #fff;
  flex: 1;
  margin-right: 8px;
}

.exp-status {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 12px;
  flex-shrink: 0;
}

.exp-status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

.exp-desc {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.4);
  line-height: 1.4;
}

/* 变体对比 */
.exp-variants {
  margin-bottom: 12px;
}

.variant {
  margin-bottom: 10px;
}

.variant:last-child {
  margin-bottom: 0;
}

.variant-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
}

.variant-name {
  font-size: 13px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.7);
}

.variant-value {
  font-size: 14px;
  font-weight: 700;
  color: #a78bfa;
}

.variant-bar-track {
  height: 6px;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 3px;
  overflow: hidden;
  margin-bottom: 2px;
}

.variant-bar {
  height: 100%;
  border-radius: 3px;
  transition: width 0.5s ease;
}

.variant-stats {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.3);
}

/* 底部信息 */
.exp-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12px;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.exp-date {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.3);
}

.exp-winner {
  font-size: 12px;
  font-weight: 600;
  color: #22C55E;
}

/* 空状态 */
.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

/* 创建区域 */
.create-area {
  padding: 20px 16px;
}

/* 加载 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100px 32px;
}

.loading-spinner {
  width: 36px;
  height: 36px;
  border: 3px solid rgba(139, 92, 246, 0.15);
  border-top-color: #8b5cf6;
  border-radius: 50%;
  animation: abSpin 0.8s linear infinite;
}

@keyframes abSpin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12px;
}

.bottom-placeholder {
  height: 40px;
}
