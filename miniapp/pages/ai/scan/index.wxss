.scan-header {
  display: flex;
  align-items: center;
  padding: 20px 16px;
  background: linear-gradient(135deg, #059669 0%, #34D399 100%);
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
}

.back-btn .icon {
  width: 24px;
  height: 24px;
  color: #fff;
}

.header-title {
  flex: 1;
}

.header-title .title {
  font-size: 18px;
  font-weight: var(--font-weight-bold);
  display: block;
}

.header-title .subtitle {
  font-size: 12px;
  opacity: 0.8;
  margin-top: 2px;
  display: block;
}

.scan-badge {
  display: flex;
  align-items: center;
  gap: 4px;
  background: rgba(255, 255, 255, 0.2);
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: var(--font-weight-bold);
}

.scan-area {
  padding: 32px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scan-frame {
  width: 280px;
  height: 200px;
  border: 2px dashed #059669;
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(5, 150, 105, 0.05);
  margin-bottom: 24px;
}

.scan-camera-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.scan-hint {
  font-size: 13px;
  color: var(--text-muted);
}

.scan-btn {
  background: linear-gradient(135deg, #059669, #34D399);
  padding: 14px 48px;
  border-radius: var(--radius-full);
  box-shadow: 0 4px 16px rgba(5, 150, 105, 0.35);
}

.scan-btn-text {
  color: #fff;
  font-size: 16px;
  font-weight: var(--font-weight-bold);
}

.scan-btn:active {
  opacity: 0.85;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0 16px;
  margin-bottom: 12px;
  font-size: 16px;
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
}

.section-tag {
  font-size: 10px;
  color: #fff;
  background: #059669;
  padding: 2px 8px;
  border-radius: 10px;
  font-weight: normal;
}

.card-preview {
  margin: 0 16px 16px;
  background: var(--surface-1);
  border-radius: var(--radius-lg);
  padding: 16px;
  box-shadow: var(--shadow-sm);
}

.card-field {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid var(--border-subtle);
}

.card-field:last-child {
  border-bottom: none;
}

.field-label {
  width: 60px;
  font-size: 13px;
  color: var(--text-muted);
  flex-shrink: 0;
}

.field-value {
  flex: 1;
  font-size: 14px;
  color: var(--text-primary);
  font-weight: 500;
}

.result-actions {
  display: flex;
  gap: 12px;
  padding: 0 16px 24px;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 12px;
  border-radius: var(--radius-lg);
  font-size: 14px;
  font-weight: var(--font-weight-bold);
}

.save-btn {
  background: linear-gradient(135deg, #059669, #34D399);
  color: #fff;
  box-shadow: 0 4px 12px rgba(5, 150, 105, 0.3);
}

.retry-btn {
  background: var(--surface-2);
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
}

.history-section {
  padding-bottom: 24px;
}

.history-list {
  margin: 0 16px;
  background: var(--surface-1);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid var(--border-subtle);
}

.history-item:last-child {
  border-bottom: none;
}

.history-icon {
  font-size: 24px;
  margin-right: 12px;
}

.history-info {
  flex: 1;
}

.history-name {
  font-size: 14px;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
}

.history-company {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 2px;
  display: block;
}

.history-time {
  font-size: 11px;
  color: var(--text-muted);
  flex-shrink: 0;
}
