.scan-header {
  display: flex;
  align-items: center;
  padding: 40rpx 16px;
  background: linear-gradient(135deg, #059669 0%, #34D399 100%);
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.back-btn .icon {
  width: 48rpx;
  height: 48rpx;
  color: #fff;
}

.header-title {
  flex: 1;
}

.header-title .title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  display: block;
}

.header-title .subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 4rpx;
  display: block;
}

.scan-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 12px;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: var(--font-weight-bold);
}

.scan-area {
  padding: 64rpx 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scan-frame {
  width: 560rpx;
  height: 400rpx;
  border: 2px dashed #059669;
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(5, 150, 105, 0.05);
  margin-bottom: 48rpx;
}

.scan-camera-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.scan-hint {
  font-size: 26rpx;
  color: var(--text-muted);
}

.scan-btn {
  background: linear-gradient(135deg, #059669, #34D399);
  padding: 28rpx 48px;
  border-radius: var(--radius-full);
  box-shadow: 0 4px 16px rgba(5, 150, 105, 0.35);
}

.scan-btn-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
}

.scan-btn:active {
  opacity: 0.85;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 16px;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
}

.section-tag {
  font-size: 20rpx;
  color: #fff;
  background: #059669;
  padding: 4rpx 8px;
  border-radius: 20rpx;
  font-weight: normal;
}

.card-preview {
  margin: 0 16px 16px;
  background: var(--surface-1);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.card-field {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid var(--border-subtle);
}

.card-field:last-child {
  border-bottom: none;
}

.field-label {
  width: 120rpx;
  font-size: 26rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

.field-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.result-actions {
  display: flex;
  gap: 24rpx;
  padding: 0 16px 24px;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
}

.save-btn {
  background: linear-gradient(135deg, #059669, #34D399);
  color: #fff;
  box-shadow: 0 4px 12px rgba(5, 150, 105, 0.3);
}

.retry-btn {
  background: var(--surface-2);
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
}

.history-section {
  padding-bottom: 48rpx;
}

.history-list {
  margin: 0 16px;
  background: var(--surface-1);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 28rpx 16px;
  border-bottom: 1px solid var(--border-subtle);
}

.history-item:last-child {
  border-bottom: none;
}

.history-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.history-info {
  flex: 1;
}

.history-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
}

.history-company {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
  display: block;
}

.history-time {
  font-size: 22rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}
