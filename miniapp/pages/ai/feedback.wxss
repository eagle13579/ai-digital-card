/* 反馈收集页面样式 - 暗色磨砂玻璃风格 */

page {
  background: #0f0f1a;
}

.feedback-page {
  min-height: 100vh;
  padding-bottom: 32px;
}

/* 头部 */
.fb-header {
  text-align: center;
  padding: 28px 16px 12px;
}

.fb-title {
  font-size: 24px;
  font-weight: 700;
  color: #fff;
  display: block;
}

.fb-subtitle {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.4);
  display: block;
  margin-top: 4px;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  margin: 8px 16px;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12px;
  padding: 3px;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  font-size: 14px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.4);
  border-radius: 10px;
  transition: all 0.2s;
}

.tab-item.active {
  background: rgba(139, 92, 246, 0.25);
  color: #a78bfa;
  font-weight: 600;
}

/* 提交卡片 */
.submit-section {
  padding: 0 16px;
}

.fb-card {
  background: rgba(30, 30, 50, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  padding: 20px;
}

.form-group {
  margin-bottom: 18px;
}

.form-label {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8px;
}

/* 选择器触发 */
.picker-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 14px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 10px;
}

.picker-text {
  font-size: 14px;
  color: #fff;
}

.picker-arrow {
  font-size: 10px;
  color: rgba(255, 255, 255, 0.3);
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 44px;
  padding: 0 14px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 10px;
  font-size: 14px;
  color: #fff;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.form-input:focus {
  border-color: #8b5cf6;
}

/* 文本域 */
.fb-textarea {
  width: 100%;
  min-height: 120px;
  padding: 14px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 10px;
  font-size: 14px;
  color: #fff;
  box-sizing: border-box;
  line-height: 1.5;
}

.fb-textarea::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.fb-textarea:focus {
  border-color: #8b5cf6;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.3);
  margin-top: 4px;
}

/* 历史记录 */
.history-section {
  padding: 0 16px;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.history-item {
  background: rgba(30, 30, 50, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  padding: 16px;
}

.hi-header {
  margin-bottom: 8px;
}

.hi-type-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6px;
}

.hi-type {
  font-size: 12px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.5);
}

.hi-status {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  padding: 2px 10px;
  border-radius: 10px;
}

.hi-status-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
}

.hi-title {
  font-size: 15px;
  font-weight: 600;
  color: #fff;
}

.hi-content {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.5;
  display: block;
  margin-bottom: 10px;
}

.hi-reply {
  background: rgba(139, 92, 246, 0.08);
  border-left: 2px solid #8b5cf6;
  border-radius: 6px;
  padding: 10px 12px;
  margin-bottom: 10px;
}

.hi-reply-label {
  font-size: 12px;
  font-weight: 600;
  color: #a78bfa;
  display: block;
  margin-bottom: 4px;
}

.hi-reply-text {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.4;
}

.hi-footer {
  display: flex;
  justify-content: flex-end;
}

.hi-date {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.25);
}

/* 空状态 */
.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.bottom-placeholder {
  height: 40px;
}
