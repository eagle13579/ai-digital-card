.section-header {
  padding: 40rpx 16px 16px;
  display: flex;
  flex-direction: column;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  background: var(--surface-2);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.back-btn .icon {
  width: 36rpx;
  height: 36rpx;
  color: var(--text-primary);
}

.section-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.section-title-sm {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 32rpx;
}

.section-subtitle {
  font-size: 28rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 8rpx;
}

.feedback-intro {
  padding: 0 16px;
  margin-bottom: 48rpx;
}

.intro-card {
  background: linear-gradient(135deg, rgba(236, 72, 153, 0.1) 0%, rgba(244, 114, 182, 0.1) 100%);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  border: 1px solid rgba(236, 72, 153, 0.2);
}

.intro-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #EC4899;
  display: block;
  margin-bottom: 16rpx;
}

.intro-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.feedback-stats {
  padding: 0 16px;
  margin-bottom: 48rpx;
}

.stat-card {
  background: linear-gradient(135deg, #EC4899 0%, #F472B6 100%);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  margin-bottom: 32rpx;
}

.stat-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.stat-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

.stat-progress {
  height: 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 100%;
  background: #fff;
  border-radius: var(--radius-full);
  transition: width 0.5s ease;
}

.stat-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-row {
  display: flex;
  gap: 24rpx;
}

.mini-stat {
  flex: 1;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  text-align: center;
}

.mini-stat.positive .mini-value { color: #22C55E; }
.mini-stat.negative .mini-value { color: #EF4444; }
.mini-stat.users .mini-value { color: #6366F1; }

.mini-value {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
}

.mini-label {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 8rpx;
}

.feedback-demo {
  padding: 0 16px;
  margin-bottom: 48rpx;
}

.demo-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-md);
}

.demo-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.demo-title {
  font-size: 28rpx;
  color: var(--text-muted);
}

.demo-match {
  font-size: 28rpx;
  font-weight: 600;
  color: #10B981;
}

.demo-content {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.demo-info {
  flex: 1;
  min-width: 0;
}

.demo-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.demo-company {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 8rpx;
}

.demo-tags {
  font-size: 24rpx;
  color: #6366F1;
}

.feedback-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  border-radius: var(--radius-md);
  padding: 24rpx;
  text-align: center;
}

.action-btn.positive {
  background: rgba(34, 197, 94, 0.1);
  border: 1px solid rgba(34, 197, 94, 0.2);
}

.action-btn.negative {
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.2);
}

.action-btn.neutral {
  background: rgba(148, 163, 184, 0.1);
  border: 1px solid rgba(148, 163, 184, 0.2);
}

.action-btn:active {
  opacity: 0.8;
}

.action-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.weight-section {
  padding: 0 16px;
  margin-bottom: 48rpx;
}

.weight-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.weight-card {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.weight-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.weight-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.weight-change {
  font-size: 28rpx;
  font-weight: 600;
}

.weight-change.up { color: #22C55E; }
.weight-change.down { color: #EF4444; }

.weight-bar-bg {
  height: 12rpx;
  background: var(--surface-2);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-bottom: 16rpx;
}

.weight-bar {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 0.3s ease;
}

.weight-meta {
  display: flex;
  justify-content: space-between;
}

.weight-before, .weight-after {
  font-size: 22rpx;
  color: var(--text-muted);
}

.history-section {
  padding: 0 16px;
  margin-bottom: 48rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx 16px;
  box-shadow: var(--shadow-sm);
}

.history-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.history-icon.positive { background: rgba(34, 197, 94, 0.1); }
.history-icon.negative { background: rgba(239, 68, 68, 0.1); }
.history-icon.neutral { background: rgba(148, 163, 184, 0.1); }

.history-icon text {
  font-size: 28rpx;
}

.history-content {
  flex: 1;
  min-width: 0;
}

.history-user {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.history-target {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
}

.history-time {
  font-size: 24rpx;
  color: var(--text-muted);
}

.bottom-placeholder {
  height: 160rpx;
}