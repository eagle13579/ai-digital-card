/* 模型服务管理页面样式 - 暗色磨砂玻璃风格 */

page {
  background: #0f0f1a;
}

.modelserve-page {
  min-height: 100vh;
  padding-bottom: 32px;
}

/* 头部 */
.ms-header {
  text-align: center;
  padding: 28px 16px 16px;
}

.ms-title {
  font-size: 24px;
  font-weight: 700;
  color: #fff;
  display: block;
}

.ms-subtitle {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.4);
  display: block;
  margin-top: 4px;
}

/* 概览统计 */
.ms-stats {
  display: flex;
  gap: 10px;
  padding: 0 16px;
  margin-bottom: 16px;
}

.ms-stat-card {
  flex: 1;
  background: rgba(30, 30, 50, 0.5);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 14px;
  border: 1px solid rgba(255, 255, 255, 0.06);
  padding: 14px 10px;
  text-align: center;
}

.ms-stat-card:active {
  opacity: 0.7;
}

.ms-stat-card.online {
  border-color: rgba(34, 197, 94, 0.2);
}

.ms-stat-card.degraded {
  border-color: rgba(245, 158, 11, 0.2);
}

.ms-stat-card.offline {
  border-color: rgba(239, 68, 68, 0.2);
}

.ms-stat-num {
  font-size: 24px;
  font-weight: 700;
  color: #fff;
  display: block;
}

.ms-stat-label {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.4);
  display: block;
  margin-top: 2px;
}

/* 刷新行 */
.ms-refresh-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 16px;
  margin-bottom: 12px;
}

.ms-filter-label {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.4);
}

.ms-refresh-btn {
  font-size: 12px;
  color: #a78bfa;
  padding: 6px 14px;
  background: rgba(139, 92, 246, 0.1);
  border-radius: 16px;
}

/* 服务卡片 */
.ms-service-list {
  padding: 0 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.ms-service-card {
  background: rgba(30, 30, 50, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  padding: 16px;
}

/* 服务头部 */
.ms-svc-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 14px;
}

.ms-svc-name-row {
  display: flex;
  align-items: center;
  gap: 12px;
  flex: 1;
}

.ms-svc-icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ms-svc-info {
  flex: 1;
}

.ms-svc-name {
  font-size: 15px;
  font-weight: 600;
  color: #fff;
  display: block;
}

.ms-svc-model {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.4);
  display: block;
  margin-top: 2px;
}

.ms-svc-status {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
  font-size: 11px;
  font-weight: 500;
  padding: 4px 12px;
  border-radius: 12px;
}

.ms-svc-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

/* 指标区域 */
.ms-svc-metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 12px;
}

.ms-metric {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 10px;
  padding: 10px 12px;
}

.ms-metric-label {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.35);
  display: block;
  margin-bottom: 4px;
}

.ms-metric-value {
  font-size: 14px;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

/* 底部 */
.ms-svc-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12px;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.ms-svc-version {
  display: flex;
  align-items: center;
  gap: 6px;
}

.ms-ver-label {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.3);
}

.ms-ver-value {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.ms-restart-btn {
  font-size: 12px;
  color: #EF4444;
  background: rgba(239, 68, 68, 0.1);
  border: none;
  border-radius: 16px;
  padding: 5px 16px;
}

/* 加载 */
.ms-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100px 32px;
}

.loading-spinner {
  width: 36px;
  height: 36px;
  border: 3px solid rgba(139, 92, 246, 0.15);
  border-top-color: #8b5cf6;
  border-radius: 50%;
  animation: msSpin 0.8s linear infinite;
}

@keyframes msSpin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12px;
}

/* 空状态 */
.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.bottom-placeholder {
  height: 40px;
}
