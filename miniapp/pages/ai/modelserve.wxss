.section-header {
  padding: 20px 16px 16px;
  display: flex;
  flex-direction: column;
}

.back-btn {
  width: 36px;
  height: 36px;
  background: var(--surface-2);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}

.back-btn .icon {
  width: 18px;
  height: 18px;
  color: var(--text-primary);
}

.section-title {
  font-size: 24px;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.section-title-sm {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16px;
}

.section-subtitle {
  font-size: 14px;
  color: var(--text-muted);
  display: block;
  margin-top: 4px;
}

.gateway-intro {
  padding: 0 16px;
  margin-bottom: 24px;
}

.intro-card {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
  border-radius: var(--radius-lg);
  padding: 16px;
  border: 1px solid rgba(99, 102, 241, 0.2);
}

.intro-title {
  font-size: 16px;
  font-weight: 600;
  color: #6366F1;
  display: block;
  margin-bottom: 8px;
}

.intro-desc {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.5;
}

.availability-status {
  padding: 0 16px;
  margin-bottom: 24px;
}

.availability-card {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  border-radius: var(--radius-lg);
  padding: 24px;
  display: flex;
  align-items: center;
  gap: 20px;
  position: relative;
  overflow: hidden;
}

.availability-ring {
  width: 64px;
  height: 64px;
  border: 4px solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 2s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.availability-content {
  flex: 1;
}

.availability-value {
  font-size: 40px;
  font-weight: 700;
  color: #fff;
  display: block;
}

.availability-label {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.9);
}

.model-layer-section {
  padding: 0 16px;
  margin-bottom: 24px;
}

.layer-stack {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.layer-card {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 16px;
  box-shadow: var(--shadow-sm);
  border-left: 4px solid;
}

.layer-card.primary { border-left-color: #22C55E; }
.layer-card.secondary { border-left-color: #F59E0B; }
.layer-card.fallback { border-left-color: #6366F1; }

.layer-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.layer-status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--text-muted);
}

.layer-status-dot.active {
  background: #22C55E;
  box-shadow: 0 0 8px #22C55E;
  animation: pulse 1.5s infinite;
}

.layer-status-dot.standby {
  background: #F59E0B;
}

.layer-status-dot.backup {
  background: #6366F1;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.layer-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
}

.layer-info {
  margin-bottom: 12px;
}

.layer-desc {
  font-size: 13px;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 4px;
}

.layer-latency {
  font-size: 12px;
  color: var(--text-muted);
}

.layer-traffic {
  height: 6px;
  background: var(--surface-2);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-bottom: 6px;
}

.traffic-bar {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 0.5s ease;
}

.layer-card.primary .traffic-bar { background: #22C55E; }
.layer-card.secondary .traffic-bar { background: #F59E0B; }
.layer-card.fallback .traffic-bar { background: #6366F1; }

.layer-traffic-hint {
  font-size: 12px;
  color: var(--text-muted);
}

.routing-section {
  padding: 0 16px;
  margin-bottom: 24px;
}

.routing-demo {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 20px;
  box-shadow: var(--shadow-md);
  margin-bottom: 16px;
}

.request-card {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
  border-radius: var(--radius-md);
  padding: 16px;
  margin-bottom: 20px;
}

.request-label {
  font-size: 12px;
  color: #6366F1;
  display: block;
  margin-bottom: 4px;
}

.request-text {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
}

.request-arrow {
  text-align: right;
  font-size: 24px;
  color: #6366F1;
  margin-top: 8px;
}

.routing-flow {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20px;
}

.flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.step-circle {
  width: 36px;
  height: 36px;
  background: var(--surface-2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-circle.active {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
}

.step-num {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-muted);
}

.step-circle.active .step-num {
  color: #fff;
}

.step-label {
  font-size: 12px;
  color: var(--text-muted);
}

.step-status {
  font-size: 10px;
  color: #22C55E;
}

.result-card {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.1) 0%, rgba(16, 185, 129, 0.1) 100%);
  border-radius: var(--radius-md);
  padding: 16px;
  border: 1px solid rgba(34, 197, 94, 0.2);
}

.result-label {
  font-size: 12px;
  color: #22C55E;
  display: block;
  margin-bottom: 8px;
}

.result-service, .result-latency, .result-dimension {
  font-size: 14px;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4px;
}

.action-btn {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  border-radius: var(--radius-lg);
  padding: 16px;
  text-align: center;
}

.action-btn:active {
  opacity: 0.9;
}

.btn-text {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
}

.metrics-section {
  padding: 0 16px;
  margin-bottom: 24px;
}

.metrics-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.metric-item {
  width: calc(50% - 6px);
  background: #fff;
  border-radius: var(--radius-md);
  padding: 16px;
  box-shadow: var(--shadow-sm);
  text-align: center;
}

.metric-num {
  font-size: 24px;
  font-weight: 700;
  color: #6366F1;
  display: block;
}

.metric-name {
  font-size: 12px;
  color: var(--text-muted);
  display: block;
  margin-top: 4px;
}

.bottom-placeholder {
  height: 80px;
}