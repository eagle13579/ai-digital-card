.section-header {
  padding: 40rpx 16px 16px;
  display: flex;
  flex-direction: column;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  background: var(--surface-2);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.back-btn .icon {
  width: 36rpx;
  height: 36rpx;
  color: var(--text-primary);
}

.section-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.section-title-sm {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 32rpx;
}

.section-subtitle {
  font-size: 28rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 8rpx;
}

.brain-status {
  padding: 0 16px;
  margin-bottom: 48rpx;
}

.status-card {
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

.status-glow {
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  animation: pulseGlow 2s ease-in-out infinite;
}

@keyframes pulseGlow {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.2); }
}

.status-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.status-indicator {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
}

.status-indicator.active {
  background: #22C55E;
  box-shadow: 0 0 10px #22C55E;
  animation: statusPulse 1.5s ease-in-out infinite;
}

@keyframes statusPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.evolution-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding: 0 16px;
  margin-bottom: 48rpx;
}

.metric-card {
  flex: 1;
  min-width: calc(50% - 6px);
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.metric-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.metric-icon-wrap .icon {
  width: 40rpx;
  height: 40rpx;
  color: #fff;
}

.metric-pulse {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 20rpx;
  height: 20rpx;
  background: #22C55E;
  border-radius: 50%;
  animation: metricPulse 2s infinite;
}

@keyframes metricPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.2); }
}

.metric-trend {
  font-size: 28rpx;
  font-weight: 600;
  position: absolute;
  top: 16rpx;
  right: 16rpx;
}

.metric-trend.up { color: #22C55E; }
.metric-trend.stable { color: #F59E0B; font-size: 16rpx; }

.data-flow-section {
  padding: 0 16px;
  margin-bottom: 48rpx;
}

.flow-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.flow-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.flow-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.flow-status.active {
  color: #22C55E;
}

.flow-status text {
  font-size: 24rpx;
}

.flow-dot {
  width: 16rpx;
  height: 16rpx;
  background: #22C55E;
  border-radius: 50%;
  animation: flowDotPulse 1.5s infinite;
}

@keyframes flowDotPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.flow-container {
  background: linear-gradient(135deg, rgba(14, 165, 233, 0.05) 0%, rgba(56, 189, 248, 0.05) 100%);
  border: 1px solid rgba(14, 165, 233, 0.1);
  border-radius: var(--radius-md);
  height: 120rpx;
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.flow-particle {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  border-radius: 50%;
  opacity: 0;
}

.flow-particle.fp1 {
  top: 20%;
  animation: flowMove1 3s linear infinite;
}

.flow-particle.fp2 {
  top: 40%;
  animation: flowMove2 4s linear infinite;
  animation-delay: 0.5s;
}

.flow-particle.fp3 {
  top: 60%;
  animation: flowMove1 3.5s linear infinite;
  animation-delay: 1s;
}

.flow-particle.fp4 {
  top: 80%;
  animation: flowMove2 4.5s linear infinite;
  animation-delay: 1.5s;
}

.flow-particle.fp5 {
  top: 30%;
  animation: flowMove1 5s linear infinite;
  animation-delay: 2s;
}

@keyframes flowMove1 {
  0% { left: -20rpx; opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { left: 100%; opacity: 0; }
}

@keyframes flowMove2 {
  0% { right: -20rpx; opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { right: 100%; opacity: 0; }
}

.flow-stats {
  display: flex;
  gap: 24rpx;
}

.flow-stat {
  flex: 1;
  background: #fff;
  border-radius: var(--radius-sm);
  padding: 24rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.flow-stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #0EA5E9;
  display: block;
}

.flow-stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 8rpx;
}

.metric-info {
  display: flex;
  flex-direction: column;
}

.metric-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #0EA5E9;
}

.metric-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.agent-section {
  padding: 0 16px;
  margin-bottom: 48rpx;
}

.agent-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.agent-card {
  width: calc(50% - 6px);
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.agent-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.agent-emoji {
  font-size: 48rpx;
}

.agent-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.agent-role {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
}

.agent-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #22C55E;
}

.status-text-sm {
  font-size: 22rpx;
  color: #22C55E;
}

.knowledge-section {
  padding: 0 16px;
  margin-bottom: 48rpx;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.view-all {
  font-size: 28rpx;
  color: #0EA5E9;
}

.knowledge-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.knowledge-item {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.knowledge-type-tag {
  font-size: 22rpx;
  padding: 6rpx 8px;
  border-radius: var(--radius-full);
  display: inline-block;
  margin-bottom: 16rpx;
}

.knowledge-content {
  margin-bottom: 16rpx;
}

.knowledge-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.knowledge-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

.knowledge-meta {
  display: flex;
  justify-content: space-between;
}

.knowledge-source {
  font-size: 24rpx;
  color: var(--text-muted);
}

.knowledge-confidence {
  font-size: 24rpx;
  font-weight: 600;
  color: #22C55E;
}

.evolution-button {
  margin: 0 16px;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 100%);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.evolution-button:active {
  opacity: 0.9;
}

.button-glow {
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  animation: shimmer 2s infinite;
}

@keyframes shimmer {
  100% { left: 100%; }
}

.button-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  position: relative;
  z-index: 1;
}

.bottom-placeholder {
  height: 160rpx;
}