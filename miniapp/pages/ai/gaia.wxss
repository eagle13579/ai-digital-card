/* 盖娅大脑页 - v2.0 Dark Minimal */

.gaia-page {
  min-height: 100vh;
  background: var(--surface-primary);
  padding-bottom: var(--space-8);
}

/* ===== Header ===== */
.gaia-header {
  padding: var(--space-5) var(--space-4) var(--space-4);
  display: flex;
  flex-direction: column;
}

.back-btn {
  width: 36px;
  height: 36px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-4);
}

.back-icon {
  font-size: 18px;
  color: var(--text-primary);
}

.gaia-title {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  display: block;
}

.gaia-subtitle {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  display: block;
  margin-top: var(--space-1);
}

/* ===== Brain Status ===== */
.brain-status-card {
  margin: 0 var(--space-4) var(--space-6);
  background: linear-gradient(135deg, #7c5cfc 0%, #5b8def 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-5);
  position: relative;
  overflow: hidden;
}

.status-glow {
  position: absolute;
  top: -50%;
  right: -20%;
  width: 100px;
  height: 100px;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  animation: pulseGlow 2s ease-in-out infinite;
}

@keyframes pulseGlow {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.2); }
}

.status-content {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  position: relative;
  z-index: 1;
}

.status-indicator {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
}

.status-indicator.active {
  background: #22C55E;
  box-shadow: 0 0 10px #22C55E;
  animation: statusPulse 1.5s ease-in-out infinite;
}

@keyframes statusPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.status-text {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: #fff;
}

.status-info {
  font-size: var(--text-xs);
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-top: var(--space-2);
  position: relative;
  z-index: 1;
}

/* ===== Metrics ===== */
.metrics-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  padding: 0 var(--space-4);
  margin-bottom: var(--space-6);
}

.metric-card {
  flex: 1;
  min-width: calc(50% - 6px);
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.metric-icon-wrap {
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(6,182,212,0.1));
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.metric-icon {
  font-size: 20px;
}

.metric-pulse {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 10px;
  height: 10px;
  background: var(--success);
  border-radius: 50%;
  animation: metricPulse 2s infinite;
}

@keyframes metricPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.2); }
}

.metric-trend {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  position: absolute;
  top: 8px;
  right: 8px;
}

.metric-trend.up { color: var(--success); }

.metric-info {
  display: flex;
  flex-direction: column;
}

.metric-value {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  color: var(--accent);
}

.metric-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 2px;
}

/* ===== Data Flow ===== */
.data-flow-section {
  padding: 0 var(--space-4);
  margin-bottom: var(--space-6);
}

.flow-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-3);
}

.flow-title {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
}

.flow-status {
  display: flex;
  align-items: center;
  gap: 6px;
}

.flow-status.active {
  color: var(--success);
}

.flow-status text {
  font-size: var(--text-xs);
}

.flow-dot {
  width: 8px;
  height: 8px;
  background: var(--success);
  border-radius: 50%;
  animation: flowDotPulse 1.5s infinite;
}

@keyframes flowDotPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.flow-container {
  background: linear-gradient(135deg, rgba(139,92,246,0.05), rgba(6,182,212,0.03));
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  height: 60px;
  position: relative;
  overflow: hidden;
  margin-bottom: var(--space-3);
}

.flow-particle {
  position: absolute;
  width: 8px;
  height: 8px;
  background: linear-gradient(135deg, var(--accent), var(--info));
  border-radius: 50%;
  opacity: 0;
}

.flow-particle.fp1 { top: 20%; animation: flowMove1 3s linear infinite; }
.flow-particle.fp2 { top: 40%; animation: flowMove2 4s linear infinite; animation-delay: 0.5s; }
.flow-particle.fp3 { top: 60%; animation: flowMove1 3.5s linear infinite; animation-delay: 1s; }
.flow-particle.fp4 { top: 80%; animation: flowMove2 4.5s linear infinite; animation-delay: 1.5s; }
.flow-particle.fp5 { top: 30%; animation: flowMove1 5s linear infinite; animation-delay: 2s; }

@keyframes flowMove1 {
  0% { left: -10px; opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { left: 100%; opacity: 0; }
}

@keyframes flowMove2 {
  0% { right: -10px; opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { right: 100%; opacity: 0; }
}

.flow-stats {
  display: flex;
  gap: var(--space-3);
}

.flow-stat {
  flex: 1;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-sm);
  padding: var(--space-3);
  text-align: center;
}

.flow-stat-num {
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
  color: var(--accent);
  display: block;
}

.flow-stat-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  display: block;
  margin-top: 4px;
}

/* ===== Agent Section ===== */
.agent-section {
  padding: 0 var(--space-4);
  margin-bottom: var(--space-6);
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-4);
}

.section-title-sm {
  font-size: var(--text-lg);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  display: block;
}

.view-all {
  font-size: var(--text-sm);
  color: var(--accent);
}

.agent-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
}

.agent-card {
  width: calc(50% - 6px);
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.agent-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-2);
}

.agent-emoji {
  font-size: 24px;
}

.agent-name {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  margin-bottom: 4px;
}

.agent-role {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-bottom: var(--space-2);
}

.agent-status {
  display: flex;
  align-items: center;
  gap: 4px;
}

.status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

.status-text-sm {
  font-size: var(--text-xs);
  color: var(--text-secondary);
}

/* ===== Knowledge ===== */
.knowledge-section {
  padding: 0 var(--space-4);
  margin-bottom: var(--space-6);
}

.knowledge-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.knowledge-item {
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  padding: var(--space-4);
}

.knowledge-type-tag {
  font-size: var(--text-xs);
  padding: 3px 8px;
  border-radius: var(--radius-full);
  display: inline-block;
  margin-bottom: var(--space-2);
}

.knowledge-content {
  margin-bottom: var(--space-2);
}

.knowledge-title {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  display: block;
  margin-bottom: 4px;
}

.knowledge-desc {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  line-height: 1.4;
}

.knowledge-meta {
  display: flex;
  justify-content: space-between;
}

.knowledge-source {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
}

.knowledge-confidence {
  font-size: var(--text-xs);
  font-weight: var(--weight-semibold);
  color: var(--success);
}

/* ===== Evolution Button ===== */
.evolution-button {
  margin: 0 var(--space-4);
  background: var(--gradient-accent);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.evolution-button:active {
  opacity: 0.9;
}

.button-glow {
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  animation: shimmer 2s infinite;
}

@keyframes shimmer {
  100% { left: 100%; }
}

.button-text {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: #fff;
  position: relative;
  z-index: 1;
}

/* ===== Loading ===== */
.loading-overlay {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-brain {
  text-align: center;
}

.brain-pulse {
  width: 48px;
  height: 48px;
  border: 3px solid rgba(139, 92, 246, 0.2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto var(--space-4);
}

.loading-brain-text {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
}

/* ===== Error ===== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80px 16px;
  gap: var(--space-4);
}

.error-icon {
  font-size: 36px;
}

.error-text {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  text-align: center;
}
