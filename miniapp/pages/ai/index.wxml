<scroll-view class="page-container" scroll-y>
  <!-- 顶部横幅 -->
  <view class="hero-section">
    <view class="hero-bg"></view>
    <view class="hero-glow"></view>
    <view class="hero-content">
      <view class="hero-icon">
        <text class="icon-emoji">🤖</text>
      </view>
      <text class="hero-title">AI能力中心</text>
      <text class="hero-desc">智能驱动 · 高效创作</text>
    </view>
  </view>

  <!-- 核心功能 -->
  <view class="feature-section">
    <view class="section-header">
      <text class="section-title">核心功能</text>
      <text class="section-subtitle">日常AI工具，提升效率</text>
    </view>
    <view class="feature-list">
      <view
        class="feature-card"
        wx:for="{{coreFeatures}}"
        wx:key="id"
        data-path="{{item.path}}"
        bindtap="navigateTo"
      >
        <view class="card-bg" style="background: {{item.color}}"></view>
        <view class="card-content">
          <text class="card-icon">{{item.icon}}</text>
          <view class="card-text">
            <text class="card-title">{{item.title}}</text>
            <text class="card-desc">{{item.desc}}</text>
          </view>
          <text class="card-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 进阶能力 -->
  <view class="feature-section">
    <view class="section-header">
      <text class="section-title">进阶能力</text>
      <text class="section-subtitle">深度AI分析，赋能商业决策</text>
    </view>
    <view class="feature-list">
      <view
        class="feature-card"
        wx:for="{{advancedFeatures}}"
        wx:key="id"
        data-path="{{item.path}}"
        bindtap="navigateTo"
      >
        <view class="card-bg" style="background: {{item.color}}"></view>
        <view class="card-content">
          <text class="card-icon">{{item.icon}}</text>
          <view class="card-text">
            <text class="card-title">{{item.title}}</text>
            <text class="card-desc">{{item.desc}}</text>
          </view>
          <text class="card-arrow">›</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
