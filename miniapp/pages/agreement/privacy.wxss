/**
 * 隐私政策 — AI原生暗色适配
 * 基于 tokens.wxss 设计Token系统
 * (注：此文件为冗余副本，实际页面引用 pages/agreement/privacy/privacy.wxss)
 */
.agreement-container {
  min-height: 100vh;
  background: var(--bg-page);
}

.agreement-header {
  background: var(--gradient-cyan-purple);
  padding: var(--space-10) var(--space-8);
  text-align: center;
}

.agreement-title {
  font-size: var(--text-2xl);
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: var(--space-3);
}

.agreement-subtitle {
  font-size: var(--text-xs);
  color: rgba(255, 255, 255, 0.75);
  display: block;
}

.agreement-content {
  height: calc(100vh - 240rpx);
  padding: var(--space-8);
}

.article {
  margin-bottom: var(--space-10);
}

.article-title {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-4);
}

.article-text {
  font-size: var(--text-base);
  color: var(--text-secondary);
  line-height: 1.8;
  display: block;
  margin-bottom: var(--space-4);
}

.article-text:last-child {
  margin-bottom: 0;
}
