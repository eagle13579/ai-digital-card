/* ===== 平台详情页 - 深色磨砂玻璃风格 ===== */

.page-container {
  min-height: 100vh;
  background: var(--surface-primary);
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: var(--surface-primary);
  border-bottom: 1px solid var(--border-subtle);
}

.back {
  font-size: 28px;
  color: var(--text-primary);
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.invite-btn {
  font-size: 14px;
  color: #fff;
  background: var(--gradient-accent);
  padding: 6px 12px;
  border-radius: 16px;
}

.more-btn {
  font-size: 24px;
  color: var(--text-primary);
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
  gap: 12px;
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid rgba(139, 92, 246, 0.2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 14px;
  color: var(--text-tertiary);
}

.platform-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 16px;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  margin: 12px 16px;
}

.platform-info {
  flex: 1;
}

.platform-name {
  font-size: 20px;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.platform-desc {
  font-size: 13px;
  color: var(--text-tertiary);
  display: block;
  margin-top: 6px;
}

.secretary-link {
  color: var(--accent);
}

.platform-logo {
  width: 60px;
  height: 60px;
  border-radius: 12px;
  background: var(--gradient-accent);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  font-size: 26px;
  font-weight: 700;
  color: #fff;
}

.stats-bar {
  display: flex;
  align-items: center;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  padding: 16px;
  margin: 0 16px 12px;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.stat-num {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
}

.stat-label {
  font-size: 12px;
  color: var(--text-tertiary);
}

.stat-divider {
  width: 1px;
  height: 32px;
  background: var(--border-subtle);
}

.tab-bar {
  display: flex;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  margin: 0 16px 12px;
  padding: 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16px 0;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40px;
  height: 3px;
  background: var(--accent);
  border-radius: 2px;
}

.tab-text {
  font-size: 15px;
  color: var(--text-tertiary);
}

.tab-item.active .tab-text {
  color: var(--text-primary);
  font-weight: 600;
}

.tab-content {
  padding: 0 16px;
}

.creator-card {
  display: flex;
  align-items: center;
  padding: 16px;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  margin-bottom: 12px;
}

.creator-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--gradient-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
}

.avatar-text {
  font-size: 18px;
  font-weight: 600;
  color: #fff;
}

.creator-info {
  flex: 1;
}

.creator-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.creator-company {
  font-size: 13px;
  color: var(--text-tertiary);
  display: block;
  margin-top: 4px;
}

.creator-badge {
  font-size: 11px;
  color: #fff;
  background: var(--accent);
  padding: 4px 10px;
  border-radius: 10px;
}

.info-section {
  padding: 16px;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  margin-bottom: 12px;
}

.section-label {
  font-size: 13px;
  color: var(--text-tertiary);
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12px;
}

.section-content {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.6;
}

.unit-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.unit-item {
  font-size: 13px;
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.05);
  padding: 6px 12px;
  border-radius: 6px;
}

.opportunity-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.opportunity-item {
  padding: 14px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--border-subtle);
  border-radius: 10px;
}

.opp-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.opp-desc {
  font-size: 13px;
  color: var(--text-secondary);
  display: block;
  margin-top: 6px;
  line-height: 1.5;
}

.opp-meta {
  display: flex;
  gap: 12px;
  margin-top: 10px;
}

.opp-tag {
  font-size: 12px;
  color: var(--accent-light);
  background: rgba(139, 92, 246, 0.12);
  padding: 2px 8px;
  border-radius: 4px;
}

.opp-location {
  font-size: 12px;
  color: var(--text-tertiary);
}

.resource-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.resource-item {
  display: flex;
  align-items: center;
  padding: 14px;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
}

.resource-avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(6, 182, 212, 0.2));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
}

.resource-info {
  flex: 1;
}

.resource-name {
  font-size: 15px;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
}

.resource-meta {
  font-size: 13px;
  color: var(--text-tertiary);
  display: block;
  margin-top: 4px;
}

.resource-action {
  padding: 8px 16px;
  background: rgba(139, 92, 246, 0.12);
  border-radius: 6px;
}

.action-text {
  font-size: 13px;
  color: var(--accent-light);
}

.opportunity-card {
  padding: 16px;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  margin-bottom: 12px;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.card-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
}

.card-tag {
  font-size: 12px;
  color: var(--accent-light);
  background: rgba(139, 92, 246, 0.12);
  padding: 2px 8px;
  border-radius: 4px;
}

.card-desc {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.6;
  display: block;
}

.card-footer {
  display: flex;
  gap: 16px;
  margin-top: 12px;
}

.card-info {
  font-size: 13px;
  color: var(--text-tertiary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 0;
}

.empty-text {
  font-size: 14px;
  color: var(--text-tertiary);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  padding-bottom: calc(env(safe-area-inset-bottom) + 12px);
  background: var(--surface-glass-strong);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1px solid var(--border-subtle);
}

.join-btn {
  height: 48px;
  background: var(--gradient-accent);
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  border: none;
  border-radius: 10px;
  width: 100%;
}

.join-btn[disabled] {
  opacity: 0.4;
}

.join-text {
  font-size: 16px;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-content {
  width: 100%;
  background: var(--surface-glass-strong);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 16px 16px 0 0;
  overflow: hidden;
  border-top: 1px solid var(--border-subtle);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid var(--border-subtle);
}

.modal-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: 20px;
  color: var(--text-tertiary);
  padding: 4px;
}

.modal-body {
  padding: 16px;
}

.contact-tip {
  font-size: 13px;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 16px;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 14px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--border-subtle);
  border-radius: 10px;
}

.contact-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--gradient-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
}

.contact-info {
  flex: 1;
}

.contact-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
}

.call-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(139, 92, 246, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.call-icon {
  font-size: 20px;
}

.invite-methods {
  display: flex;
  flex-direction: column;
}

.invite-method {
  display: flex;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid var(--border-subtle);
}

.invite-method:last-child {
  border-bottom: none;
}

.method-icon {
  font-size: 24px;
  margin-right: 12px;
}

.method-info {
  flex: 1;
}

.method-title {
  font-size: 15px;
  color: var(--text-primary);
  display: block;
}

.method-desc {
  font-size: 13px;
  color: var(--text-tertiary);
  display: block;
  margin-top: 4px;
}

.method-arrow {
  font-size: 18px;
  color: var(--text-tertiary);
}
