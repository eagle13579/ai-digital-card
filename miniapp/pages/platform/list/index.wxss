/* ===== 平台推荐列表页 - 暗色系 ===== */

/* 页面滚动容器 */
.list-scroll {
  height: 100vh;
  padding: 0 16px;
}

.list-container {
  padding-top: 8px;
}

/* ===== 加载状态 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80px 0;
  gap: 12px;
}

.loading-text {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.5);
}

/* ===== 空状态 ===== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120px 0;
}

.empty-icon {
  font-size: 56px;
  display: block;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-text {
  font-size: 15px;
  color: rgba(255, 255, 255, 0.35);
}

/* ===== 平台列表项 - 磨砂玻璃风格卡片 ===== */
.platform-list-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  margin-bottom: 10px;
  background: rgba(30, 30, 50, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 14px;
  transition: all 0.2s;
}

.item-hover {
  background: rgba(255, 255, 255, 0.06);
}

/* ===== 排名徽标 ===== */
.rank-badge {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 12px;
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.05);
}

.rank-first {
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.2), rgba(245, 158, 11, 0.1));
  border: 1px solid rgba(251, 191, 36, 0.25);
}

.rank-text {
  font-size: 18px;
}

.rank-num {
  font-size: 15px;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.5);
}

/* ===== Logo占位（圆形/首字母） ===== */
.platform-logo {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 12px;
  background: linear-gradient(135deg, #8b5cf6, #06b6d4);
}

.logo-letter {
  font-size: 20px;
  font-weight: 700;
  color: #ffffff;
}

/* ===== 平台信息 ===== */
.platform-info {
  flex: 1;
  min-width: 0;
}

.platform-name-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.platform-name {
  font-size: 15px;
  font-weight: 600;
  color: #ffffff;
  display: block;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 官方认证标签 — 仅第1名 */
.cert-badge {
  font-size: 10px;
  padding: 1px 7px;
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
  color: #1a1a1a;
  border-radius: 10px;
  font-weight: 600;
  flex-shrink: 0;
}

.platform-meta {
  display: flex;
  align-items: center;
  margin-top: 3px;
}

.meta-item {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.45);
}

.meta-divider {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.2);
  margin: 0 6px;
}

/* ===== 年费标签 ===== */
.fee-tag {
  flex-shrink: 0;
  margin-left: 10px;
  padding: 4px 10px;
  background: rgba(139, 92, 246, 0.12);
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: 8px;
}

.fee-value {
  font-size: 12px;
  color: #a78bfa;
  font-weight: 600;
}
