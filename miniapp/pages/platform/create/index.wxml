<view class="page-wrap">
  <!-- 顶部 -->
  <view class="status-bar">
    <text class="back-icon" bindtap="goBack">‹</text>
    <text class="status-time">创建资源平台</text>
    <text class="status-placeholder"></text>
  </view>

  <!-- 标题 -->
  <view class="page-title">创建资源平台</view>

  <!-- 图标 -->
  <view class="icon-box">
    <view class="cube-icon"></view>
    <view class="add-circle">+</view>
  </view>

  <!-- 表单 -->
  <view class="form-item">
    <text class="label-text">名称</text>
    <input class="input-box" placeholder="请输入平台名称" value="{{name}}" bindinput="onNameInput" />
  </view>

  <view class="form-item">
    <text class="label-text">年费标准</text>
    <input class="input-box" placeholder="请输入" value="{{fee}}" bindinput="onFeeInput" />
    <text class="tip-text">加入平台使用平台资源需要为您支付的年费。</text>
  </view>

  <!-- 底部 -->
  <view class="bottom-area">
    <button class="create-btn {{submitting ? 'create-btn--disabled' : ''}}" bindtap="submit" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '创建平台'}}
    </button>
    <view class="agree-wrap">
      <radio class="agree-checkbox" checked="{{agreed}}" bindtap="toggleAgree" />
      <text class="agree-text">
        我已阅读并同意<text class="agree-link">《询赋资源平台服务协议》</text>
      </text>
    </view>
  </view>
</view>
