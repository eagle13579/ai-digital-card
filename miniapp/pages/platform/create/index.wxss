.form-scroll {
  height: calc(100vh - 60px - 80px);
}

.form-section {
  padding: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16px;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.tag-item {
  padding: 8px 16px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20px;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.tag-item.selected {
  background: rgba(139, 92, 246, 0.2);
  color: #a78bfa;
  border-color: rgba(139, 92, 246, 0.4);
}

.location-row {
  display: flex;
  gap: 8px;
}

.location-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 12px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 8px;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.picker-value {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
}

.picker-arrow {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.4);
}

.char-count {
  display: block;
  text-align: right;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 4px;
}

.fee-input-wrap {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 8px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  padding: 0 12px;
}

.fee-prefix, .fee-suffix {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.5);
}

.fee-input {
  flex: 1;
  height: 44px;
  padding: 0;
  background: transparent;
  border: none;
}

.form-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  padding-bottom: calc(env(safe-area-inset-bottom) + 12px);
  background: rgba(15, 15, 26, 0.95);
  backdrop-filter: blur(20px);
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.picker-content {
  width: 100%;
  max-height: 70vh;
  background: rgba(30, 30, 50, 0.95);
  border-radius: 16px 16px 0 0;
  overflow: hidden;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.picker-title {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
}

.picker-close {
  font-size: 20px;
  color: rgba(255, 255, 255, 0.5);
  padding: 4px;
}

.picker-list {
  max-height: 50vh;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  font-size: 15px;
  color: rgba(255, 255, 255, 0.8);
}

.picker-item.selected {
  color: #8b5cf6;
}

.picker-check {
  font-size: 16px;
  color: #8b5cf6;
}