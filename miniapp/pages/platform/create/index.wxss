/* =========================================================
   创建资源平台 — 平台创建表单页面样式
   品牌色体系（参考 design_patterns.json）:
     primary:    #7c3aed (purple-600)
     primary-light:  #a78bfa
     primary-dark:   #5b21b6
     accent-orange:  #f59e0b
     accent-green:   #10b981
     bg-gray:        #f5f5f5
   设计规范: 移动端优先，圆角柔和，紫调品牌
   ========================================================= */

.page-wrap {
  min-height: 100vh;
  background: #f8f7fc;
  padding: 0 20px 40px;
}

/* =========================================================
   顶部导航栏
   ========================================================= */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 18px;
  font-weight: 500;
  padding: 12px 0 8px;
  position: sticky;
  top: 0;
  z-index: 10;
  background: #f8f7fc;
}
.back-icon {
  font-size: 28px;
  padding: 4px 8px;
  color: #333;
  font-weight: 300;
  width: 36px;
}
.status-time {
  font-size: 17px;
  color: #222;
  font-weight: 600;
}
.status-placeholder {
  width: 36px;
}

/* =========================================================
   页面主标题
   ========================================================= */
.page-title {
  font-size: 24px;
  font-weight: 700;
  color: #1a1a2e;
  margin-top: 8px;
  margin-bottom: 4px;
  text-align: center;
}
.page-subtitle {
  font-size: 13px;
  color: #888;
  text-align: center;
  margin-bottom: 28px;
}

/* =========================================================
   Logo 图标区域（示意占位，匹配设计模式）
   ========================================================= */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32px;
}
.logo-box {
  width: 80px;
  height: 80px;
  background: #ede9fe;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.logo-icon {
  font-size: 36px;
}
.logo-add {
  position: absolute;
  bottom: -2px;
  right: -2px;
  width: 26px;
  height: 26px;
  background: #7c3aed;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  border: 2px solid #f8f7fc;
}
.logo-tip {
  font-size: 12px;
  color: #a78bfa;
  margin-top: 6px;
}

/* =========================================================
   表单区域
   ========================================================= */
.form-section {
  background: #ffffff;
  border-radius: 16px;
  padding: 20px 16px;
  box-shadow: 0 1px 3px rgba(124, 58, 237, 0.06);
  margin-bottom: 12px;
}
.form-item {
  margin-bottom: 24px;
}
.form-item:last-child {
  margin-bottom: 0;
}

.label-text {
  display: block;
  font-size: 15px;
  font-weight: 500;
  color: #333;
  margin-bottom: 10px;
}
.required {
  color: #ef4444;
}

/* 输入框 */
.input-box {
  width: 100%;
  height: 48px;
  background: #f5f3ff;
  border-radius: 12px;
  border: 1.5px solid transparent;
  padding: 0 16px;
  font-size: 15px;
  color: #333;
  box-sizing: border-box;
  transition: border-color 0.2s, background 0.2s;
}
.input-box:focus {
  background: #fff;
  border-color: #7c3aed;
}
.input-box::placeholder {
  color: #b0aec0;
}

/* 多行文本域 */
.textarea-box {
  width: 100%;
  min-height: 100px;
  background: #f5f3ff;
  border-radius: 12px;
  border: 1.5px solid transparent;
  padding: 14px 16px;
  font-size: 15px;
  color: #333;
  box-sizing: border-box;
  line-height: 1.6;
}
.textarea-box:focus {
  background: #fff;
  border-color: #7c3aed;
}
.textarea-box::placeholder {
  color: #b0aec0;
}
.char-count {
  display: block;
  text-align: right;
  font-size: 12px;
  color: #aaa;
  margin-top: 4px;
}

/* 年费输入 */
.fee-input-wrap {
  display: flex;
  align-items: center;
  gap: 0;
}
.fee-input {
  flex: 1;
  border-radius: 12px 0 0 12px;
}
.fee-unit {
  background: #ede9fe;
  height: 48px;
  line-height: 48px;
  padding: 0 16px;
  border-radius: 0 12px 12px 0;
  font-size: 14px;
  color: #7c3aed;
  font-weight: 500;
  white-space: nowrap;
}
.tip-text {
  display: block;
  font-size: 12px;
  color: #999;
  margin-top: 6px;
  line-height: 1.5;
}

/* =========================================================
   行业标签展示区域
   ========================================================= */
.tag-display-area {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  min-height: 48px;
  background: #f5f3ff;
  border-radius: 12px;
  padding: 8px 12px;
  border: 1.5px solid transparent;
}
.tag-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  flex: 1;
}
.tag-pill {
  display: flex;
  align-items: center;
  background: #ede9fe;
  border-radius: 20px;
  padding: 4px 12px;
  gap: 6px;
}
.tag-pill-text {
  font-size: 13px;
  color: #7c3aed;
}
.tag-pill-remove {
  font-size: 16px;
  color: #a78bfa;
  line-height: 1;
  padding: 0 2px;
}
.tag-placeholder {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}
.tag-placeholder-text {
  font-size: 15px;
  color: #b0aec0;
}
.tag-arrow {
  font-size: 18px;
  color: #ccc;
  font-weight: 300;
}
.tag-edit-btn {
  font-size: 13px;
  color: #7c3aed;
  white-space: nowrap;
  padding-left: 8px;
  line-height: 32px;
}

/* =========================================================
   地区选择器触发区
   ========================================================= */
.region-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 48px;
  background: #f5f3ff;
  border-radius: 12px;
  padding: 0 16px;
  border: 1.5px solid transparent;
}
.region-text {
  font-size: 15px;
  color: #333;
}
.region-placeholder {
  color: #b0aec0;
}

/* =========================================================
   错误提示
   ========================================================= */
.error-area {
  background: #fef2f2;
  border-radius: 10px;
  padding: 10px 14px;
  margin-bottom: 12px;
}
.error-text {
  font-size: 13px;
  color: #dc2626;
  line-height: 1.5;
}

/* =========================================================
   底部操作区
   ========================================================= */
.bottom-area {
  margin-top: 24px;
}
.create-btn {
  width: 100%;
  height: 52px;
  line-height: 52px;
  background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
  border-radius: 26px;
  border: none;
  color: #fff;
  font-size: 17px;
  font-weight: 600;
  text-align: center;
  margin-bottom: 16px;
  box-shadow: 0 4px 14px rgba(124, 58, 237, 0.3);
  transition: opacity 0.2s, transform 0.1s;
}
.create-btn:active {
  transform: scale(0.98);
}
.create-btn--disabled {
  opacity: 0.5;
  box-shadow: none;
}
.agree-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}
.agree-checkbox {
  transform: scale(0.75);
}
.agree-text {
  font-size: 13px;
  color: #666;
}
.agree-link {
  color: #7c3aed;
  font-weight: 500;
}

/* =========================================================
   弹窗遮罩 + 抽屉面板
   ========================================================= */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
}

.picker-drawer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 20px 20px 0 0;
  z-index: 101;
  max-height: 55vh;
  display: flex;
  flex-direction: column;
}
.picker-drawer--tall {
  max-height: 65vh;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid #f0f0f0;
  flex-shrink: 0;
}
.picker-cancel {
  font-size: 15px;
  color: #999;
}
.picker-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}
.picker-confirm {
  font-size: 15px;
  color: #7c3aed;
  font-weight: 600;
}

.picker-body {
  padding: 16px 20px 24px;
  overflow-y: auto;
  flex: 1;
}

/* =========================================================
   行业标签网格
   ========================================================= */
.tag-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
.tag-grid-item {
  background: #f5f3ff;
  border-radius: 10px;
  padding: 12px 8px;
  text-align: center;
  font-size: 14px;
  color: #555;
  border: 1.5px solid transparent;
  transition: all 0.15s;
}
.tag-grid-item:active {
  transform: scale(0.96);
}
.tag-grid-item--active {
  background: #ede9fe;
  border-color: #7c3aed;
  color: #7c3aed;
  font-weight: 500;
}

/* =========================================================
   地区选择器（picker-view）
   ========================================================= */
.region-picker-view {
  width: 100%;
  height: 220px;
}
.picker-col-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40px;
  font-size: 15px;
  color: #333;
}
