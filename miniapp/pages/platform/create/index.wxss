/**
 * 创建资源平台 — AI原生暗色适配
 * 基于 tokens.wxss 设计Token系统
 * 基底: #0A0A18 | 玻璃三层 | Orb光晕 | 三重渐变 | spring弹簧动效
 */

.page-wrap {
  min-height: 100vh;
  background: var(--bg-page);
  padding: 0 40rpx 40rpx;
  position: relative;
}

/* 背景Orb光晕 */
.page-wrap::before {
  content: '';
  position: fixed;
  width: 500rpx;
  height: 500rpx;
  top: -100rpx;
  right: -150rpx;
  background: radial-gradient(circle, rgba(6, 182, 212, 0.08), transparent 70%);
  pointer-events: none;
  z-index: 0;
}
.page-wrap::after {
  content: '';
  position: fixed;
  width: 400rpx;
  height: 400rpx;
  bottom: 200rpx;
  left: -120rpx;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.08), transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* =========================================================
   顶部导航栏
   ========================================================= */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: var(--text-xl);
  font-weight: 500;
  padding: var(--space-6) 0 var(--space-2);
  position: sticky;
  top: 0;
  z-index: 10;
  background: var(--bg-page);
}
.back-icon {
  font-size: 56rpx;
  padding: 8rpx 16rpx;
  color: var(--text-primary);
  font-weight: 300;
  width: 72rpx;
}
.back-icon:active {
  color: var(--text-accent);
}
.status-time {
  font-size: var(--text-xl);
  color: var(--text-primary);
  font-weight: 600;
  letter-spacing: var(--tracking-tight);
}
.status-placeholder {
  width: 72rpx;
}

/* =========================================================
   页面主标题
   ========================================================= */
.page-title {
  font-size: var(--text-3xl);
  font-weight: 700;
  color: var(--text-primary);
  margin-top: var(--space-4);
  margin-bottom: var(--space-2);
  text-align: center;
  letter-spacing: var(--tracking-tight);
  position: relative;
  z-index: 1;
}
.page-subtitle {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  text-align: center;
  margin-bottom: var(--space-12);
  position: relative;
  z-index: 1;
}

/* =========================================================
   Logo 图标区域（玻璃质感）
   ========================================================= */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: var(--space-16);
  position: relative;
  z-index: 1;
}
.logo-box {
  width: 160rpx;
  height: 160rpx;
  background: var(--bg-glass-3);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: var(--orb-md), var(--shadow-glass-edge);
  border: var(--glass-border-3);
}
.logo-icon {
  font-size: 72rpx;
}
.logo-add {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 52rpx;
  height: 52rpx;
  background: var(--gradient-cyan-purple);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: 2px solid var(--bg-page);
  box-shadow: var(--orb-sm);
}
.logo-tip {
  font-size: var(--text-xs);
  color: var(--text-accent);
  margin-top: var(--space-3);
}

/* =========================================================
   表单区域 — 玻璃卡片
   ========================================================= */
.form-section {
  background: var(--bg-glass-2);
  border-radius: var(--radius-lg);
  padding: var(--space-10) var(--space-6);
  box-shadow: var(--orb-sm), var(--shadow-glass-edge);
  margin-bottom: var(--space-6);
  border: var(--glass-border-2);
  position: relative;
  z-index: 1;
}
.form-item {
  margin-bottom: var(--space-10);
}
.form-item:last-child {
  margin-bottom: 0;
}

.label-text {
  display: block;
  font-size: var(--text-lg);
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--space-5);
  letter-spacing: var(--tracking-tight);
}
.required {
  color: var(--danger);
}

/* 输入框 */
.input-box {
  width: 100%;
  height: var(--input-height);
  background: var(--input-bg);
  border-radius: var(--input-radius);
  border: var(--input-border);
  padding: var(--input-padding);
  font-size: var(--text-base);
  color: var(--input-color);
  box-sizing: border-box;
  transition: border var(--duration-fast) var(--ease-out),
              background var(--duration-fast) var(--ease-out);
}
.input-box:focus {
  background: var(--bg-glass-2);
  border: var(--input-focus-border);
}
.input-box::placeholder {
  color: var(--input-placeholder);
}

/* 多行文本域 */
.textarea-box {
  width: 100%;
  min-height: 200rpx;
  background: var(--input-bg);
  border-radius: var(--input-radius);
  border: var(--input-border);
  padding: var(--space-7) var(--space-6);
  font-size: var(--text-base);
  color: var(--input-color);
  box-sizing: border-box;
  line-height: 1.6;
  transition: border var(--duration-fast) var(--ease-out),
              background var(--duration-fast) var(--ease-out);
}
.textarea-box:focus {
  background: var(--bg-glass-2);
  border: var(--input-focus-border);
}
.textarea-box::placeholder {
  color: var(--input-placeholder);
}
.char-count {
  display: block;
  text-align: right;
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: var(--space-2);
}

/* 年费输入 */
.fee-input-wrap {
  display: flex;
  align-items: center;
  gap: 0;
}
.fee-input {
  flex: 1;
  border-radius: var(--radius-sm) 0 0 var(--radius-sm);
}
.fee-unit {
  background: var(--bg-glass-3);
  height: var(--input-height);
  line-height: var(--input-height);
  padding: 0 var(--space-6);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-size: var(--text-base);
  color: var(--purple-light);
  font-weight: 500;
  white-space: nowrap;
  border: var(--input-border);
  border-left: none;
}
.tip-text {
  display: block;
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: var(--space-3);
  line-height: 1.5;
}

/* =========================================================
   行业标签展示区域
   ========================================================= */
.tag-display-area {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  min-height: var(--input-height);
  background: var(--input-bg);
  border-radius: var(--input-radius);
  padding: var(--space-4) var(--space-6);
  border: var(--input-border);
}
.tag-pills {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  flex: 1;
}
.tag-pill {
  display: flex;
  align-items: center;
  background: var(--bg-glass-3);
  border-radius: var(--radius-full);
  padding: var(--space-2) var(--space-4);
  gap: var(--space-3);
}
.tag-pill-text {
  font-size: var(--text-sm);
  color: var(--purple-light);
}
.tag-pill-remove {
  font-size: var(--text-lg);
  color: var(--text-accent);
  line-height: 1;
  padding: 0 4rpx;
}
.tag-placeholder {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}
.tag-placeholder-text {
  font-size: var(--text-base);
  color: var(--input-placeholder);
}
.tag-arrow {
  font-size: var(--text-xl);
  color: var(--text-quaternary);
  font-weight: 300;
}
.tag-edit-btn {
  font-size: var(--text-sm);
  color: var(--purple-light);
  white-space: nowrap;
  padding-left: var(--space-4);
  line-height: 64rpx;
}

/* =========================================================
   地区选择器触发区
   ========================================================= */
.region-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: var(--input-height);
  background: var(--input-bg);
  border-radius: var(--input-radius);
  padding: 0 var(--space-6);
  border: var(--input-border);
}
.region-text {
  font-size: var(--text-base);
  color: var(--text-primary);
}
.region-placeholder {
  color: var(--input-placeholder);
}

/* =========================================================
   错误提示
   ========================================================= */
.error-area {
  background: rgba(239, 68, 68, 0.10);
  border-radius: var(--radius-sm);
  padding: var(--space-5) var(--space-4);
  margin-bottom: var(--space-6);
  border: 0.5px solid rgba(239, 68, 68, 0.20);
  position: relative;
  z-index: 1;
}
.error-text {
  font-size: var(--text-sm);
  color: var(--danger);
  line-height: 1.5;
}

/* =========================================================
   底部操作区
   ========================================================= */
.bottom-area {
  margin-top: var(--space-10);
  position: relative;
  z-index: 1;
}
.create-btn {
  width: 100%;
  height: var(--btn-primary-height);
  line-height: var(--btn-primary-height);
  background: var(--btn-primary-bg);
  border-radius: var(--btn-primary-radius);
  border: none;
  color: var(--btn-primary-color);
  font-size: var(--btn-primary-font-size);
  font-weight: var(--btn-primary-font-weight);
  text-align: center;
  margin-bottom: var(--space-8);
  box-shadow: var(--btn-primary-orb);
  transition: box-shadow var(--duration-fast) var(--ease-out),
              transform var(--duration-fast) var(--ease-out),
              opacity var(--duration-fast) var(--ease-out);
}
.create-btn:active {
  transform: scale(0.98);
  box-shadow: var(--btn-primary-hover-orb);
}
.create-btn--disabled {
  opacity: 0.4;
  box-shadow: none;
}
.agree-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-3);
}
.agree-checkbox {
  transform: scale(0.75);
}
.agree-text {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
}
.agree-link {
  color: var(--text-accent);
  font-weight: 500;
}

/* =========================================================
   弹窗遮罩 + 抽屉面板 — 暗色适配
   ========================================================= */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 100;
}

.picker-drawer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-elevated);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  z-index: 101;
  max-height: 55vh;
  display: flex;
  flex-direction: column;
  box-shadow: var(--orb-lg);
  border-top: var(--glass-border-2);
}
.picker-drawer--tall {
  max-height: 65vh;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-8) var(--space-8);
  border-bottom: 0.5px solid var(--border-subtle);
  flex-shrink: 0;
}
.picker-cancel {
  font-size: var(--text-base);
  color: var(--text-tertiary);
}
.picker-cancel:active {
  color: var(--text-secondary);
}
.picker-title {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: var(--tracking-tight);
}
.picker-confirm {
  font-size: var(--text-base);
  color: var(--text-accent);
  font-weight: 600;
}
.picker-confirm:active {
  color: var(--purple-light);
}

.picker-body {
  padding: var(--space-8) var(--space-8) var(--space-6);
  overflow-y: auto;
  flex: 1;
}

/* =========================================================
   行业标签网格
   ========================================================= */
.tag-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}
.tag-grid-item {
  background: var(--bg-glass-2);
  border-radius: var(--radius-sm);
  padding: var(--space-6) var(--space-2);
  text-align: center;
  font-size: var(--text-base);
  color: var(--text-secondary);
  border: 1px solid transparent;
  transition: all var(--duration-fast) var(--ease-out);
}
.tag-grid-item:active {
  transform: scale(0.96);
}
.tag-grid-item--active {
  background: var(--bg-glass-3);
  border-color: var(--border-accent);
  color: var(--purple-light);
  font-weight: 500;
  box-shadow: var(--orb-sm);
}

/* =========================================================
   地区选择器（picker-view）
   ========================================================= */
.region-picker-view {
  width: 100%;
  height: 440rpx;
}
.picker-col-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  font-size: var(--text-base);
  color: var(--text-primary);
}
