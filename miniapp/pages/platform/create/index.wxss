.page-wrap {
  min-height: 100vh;
  background: #ffffff;
  padding: 20px 24px;
}

/* 顶部栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 18px;
  font-weight: 500;
  margin-bottom: 24px;
}
.back-icon {
  font-size: 22px;
  padding: 8px;
}
.status-time {
  font-size: 16px;
  color: #333;
}
.status-placeholder {
  width: 30px;
}

/* 页面标题 */
.page-title {
  font-size: 20px;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40px;
}

/* 图标区域 */
.icon-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48px;
}
.cube-icon {
  width: 120px;
  height: 120px;
  background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><path fill="%234068b8" d="M40 20 L60 20 L65 28 L45 28 Z"/><path fill="%235078d0" d="M60 20 L75 30 L70 42 L55 32 Z"/><path fill="%233058a8" d="M40 20 L25 30 L30 42 L45 32 Z"/><path fill="%23284890" d="M30 42 L45 32 L45 50 L30 60 Z"/><path fill="%234068b8" d="M55 32 L70 42 L70 60 L55 50 Z"/><path fill="%235078d0" d="M45 32 L55 32 L55 50 L45 50 Z"/><path fill="%233058a8" d="M30 60 L45 50 L45 70 L30 80 Z"/><path fill="%234068b8" d="M55 50 L70 60 L70 80 L55 70 Z"/><path fill="%235078d0" d="M45 50 L55 50 L55 70 L45 70 Z"/><circle cx="50" cy="50" r="8" fill="white" opacity="0.9"/><path fill="white" d="M46 48 h8 v4 h-8 z M48 46 v8 h4 v-8 z"/></svg>') center / contain no-repeat;
  margin-bottom: 8px;
}
.add-circle {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #5474b8;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

/* 表单模块 */
.form-item {
  margin-bottom: 32px;
}
.label-text {
  font-size: 16px;
  color: #666;
  margin-bottom: 12px;
  display: block;
}
.input-box {
  width: 100%;
  height: 56px;
  background: #f5f6f8;
  border-radius: 12px;
  border: none;
  padding: 0 16px;
  font-size: 16px;
  color: #333;
  box-sizing: border-box;
}
.input-box::placeholder {
  color: #b0b4bc;
}
.tip-text {
  font-size: 13px;
  color: #999;
  margin-top: 8px;
  display: block;
}

/* 底部按钮区域 */
.bottom-area {
  margin-top: 80px;
}
.create-btn {
  width: 100%;
  height: 60px;
  line-height: 60px;
  background: #c2cdf8;
  border-radius: 30px;
  border: none;
  color: #fff;
  font-size: 18px;
  font-weight: 500;
  text-align: center;
  margin-bottom: 24px;
}
.create-btn--disabled {
  opacity: 0.6;
}
.agree-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
}
.agree-checkbox {
  transform: scale(0.8);
}
.agree-text {
  font-size: 15px;
  color: #666;
}
.agree-link {
  color: #27a878;
}
