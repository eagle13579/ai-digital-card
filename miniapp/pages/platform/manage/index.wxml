<view class="page-container page-container-fade-in">
  <view class="page-header">
    <view class="back" bindtap="goBack">‹</view>
    <text class="title">平台管理</text>
    <view class="invite-btn" bindtap="openInviteModal">邀请加入</view>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:if="{{!loading && platform}}">
    <view class="platform-header-card">
      <view class="platform-logo">
        <text class="logo-text">{{platform.name ? platform.name[0] : 'P'}}</text>
      </view>
      <view class="platform-info">
        <text class="platform-name">{{platform.name}}</text>
        <text class="platform-linkable">可链接单位 {{linkableCount || 1}}</text>
      </view>
    </view>

    <view class="section-card">
      <view class="section-row" bindtap="goToMemberManage">
        <view class="section-item">
          <text class="section-icon">👥</text>
          <text class="section-title">成员管理</text>
        </view>
        <view class="section-right">
          <text class="section-value">{{members.length || 0}}人</text>
          <text class="section-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="import-card" bindtap="handleImportMembers">
      <text class="import-title">一键导入会员</text>
      <text class="import-desc">会员下载App后无需再次注册，自动以预置身份加入平台。</text>
    </view>

    <view class="section-card">
      <view class="section-row" bindtap="goToMessage">
        <view class="section-item">
          <text class="section-icon">📢</text>
          <text class="section-title">消息发布/管理</text>
        </view>
        <text class="section-arrow">›</text>
      </view>
    </view>

    <view class="action-grid">
      <view class="action-item" bindtap="goToNewMemberReview">
        <text class="action-icon">👤</text>
        <text class="action-title">新成员审核</text>
        <text class="action-count" wx:if="{{pendingApplications > 0}}">{{pendingApplications}}</text>
      </view>
      <view class="action-item" bindtap="goToConnectionReview">
        <text class="action-icon">🔗</text>
        <text class="action-title">建联审核</text>
        <text class="action-count" wx:if="{{pendingConnections > 0}}">{{pendingConnections}}</text>
      </view>
    </view>

    <view class="section-card">
      <text class="card-title">平台资源覆盖率</text>
      <view class="coverage-grid">
        <view class="coverage-item">
          <view class="ring-chart">
            <text class="ring-value">{{coverage.platformCities || 0}}</text>
            <text class="ring-label">城市</text>
          </view>
          <view class="coverage-legend">
            <view class="legend-item">
              <view class="legend-dot platform"></view>
              <text class="legend-text">平台成员</text>
            </view>
            <view class="legend-item">
              <view class="legend-dot linkable"></view>
              <text class="legend-text">可链接</text>
            </view>
          </view>
        </view>
        <view class="coverage-item">
          <view class="ring-chart">
            <text class="ring-value">{{coverage.platformIndustries || 0}}</text>
            <text class="ring-label">行业</text>
          </view>
          <view class="coverage-legend">
            <view class="legend-item">
              <view class="legend-dot platform"></view>
              <text class="legend-text">平台成员</text>
            </view>
            <view class="legend-item">
              <view class="legend-dot linkable"></view>
              <text class="legend-text">可链接</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <text class="card-title">平台成员的资源库排名 前3名</text>
      <view class="ranking-list">
        <view class="ranking-item" wx:for="{{ranking}}" wx:key="id">
          <view class="rank-badge" wx:if="{{item.rank <= 3}}">
            <text class="rank-num" style="color: {{getRankColor(item.rank)}}">{{item.rank}}</text>
          </view>
          <view class="rank-num-normal" wx:else>{{item.rank}}</view>
          <view class="member-info">
            <view class="member-avatar">
              <text class="avatar-text">{{item.name ? item.name[0] : '?'}}</text>
            </view>
            <view class="member-detail">
              <text class="member-name">{{item.name}}</text>
              <text class="member-role-text">{{getRoleInfo(item.role).label}}</text>
            </view>
          </view>
          <text class="resource-count">{{item.resourceCount || 0}}</text>
        </view>
      </view>
    </view>
  </block>

  <view class="modal-overlay" wx:if="{{showInviteModal}}" bindtap="closeInviteModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">邀请成员</text>
        <text class="modal-close" bindtap="closeInviteModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="invite-methods">
          <view class="invite-method" bindtap="inviteFromApp">
            <text class="method-icon">📱</text>
            <view class="method-info">
              <text class="method-title">从询赋 App 中邀请</text>
              <text class="method-desc">选择询赋内的好友，发送邀请链接</text>
            </view>
            <text class="method-arrow">›</text>
          </view>
          <view class="invite-method" bindtap="inviteFromWechat">
            <text class="method-icon">💬</text>
            <view class="method-info">
              <text class="method-title">从微信邀请</text>
              <text class="method-desc">选择微信好友，发送邀请链接</text>
            </view>
            <text class="method-arrow">›</text>
          </view>
          <view class="invite-method" bindtap="showQRCode">
            <text class="method-icon">📷</text>
            <view class="method-info">
              <text class="method-title">平台二维码</text>
              <text class="method-desc">通过平台二维码邀请</text>
            </view>
            <text class="method-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>