.page-container {
  min-height: 100vh;
  background: #0f0f1a;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.back {
  font-size: 28px;
  color: #fff;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title {
  font-size: 17px;
  font-weight: 600;
  color: #fff;
}

.edit-btn {
  font-size: 22px;
  color: rgba(255, 255, 255, 0.5);
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
  gap: 12px;
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid rgba(139, 92, 246, 0.2);
  border-top-color: #8b5cf6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.5);
}

.platform-card {
  margin: 16px;
  padding: 20px;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(6, 182, 212, 0.1));
  border-radius: 14px;
  border: 1px solid rgba(139, 92, 246, 0.15);
}

.platform-name {
  font-size: 20px;
  font-weight: 700;
  color: #fff;
  display: block;
}

.platform-desc {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8px;
  display: block;
  line-height: 1.5;
}

.platform-meta {
  display: flex;
  gap: 20px;
  margin-top: 14px;
}

.meta-item {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.6);
}

.tab-bar {
  display: flex;
  margin: 0 16px 12px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 10px;
  padding: 3px;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  border-radius: 8px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.tab-item.active {
  background: rgba(139, 92, 246, 0.15);
}

.tab-text {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.5);
}

.tab-item.active .tab-text {
  color: #a78bfa;
  font-weight: 600;
}

.tab-badge {
  font-size: 10px;
  background: #ef4444;
  color: #fff;
  padding: 1px 6px;
  border-radius: 10px;
  min-width: 16px;
  text-align: center;
}

.content-scroll {
  height: calc(100vh - 280px);
  padding: 0 16px;
}

.section-actions {
  padding: 4px 0 12px;
}

.action-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 20px;
  background: rgba(139, 92, 246, 0.15);
  border: 1px solid rgba(139, 92, 246, 0.25);
  border-radius: 10px;
}

.btn-icon {
  font-size: 16px;
  color: #8b5cf6;
  font-weight: 600;
}

.btn-text {
  font-size: 14px;
  color: #a78bfa;
}

/* 成员列表 */
.member-item {
  display: flex;
  align-items: center;
  padding: 14px 12px;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12px;
  margin-bottom: 8px;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.member-avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(6, 182, 212, 0.2));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.member-initial {
  font-size: 16px;
  font-weight: 600;
  color: #a78bfa;
}

.member-info {
  flex: 1;
  margin-left: 12px;
}

.member-name {
  font-size: 15px;
  font-weight: 500;
  color: #fff;
  display: block;
}

.member-join {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 2px;
  display: block;
}

.member-role {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  border-radius: 20px;
  border: 1px solid;
  flex-shrink: 0;
}

.role-icon {
  font-size: 12px;
}

.role-label {
  font-size: 12px;
  font-weight: 500;
}

/* 审核列表 */
.application-item {
  display: flex;
  align-items: center;
  padding: 14px 12px;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12px;
  margin-bottom: 8px;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.app-icon {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.app-icon text {
  font-size: 15px;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
}

.app-info {
  flex: 1;
  margin-left: 12px;
}

.app-name {
  font-size: 15px;
  color: #fff;
  display: block;
}

.app-time {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 2px;
  display: block;
}

.app-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}

.app-btn {
  padding: 6px 14px;
  border-radius: 16px;
  font-size: 13px;
  border: 1px solid;
}

.app-btn.approve {
  background: rgba(34, 197, 94, 0.1);
  border-color: rgba(34, 197, 94, 0.3);
  color: #22c55e;
}

.app-btn.reject {
  background: rgba(239, 68, 68, 0.1);
  border-color: rgba(239, 68, 68, 0.3);
  color: #ef4444;
}

.app-status {
  flex-shrink: 0;
}

.status-text {
  font-size: 13px;
}

.status-text.approved {
  color: #22c55e;
}

.status-text.rejected {
  color: rgba(255, 255, 255, 0.3);
}

/* 数据统计 */
.report-section {
  margin-bottom: 20px;
}

.report-section-title {
  font-size: 15px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12px;
  display: block;
}

.stats-grid {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.stat-card {
  flex: 1;
  min-width: calc(50% - 5px);
  padding: 20px;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.06);
  text-align: center;
}

.stat-count {
  font-size: 28px;
  font-weight: 700;
  color: #a78bfa;
  display: block;
}

.stat-label {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 6px;
  display: block;
}

.industry-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.industry-tag {
  padding: 6px 14px;
  background: rgba(139, 92, 246, 0.1);
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: 16px;
  font-size: 13px;
  color: #a78bfa;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 40px 0;
}

.empty-icon {
  font-size: 36px;
  display: block;
  margin-bottom: 10px;
}

.empty-text {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.4);
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  width: 85%;
  max-width: 340px;
  background: rgba(30, 30, 50, 0.95);
  backdrop-filter: blur(20px);
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.modal-title {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
}

.modal-close {
  font-size: 20px;
  color: rgba(255, 255, 255, 0.5);
  padding: 4px;
}

.modal-body {
  padding: 16px;
}

.form-group {
  margin-bottom: 12px;
}

.form-label {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 6px;
  display: block;
}

.form-input {
  height: 44px;
  padding: 0 12px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  font-size: 15px;
  color: #fff;
  width: 100%;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 12px;
  padding: 12px 16px;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.btn-cancel, .btn-confirm {
  flex: 1;
  height: 40px;
  border-radius: 8px;
  font-size: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-cancel {
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.7);
}

.btn-confirm {
  background: linear-gradient(135deg, #8b5cf6, #06b6d4);
  color: #fff;
}
