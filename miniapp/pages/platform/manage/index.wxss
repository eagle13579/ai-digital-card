/* ===== 平台管理页 - 深色磨砂玻璃风格 ===== */

.page-container {
  min-height: 100vh;
  background: var(--surface-primary);
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: var(--surface-primary);
  border-bottom: 1px solid var(--border-subtle);
}

.back {
  font-size: 28px;
  color: var(--text-primary);
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title {
  font-size: 17px;
  font-weight: 600;
  color: var(--text-primary);
}

.invite-btn {
  font-size: 14px;
  color: #fff;
  background: var(--gradient-accent);
  padding: 6px 16px;
  border-radius: 20px;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
  gap: 12px;
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid rgba(139, 92, 246, 0.2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 14px;
  color: var(--text-tertiary);
}

.platform-header-card {
  display: flex;
  align-items: center;
  gap: 16px;
  margin: 16px;
  padding: 20px;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
}

.platform-logo {
  width: 64px;
  height: 64px;
  border-radius: 14px;
  background: var(--gradient-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.logo-text {
  font-size: 28px;
  font-weight: 700;
  color: #fff;
}

.platform-info {
  flex: 1;
  min-width: 0;
}

.platform-name {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  line-height: 1.3;
}

.platform-linkable {
  font-size: 13px;
  color: var(--text-tertiary);
  display: block;
  margin-top: 6px;
}

.section-card {
  margin: 0 16px 12px;
  padding: 0;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  overflow: hidden;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
}

.section-item {
  display: flex;
  align-items: center;
  gap: 10px;
}

.section-icon {
  font-size: 20px;
}

.section-title {
  font-size: 15px;
  color: var(--text-primary);
  font-weight: 500;
}

.section-right {
  display: flex;
  align-items: center;
  gap: 6px;
}

.section-value {
  font-size: 15px;
  color: var(--text-primary);
  font-weight: 500;
}

.section-arrow {
  font-size: 18px;
  color: var(--text-tertiary);
}

.import-card {
  margin: 0 16px 12px;
  padding: 20px;
  background: var(--gradient-accent);
  border-radius: 12px;
  text-align: center;
}

.import-title {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
  display: block;
}

.import-desc {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-top: 6px;
}

.action-grid {
  display: flex;
  gap: 12px;
  margin: 0 16px 12px;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  position: relative;
}

.action-icon {
  font-size: 24px;
  margin-bottom: 8px;
}

.action-title {
  font-size: 14px;
  color: var(--text-primary);
}

.action-count {
  position: absolute;
  top: 10px;
  right: 10px;
  font-size: 11px;
  background: var(--danger);
  color: #fff;
  padding: 1px 6px;
  border-radius: 10px;
  min-width: 16px;
  text-align: center;
}

.card-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
  padding: 16px 16px 12px;
  display: block;
}

.coverage-grid {
  display: flex;
  padding: 0 16px 16px;
  gap: 20px;
}

.coverage-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ring-chart {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: conic-gradient(var(--accent) 0deg, var(--accent) 45deg, rgba(255,255,255,0.1) 45deg, rgba(255,255,255,0.1) 360deg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.ring-chart::after {
  content: '';
  position: absolute;
  width: 65px;
  height: 65px;
  background: var(--surface-primary);
  border-radius: 50%;
}

.ring-value {
  font-size: 24px;
  font-weight: 700;
  color: var(--text-primary);
  position: relative;
  z-index: 1;
}

.ring-label {
  font-size: 12px;
  color: var(--text-tertiary);
  position: relative;
  z-index: 1;
}

.coverage-legend {
  display: flex;
  gap: 16px;
  margin-top: 12px;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 4px;
}

.legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.legend-dot.platform {
  background: var(--accent);
}

.legend-dot.linkable {
  background: rgba(255, 255, 255, 0.1);
}

.legend-text {
  font-size: 11px;
  color: var(--text-tertiary);
}

.ranking-list {
  padding: 0 16px 16px;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid var(--border-subtle);
}

.ranking-item:last-child {
  border-bottom: none;
}

.rank-badge {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  border: 2px solid var(--border-default);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
}

.rank-num {
  font-size: 13px;
  font-weight: 700;
}

.rank-num-normal {
  font-size: 14px;
  color: var(--text-tertiary);
  width: 24px;
  text-align: center;
  margin-right: 12px;
}

.member-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10px;
}

.member-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(6, 182, 212, 0.2));
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 14px;
  font-weight: 600;
  color: var(--accent-light);
}

.member-detail {
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 14px;
  color: var(--text-primary);
}

.member-role-text {
  font-size: 12px;
  color: var(--text-tertiary);
}

.resource-count {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-content {
  width: 100%;
  background: var(--surface-glass-strong);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 16px 16px 0 0;
  overflow: hidden;
  border-top: 1px solid var(--border-subtle);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid var(--border-subtle);
}

.modal-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: 20px;
  color: var(--text-tertiary);
  padding: 4px;
}

.modal-body {
  padding: 16px;
}

.invite-methods {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.invite-method {
  display: flex;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid var(--border-subtle);
}

.invite-method:last-child {
  border-bottom: none;
}

.method-icon {
  font-size: 24px;
  margin-right: 12px;
}

.method-info {
  flex: 1;
}

.method-title {
  font-size: 15px;
  color: var(--text-primary);
  display: block;
}

.method-desc {
  font-size: 13px;
  color: var(--text-tertiary);
  display: block;
  margin-top: 4px;
}

.method-arrow {
  font-size: 18px;
  color: var(--text-tertiary);
}
