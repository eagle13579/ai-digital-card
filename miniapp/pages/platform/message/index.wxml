<view class="page-container">
  <!-- ===== 页面顶部导航 ===== -->
  <view class="page-header">
    <view class="back" bindtap="goBack">‹</view>
    <text class="title">消息发布/管理</text>
    <view class="header-right" />
  </view>

  <!-- ===== 加载状态 ===== -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:if="{{!loading}}">
    <!-- ===== 模式切换入口卡片 ===== -->
    <view class="mode-cards">
      <view class="mode-card {{activeTab === 'send' ? 'active' : ''}}" bindtap="switchToSend">
        <text class="mode-icon">📤</text>
        <text class="mode-title">发布消息</text>
        <text class="mode-desc">向平台成员发送通知或资讯</text>
      </view>
      <view class="mode-card {{activeTab === 'list' ? 'active' : ''}}" bindtap="switchToList">
        <text class="mode-icon">📋</text>
        <text class="mode-title">消息管理</text>
        <text class="mode-desc">查看已发送和接收的消息记录</text>
      </view>
    </view>

    <!-- ===== 发布消息表单 ===== -->
    <view class="form-section" wx:if="{{activeTab === 'send'}}">
      <view class="section-card">
        <text class="card-title">发送新消息</text>

        <view class="form-group">
          <text class="form-label">接收人</text>
          <picker mode="selector" range="{{receiverOptions}}" range-key="label" value="{{receiverIndex}}" bindchange="onReceiverChange">
            <view class="form-input picker-trigger">
              <text class="picker-text" wx:if="{{receiverIndex >= 0}}">{{receiverOptions[receiverIndex].label}}</text>
              <text class="picker-placeholder" wx:else>请选择接收人</text>
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>

        <view class="form-group">
          <text class="form-label">消息内容</text>
          <textarea class="form-textarea" placeholder="请输入消息内容..." value="{{messageContent}}" bindinput="onContentInput" maxlength="500" auto-height />
          <text class="char-count">{{messageContent.length}}/500</text>
        </view>

        <button class="btn-primary" bindtap="sendMessage" disabled="{{!canSend}}">
          <text wx:if="{{sending}}" class="sending-text">发送中...</text>
          <text wx:else>发送消息</text>
        </button>
      </view>
    </view>

    <!-- ===== 消息列表 ===== -->
    <view class="list-section" wx:if="{{activeTab === 'list'}}">
      <!-- 未读数统计 -->
      <view class="unread-bar" wx:if="{{unreadCount > 0}}" bindtap="refreshList">
        <text class="unread-text">你有 {{unreadCount}} 条未读消息</text>
        <text class="unread-action">刷新</text>
      </view>

      <!-- 会话列表 (按会话分组) -->
      <view class="section-card" wx:if="{{conversations.length > 0}}">
        <text class="card-title">会话列表</text>
        <view class="conv-list">
          <view class="conv-item" wx:for="{{conversations}}" wx:key="id" data-id="{{item.id}}" bindtap="openConversation">
            <view class="conv-avatar">
              <text class="avatar-text">{{item.name ? item.name[0] : '?'}}</text>
            </view>
            <view class="conv-info">
              <view class="conv-top">
                <text class="conv-name">{{item.name || '未知用户'}}</text>
                <text class="conv-time">{{item.last_time || ''}}</text>
              </view>
              <view class="conv-bottom">
                <text class="conv-preview">{{item.last_content || ''}}</text>
                <view class="conv-badge" wx:if="{{item.unread > 0}}">{{item.unread}}</view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{conversations.length === 0}}">
        <text class="empty-icon">💬</text>
        <text class="empty-text">暂无消息记录</text>
      </view>
    </view>
  </block>

  <!-- ===== 底部安全区 ===== -->
  <view class="bottom-placeholder" />
</view>
