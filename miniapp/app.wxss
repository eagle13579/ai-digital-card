/**
 * ============================================================
 *  AI数智名片 — Global Design System v2.0
 *  Dark Minimal · Glassmorphism · Purple Accent
 *  Ref: Linear.app | Stripe | Vercel
 * ============================================================
 */

/* ===== Design Tokens ===== */
page {
  /* Surface */
  --surface-primary:    #0f0f1a;
  --surface-secondary:  #1a1a2e;
  --surface-tertiary:   #252540;
  --surface-glass:      rgba(30, 30, 50, 0.6);
  --surface-glass-strong: rgba(30, 30, 50, 0.95);

  /* Accent (紫色主题) */
  --accent:             #8b5cf6;
  --accent-light:       #a78bfa;
  --accent-dark:        #6d28d9;
  --gradient-accent:    linear-gradient(135deg, #8b5cf6 0%, #06b6d4 100%);
  --gradient-warm:      linear-gradient(135deg, #a78bfa 0%, #8b5cf6 100%);
  --gradient-card:      linear-gradient(135deg, rgba(139,92,246,0.12), rgba(6,182,212,0.08));
  --gradient-header:    linear-gradient(135deg, rgba(139,92,246,0.08), rgba(6,182,212,0.04));

  /* Text */
  --text-primary:       #ffffff;
  --text-secondary:     rgba(255, 255, 255, 0.72);
  --text-tertiary:      rgba(255, 255, 255, 0.45);
  --text-disabled:      rgba(255, 255, 255, 0.2);

  /* Border */
  --border-subtle:      rgba(255, 255, 255, 0.06);
  --border-default:     rgba(255, 255, 255, 0.1);
  --border-strong:      rgba(255, 255, 255, 0.18);

  /* Semantic */
  --success:            #22c55e;
  --warning:            #f59e0b;
  --danger:             #ef4444;
  --info:               #06b6d4;

  /* Shadow */
  --shadow-sm:  0 2px 8px  rgba(0, 0, 0, 0.2);
  --shadow-md:  0 4px 16px rgba(0, 0, 0, 0.25);
  --shadow-lg:  0 8px 32px rgba(0, 0, 0, 0.35);
  --shadow-glow: 0 0 20px rgba(139, 92, 246, 0.25);

  /* Typography Scale */
  --text-xs:    11px;
  --text-sm:    13px;
  --text-base:  15px;
  --text-lg:    18px;
  --text-xl:    24px;
  --text-2xl:   32px;
  --weight-regular: 400;
  --weight-medium:  500;
  --weight-semibold: 600;
  --weight-bold:    700;

  /* Spacing (4px increment) */
  --space-1:  4px;
  --space-2:  8px;
  --space-3:  12px;
  --space-4:  16px;
  --space-5:  20px;
  --space-6:  24px;
  --space-8:  32px;
  --space-10: 40px;
  --space-12: 48px;

  /* Radius */
  --radius-sm:    8px;
  --radius-md:    12px;
  --radius-lg:    16px;
  --radius-xl:    20px;
  --radius-full:  999px;

  /* Z-index */
  --z-dropdown: 100;
  --z-sticky:   200;
  --z-overlay:  300;
  --z-modal:    400;
  --z-toast:    500;

  /* Font & Base */
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display',
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei',
    'Helvetica Neue', sans-serif;
  font-size: var(--text-base);
  color: var(--text-primary);
  background: var(--surface-primary);
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ===== Glass Card (核心视觉组件) ===== */
.glass-card {
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  margin: var(--space-3) var(--space-4);
  overflow: hidden;
}

.glass-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-4) var(--space-3);
}

.glass-card-header .title {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
}

.glass-card-header .more {
  font-size: var(--text-sm);
  color: var(--accent);
}

.glass-card-body {
  padding: 0 var(--space-4) var(--space-4);
}

/* ===== Page Container ===== */
.page-container {
  min-height: 100vh;
  background: var(--surface-primary);
}

.page-scroll {
  height: 100vh;
}

/* ===== Page Header ===== */
.page-header {
  display: flex;
  align-items: center;
  padding: var(--space-3) var(--space-4);
  border-bottom: 1px solid var(--border-subtle);
  background: var(--surface-primary);
}

.page-header .back {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  color: var(--text-primary);
  margin-right: var(--space-2);
  flex-shrink: 0;
}

.page-header .title {
  font-size: var(--text-lg);
  font-weight: var(--weight-semibold);
  flex: 1;
}

/* ===== Section Title Area ===== */
.section-header {
  text-align: center;
  padding: var(--space-6) var(--space-4) var(--space-4);
}

.section-title {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  display: block;
}

.section-subtitle {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  display: block;
  margin-top: var(--space-1);
}

/* ===== Buttons ===== */

/* 主按钮 — 紫色渐变 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  background: var(--gradient-accent);
  color: #fff;
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  border-radius: var(--radius-sm);
  border: none;
  width: 100%;
  cursor: pointer;
  transition: opacity 0.2s, transform 0.15s;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-primary.small {
  height: 36px;
  font-size: var(--text-sm);
  border-radius: var(--radius-full);
  width: auto;
  padding: 0 var(--space-5);
}

.btn-primary.disabled {
  opacity: 0.4;
  pointer-events: none;
}

/* 次要按钮 — 透明边框 */
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-primary);
  font-size: var(--text-base);
  font-weight: var(--weight-medium);
  border-radius: var(--radius-sm);
  border: 1px solid var(--border-default);
  width: 100%;
  cursor: pointer;
}

.btn-secondary:active {
  background: rgba(255, 255, 255, 0.08);
}

.btn-secondary.small {
  height: 36px;
  font-size: var(--text-sm);
  border-radius: var(--radius-full);
  width: auto;
  padding: 0 var(--space-5);
}

/* 轮廓按钮 — 带accent色边框 */
.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 44px;
  background: transparent;
  color: var(--accent);
  font-size: var(--text-base);
  font-weight: var(--weight-medium);
  border-radius: var(--radius-sm);
  border: 1.5px solid var(--accent);
  width: 100%;
  cursor: pointer;
}

.btn-outline:active {
  background: rgba(139, 92, 246, 0.08);
}

/* ===== Form Elements ===== */
.form-group {
  margin-bottom: var(--space-4);
}

.form-label {
  display: block;
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-2);
  font-weight: var(--weight-medium);
}

.form-input {
  width: 100%;
  height: 44px;
  padding: 0 var(--space-3);
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-sm);
  font-size: var(--text-base);
  color: var(--text-primary);
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.form-input:focus {
  border-color: var(--accent);
  background: rgba(255, 255, 255, 0.08);
}

.form-input::placeholder {
  color: var(--text-tertiary);
}

.form-input.error {
  border-color: var(--danger);
}

.form-textarea {
  width: 100%;
  padding: var(--space-3);
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-sm);
  font-size: var(--text-base);
  color: var(--text-primary);
  box-sizing: border-box;
  min-height: 80px;
  transition: border-color 0.2s;
}

.form-textarea:focus {
  border-color: var(--accent);
  background: rgba(255, 255, 255, 0.08);
}

.form-textarea::placeholder {
  color: var(--text-tertiary);
}

/* ===== Badges ===== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 2px 10px;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: var(--weight-medium);
}

.badge-free {
  background: rgba(255, 255, 255, 0.06);
  color: var(--text-tertiary);
}

.badge-gold {
  background: linear-gradient(135deg, #f5a623, #f7d94c);
  color: #fff;
}

.badge-diamond {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: #fff;
}

.badge-board {
  background: var(--gradient-accent);
  color: #fff;
}

/* ===== Tags ===== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  background: rgba(139, 92, 246, 0.12);
  color: var(--accent-light);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  margin: 0 6px 6px 0;
}

.tag.provide {
  background: rgba(34, 197, 94, 0.12);
  color: var(--success);
}

.tag.need {
  background: rgba(245, 158, 11, 0.12);
  color: var(--warning);
}

/* ===== Divider ===== */
.divider {
  height: 1px;
  background: var(--border-subtle);
  margin: 0 var(--space-4);
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-10) var(--space-5);
}

.empty-state .empty-icon {
  width: 80px;
  height: 80px;
  margin-bottom: var(--space-4);
  opacity: 0.4;
}

.empty-state .text {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  text-align: center;
}

/* ===== Skeleton ===== */
.skeleton {
  background: linear-gradient(90deg,
    rgba(255,255,255,0.04) 25%,
    rgba(255,255,255,0.08) 50%,
    rgba(255,255,255,0.04) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: var(--radius-sm);
}

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== Safe Area ===== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom, 12px);
}

.bottom-placeholder {
  height: var(--space-10);
}

/* ===== Spinner ===== */
.spinner {
  width: 32px;
  height: 32px;
  border: 3px solid rgba(139, 92, 246, 0.2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  0%   { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* ===== List Item (通用列表项) ===== */
.list-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background: var(--surface-glass);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  margin-bottom: 8px;
}

.list-item:active {
  background: rgba(255, 255, 255, 0.05);
}

/* ===== Statistics Grid ===== */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  padding: 0 var(--space-4) var(--space-4);
}

.stats-grid .stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-grid .stat-num {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
}

.stats-grid .stat-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 2px;
}

/* ===== Info Row ===== */
.info-row {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid var(--border-subtle);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  width: 80px;
  flex-shrink: 0;
}

.info-value {
  font-size: var(--text-base);
  color: var(--text-primary);
  flex: 1;
}

/* ===== Upgrade Hint ===== */
.upgrade-hint {
  display: flex;
  align-items: center;
  margin: var(--space-2) var(--space-4);
  padding: var(--space-3) var(--space-4);
  background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(6,182,212,0.1));
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: var(--radius-md);
}

.upgrade-hint-icon {
  font-size: 18px;
  margin-right: var(--space-2);
  flex-shrink: 0;
}

.upgrade-hint-text {
  flex: 1;
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

.upgrade-hint-arrow {
  font-size: 18px;
  color: var(--accent);
  flex-shrink: 0;
  margin-left: var(--space-2);
}

/* ===== Modal Overlay (通用) ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  z-index: var(--z-modal);
}

.modal-content {
  width: 100%;
  max-height: 70vh;
  background: var(--surface-glass-strong);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4);
  border-bottom: 1px solid var(--border-subtle);
}

.modal-title {
  font-size: var(--text-lg);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
}

.modal-close {
  font-size: 20px;
  color: var(--text-tertiary);
  padding: 4px;
}

.modal-body {
  padding: var(--space-4);
}
