/**
 * 全局样式 - AI数智名片
 * 设计Token系统已注入: tokens.wxss + tailwind-like.wxss
 */
@import "styles/tokens.wxss";
@import "styles/tailwind-like.wxss";

/* ── TabBar 选中态光晕效果 ── */
/* 利用 tokens 中的紫色光晕系统，选中时呈现紫色 glow */
/* 当使用自定义TabBar时，以下样式生效 */
.custom-tabbar-item-active {
  color: var(--purple-light, #a78bfa) !important;
}
.custom-tabbar-item-active .tabbar-icon {
  filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0.4));
}
.custom-tabbar-item-active .tabbar-label {
  text-shadow: 0 0 12px rgba(139, 92, 246, 0.5);
}

/* TabBar 背景玻璃质感 */
.custom-tabbar-wrap {
  background: rgba(15, 15, 19, 0.92) !important;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 0.5px solid rgba(255, 255, 255, 0.06);
}

/* ═══════════════════════════════════════════
   弹簧动效系统 — spring 曲线
   配合 WXML hover-class 使用
   ═══════════════════════════════════════════ */
.spring-press {
  cursor: pointer;
}

.spring-scale-down {
  transform: scale(0.97) !important;
  transition: transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1) !important;
}

.spring-scale-mini {
  transform: scale(0.95) !important;
  transition: transform 150ms cubic-bezier(0.34, 1.56, 0.64, 1) !important;
}

/* ═══════════════════════════════════════════
   玻璃三级体系 — 组件级类名
   ═══════════════════════════════════════════ */
/* 薄玻璃 — 次要容器/列表项 */
.glass-tier-1 {
  background: var(--bg-glass-1) !important;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 0.5px solid rgba(255, 255, 255, 0.04);
}

/* 中厚玻璃 — 卡片/面板（默认卡片级别） */
.glass-tier-2 {
  background: var(--bg-glass-2) !important;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 0.5px solid rgba(255, 255, 255, 0.05);
}

/* 厚玻璃 — 弹窗/导航栏 */
.glass-tier-3 {
  background: rgba(15, 15, 19, 0.92) !important;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 0.5px solid rgba(255, 255, 255, 0.06);
}

/* ═══════════════════════════════════════════
   输入框占位符 — 暗色适配
   ═══════════════════════════════════════════ */
.input-placeholder {
  color: var(--text-tertiary, rgba(255, 255, 255, 0.40));
  font-size: 28rpx;
}

/* ═══════════════════════════════════════════
   暗色模式标记（用于页面容器）
   ═══════════════════════════════════════════ */
.dark-mode {
  /* 标记类，样式由 token 系统驱动 */
}

/* 暗色滚动条覆盖 */
page::-webkit-scrollbar {
  width: 4rpx;
  height: 4rpx;
  background: transparent;
}
page::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 4rpx;
}

/* 通用容器 */
.page-container {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 卡片容器 */
.card {
  background: var(--bg-elevated);
  border-radius: var(--radius-md);
  box-shadow: var(--orb-sm), var(--shadow-glass-edge);
  margin: var(--space-6) var(--space-6);
  overflow: hidden;
  border: var(--glass-border-2);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 16px 12px;
}

.card-header .title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.card-header .more {
  font-size: 26rpx;
  color: var(--text-accent);
}

.card-body {
  padding: 0 16px 16px;
}

/* 主按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: var(--btn-primary-height);
  background: var(--btn-primary-bg);
  color: var(--btn-primary-color);
  font-size: var(--btn-primary-font-size);
  font-weight: var(--btn-primary-font-weight);
  border-radius: var(--btn-primary-radius);
  border: none;
  width: 100%;
  box-shadow: var(--btn-primary-orb);
  transition: box-shadow var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);
}

.btn-primary:active {
  box-shadow: var(--btn-primary-hover-orb);
  transform: scale(0.98);
}

.btn-primary.small {
  height: var(--btn-sm-height);
  font-size: var(--btn-sm-font-size);
  border-radius: var(--btn-sm-radius);
  width: auto;
  padding: 0 var(--space-5);
}

.btn-primary.disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 次要按钮 */
.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  height: var(--btn-outline-height);
  background: var(--btn-outline-bg);
  color: var(--btn-outline-color);
  font-size: var(--btn-outline-font-size);
  font-weight: var(--btn-outline-font-weight);
  border-radius: var(--btn-outline-radius);
  border: var(--btn-outline-border);
  width: 100%;
  transition: background var(--duration-fast) var(--ease-out);
}

.btn-outline:active {
  background: var(--bg-hover);
}

/* 表单 */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: var(--input-height);
  padding: 0 var(--space-6);
  background: var(--input-bg);
  border: var(--input-border);
  border-radius: var(--input-radius);
  font-size: var(--text-base);
  color: var(--input-color);
  box-sizing: border-box;
  transition: border var(--duration-fast) var(--ease-out);
}

.form-input:focus {
  border: var(--input-focus-border);
  background: var(--bg-glass-2);
}

.form-input.error {
  border-color: var(--danger);
}

.form-textarea {
  width: 100%;
  padding: var(--space-6);
  background: var(--input-bg);
  border: var(--input-border);
  border-radius: var(--input-radius);
  font-size: var(--text-base);
  color: var(--input-color);
  box-sizing: border-box;
  min-height: 160rpx;
}

/* 徽章 */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 10px;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-free {
  background: var(--bg-glass-2);
  color: var(--text-tertiary);
}

.badge-gold {
  background: var(--gradient-purple-pink);
  color: #fff;
}

.badge-diamond {
  background: var(--gradient-cyan-purple);
  color: #fff;
}

.badge-board {
  background: var(--gradient-primary);
  color: #fff;
}

.badge-pro {
  background: var(--gradient-purple-pink);
  color: #fff;
}

.badge-enterprise {
  background: var(--gradient-cyan-only);
  color: var(--text-inverse);
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: var(--space-2) var(--space-4);
  background: var(--bg-glass-2);
  color: var(--text-accent);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  margin: 0 6rpx 6rpx 0;
}

.tag.provide {
  background: rgba(16, 185, 129, 0.12);
  color: var(--success);
}

.tag.need {
  background: rgba(245, 158, 11, 0.12);
  color: var(--warning);
}

/* 分隔线 */
.divider {
  height: 2rpx;
  background: var(--border-subtle);
  margin: 0 var(--space-6);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 20px;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-state .text {
  font-size: var(--text-base);
  color: var(--text-tertiary);
  text-align: center;
}

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, rgba(255,255,255,0.06) 25%, rgba(255,255,255,0.10) 50%, rgba(255,255,255,0.06) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 安全区域适配 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom, 12px);
}

/* 页面标题区域 */
.page-header {
  display: flex;
  align-items: center;
  padding: var(--space-6) var(--space-6);
  background: var(--bg-glass-2);
  border-bottom: 0.5px solid var(--border-subtle);
}

.page-header .back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.page-header .title {
  font-size: 36rpx;
  font-weight: 600;
  flex: 1;
}
