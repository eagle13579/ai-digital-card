.card-item {
  display: flex;
  align-items: center;
  padding: 16px;
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  margin-bottom: 12px;
}

.card-item:active {
  opacity: 0.9;
}

.card-avatar {
  position: relative;
  width: 56px;
  height: 56px;
  border-radius: 28px;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 12px;
}

.card-avatar-img {
  width: 100%;
  height: 100%;
}

.member-badge {
  position: absolute;
  bottom: -2px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 9px;
  padding: 1px 6px;
  border-radius: 8px;
  white-space: nowrap;
  border: 1.5px solid #fff;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-name {
  font-size: 16px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 2px;
}

.card-company {
  font-size: 13px;
  color: #666;
  margin-bottom: 1px;
}

.card-title {
  font-size: 12px;
  color: #999;
  margin-bottom: 4px;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
}

.card-tags .tag {
  font-size: 11px;
  padding: 2px 8px;
  margin: 0 4px 4px 0;
}

.card-extra {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-left: 8px;
}

.match-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 4px;
}

.score-value {
  font-size: 20px;
  font-weight: 700;
  color: #07c160;
}

.score-label {
  font-size: 10px;
  color: #999;
}

.unlock-btn {
  font-size: 12px !important;
  height: 28px !important;
  padding: 0 12px !important;
  min-width: 56px;
}
