/* Card Item 组件 - v2.0 Dark Minimal */

.card-item {
  display: flex;
  align-items: center;
  padding: var(--space-4);
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-3);
}

.card-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.card-avatar {
  position: relative;
  width: 56px;
  height: 56px;
  border-radius: var(--radius-full);
  overflow: hidden;
  flex-shrink: 0;
  margin-right: var(--space-3);
  border: 1px solid var(--border-subtle);
}

.card-avatar-img {
  width: 100%;
  height: 100%;
}

.member-badge {
  position: absolute;
  bottom: -2px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 9px;
  padding: 1px 6px;
  border-radius: 8px;
  white-space: nowrap;
  border: 1.5px solid var(--surface-primary);
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-name {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  margin-bottom: 2px;
}

.card-company {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-bottom: 1px;
}

.card-title {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-bottom: 4px;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
}

.card-tags .tag {
  font-size: var(--text-xs);
  padding: 2px 8px;
  margin: 0 4px 4px 0;
}

.card-extra {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-left: var(--space-2);
}

.match-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 4px;
}

.score-value {
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
  color: var(--success);
}

.score-label {
  font-size: 10px;
  color: var(--text-tertiary);
}

.unlock-btn {
  font-size: var(--text-xs) !important;
  height: 28px !important;
  padding: 0 var(--space-3) !important;
  min-width: 56px;
}
