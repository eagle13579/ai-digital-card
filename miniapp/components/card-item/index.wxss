.card-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}

.card-item:active {
  opacity: 0.9;
}

.card-avatar {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.card-avatar-img {
  width: 100%;
  height: 100%;
}

.member-badge {
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  padding: 2rpx 6px;
  border-radius: 16rpx;
  white-space: nowrap;
  border: 1.5px solid #fff;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 4rpx;
}

.card-company {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 2rpx;
}

.card-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
}

.card-tags .tag {
  font-size: 22rpx;
  padding: 4rpx 8px;
  margin: 0 4px 4px 0;
}

.card-extra {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.match-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 8rpx;
}

.score-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #07c160;
}

.score-label {
  font-size: 20rpx;
  color: #999;
}

.unlock-btn {
  font-size: 24rpx !important;
  height: 56rpx !important;
  padding: 0 12px !important;
  min-width: 112rpx;
}
