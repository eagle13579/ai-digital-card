/**
 * Stats Grid Styles
 * AI数智名片 - 复用统计网格
 */
.stats-grid {
  display: grid;
  gap: 12px;
  padding: 8px 16px;
}

.stats-grid.cols-2 {
  grid-template-columns: repeat(2, 1fr);
}

.stats-grid.cols-3 {
  grid-template-columns: repeat(3, 1fr);
}

.stats-grid.cols-4 {
  grid-template-columns: repeat(4, 1fr);
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16px 12px;
  background: var(--surface-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  transition: border-color 0.3s ease, transform 0.2s ease;
}

.stats-item-hover {
  border-color: rgba(139, 92, 246, 0.2);
  transform: scale(0.97);
}

/* Size variants */
.size-small .stats-item {
  padding: 10px 8px;
}

.size-large .stats-item {
  padding: 20px 16px;
}

.stats-icon {
  font-size: 24px;
  margin-bottom: 8px;
  line-height: 1;
}

.size-small .stats-icon {
  font-size: 18px;
  margin-bottom: 4px;
}

.size-large .stats-icon {
  font-size: 32px;
  margin-bottom: 10px;
}

.stats-value {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  line-height: 1.2;
}

.size-small .stats-value {
  font-size: var(--text-lg);
}

.size-large .stats-value {
  font-size: var(--text-2xl);
}

.stats-label {
  font-size: var(--text-xs);
  color: var(--text-secondary);
  margin-top: 4px;
  text-align: center;
}

.stats-trend {
  font-size: 11px;
  margin-top: 6px;
  font-weight: var(--weight-medium);
}

.stats-trend.trend-up {
  color: var(--success);
}

.stats-trend.trend-down {
  color: var(--danger);
}
