/**
 * User Header Styles
 * AI数智名片 - 复用用户头部
 */
.user-header {
  padding: 16px 16px 8px;
}

.user-header.large {
  padding: 24px 16px 12px;
}

.user-header.small {
  padding: 10px 12px 6px;
}

.user-header-main {
  display: flex;
  align-items: center;
  gap: 14px;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: var(--surface-tertiary);
}

.user-header.large .avatar {
  width: 76px;
  height: 76px;
}

.user-header.small .avatar {
  width: 44px;
  height: 44px;
}

.avatar-ring {
  position: absolute;
  inset: -2px;
  border-radius: 50%;
  border: 2px solid var(--accent);
  opacity: 0.3;
  pointer-events: none;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.user-name {
  font-size: var(--text-lg);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  line-height: 1.3;
}

.user-header.large .user-name {
  font-size: var(--text-xl);
}

.user-header.small .user-name {
  font-size: var(--text-base);
}

.user-badge {
  font-size: 10px;
  padding: 1px 8px;
  background: var(--gradient-accent);
  color: #fff;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.user-title {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-top: 2px;
  display: block;
}

.user-company {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 1px;
  display: block;
}

.user-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}

.action-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-glass);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-full);
  transition: background 0.2s;
}

.action-btn:active {
  background: var(--surface-tertiary);
}

.action-icon {
  font-size: 18px;
}

.user-divider {
  height: 1px;
  background: var(--border-subtle);
  margin-top: 16px;
}
