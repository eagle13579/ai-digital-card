/* FlipBook 3D翻转名片组件 */
.flipbook {
  width: 100%;
  max-width: 340px;
  margin: 0 auto;
  perspective: 1000px;
  cursor: pointer;
}

.flipbook__inner {
  position: relative;
  width: 100%;
  height: 220px;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  transform-style: preserve-3d;
}

.flipbook--flipped .flipbook__inner {
  transform: rotateY(180deg);
}

.flipbook__face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  border-radius: 16px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.flipbook__face--front {
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  padding: 20px;
}

.flipbook__face--back {
  background: linear-gradient(135deg, #1e1e2e, #2a2a3e);
  transform: rotateY(180deg);
  border: 1px solid rgba(255,255,255,0.08);
}

.flipbook__avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.3);
  margin-bottom: 8px;
}

.flipbook__name {
  font-size: 18px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 2px;
}

.flipbook__company {
  font-size: 12px;
  color: rgba(255,255,255,0.7);
  margin-bottom: 8px;
}

.flipbook__divider {
  width: 40px;
  height: 2px;
  background: rgba(255,255,255,0.2);
  margin-bottom: 8px;
}

.flipbook__contact {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.flipbook__contact-item {
  font-size: 12px;
  color: rgba(255,255,255,0.8);
}

.flipbook__hint {
  position: absolute;
  bottom: 8px;
  font-size: 10px;
  color: rgba(255,255,255,0.3);
}

/* 背面 */
.flipbook__back-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px;
}

.flipbook__back-title {
  font-size: 14px;
  color: #fff;
  font-weight: 600;
  margin-bottom: 12px;
}

.flipbook__qrcode {
  width: 100px;
  height: 100px;
  border-radius: 8px;
  margin-bottom: 8px;
}

.flipbook__qrcode-placeholder {
  width: 100px;
  height: 100px;
  background: rgba(255,255,255,0.04);
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
}

.flipbook__qrcode-placeholder-icon {
  font-size: 32px;
}

.flipbook__qrcode-placeholder-text {
  font-size: 10px;
  color: rgba(255,255,255,0.3);
  margin-top: 4px;
}

.flipbook__back-hint {
  font-size: 11px;
  color: rgba(255,255,255,0.4);
}

/* 骨架 */
.flipbook__skeleton {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px;
}

.flipbook__skeleton-avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  margin-bottom: 12px;
}

.flipbook__skeleton-line {
  height: 10px;
  background: rgba(255,255,255,0.08);
  border-radius: 5px;
  margin-bottom: 6px;
}

.flipbook__skeleton-line--short { width: 80px; }
.flipbook__skeleton-line--medium { width: 140px; }
.flipbook__skeleton-line--long { width: 200px; }

/* 空名片 */
.flipbook__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.flipbook__empty-icon { font-size: 40px; }
.flipbook__empty-text { font-size: 16px; color: #fff; font-weight: 600; margin-top: 8px; }
.flipbook__empty-hint { font-size: 12px; color: rgba(255,255,255,0.4); margin-top: 4px; }
