/* Result Card 搜索结果卡片 */
.result-card {
  display: flex;
  align-items: center;
  padding: var(--space-3) var(--space-4);
  background: var(--surface-glass);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  margin: 0 var(--space-4) var(--space-2);
  cursor: pointer;
  transition: background 0.15s;
}

.result-card:active {
  background: rgba(255, 255, 255, 0.04);
}

.result-card-avatar {
  width: 44px;
  height: 44px;
  border-radius: var(--radius-full);
  flex-shrink: 0;
  background: var(--surface-tertiary);
  margin-right: var(--space-3);
}

.result-card-body {
  flex: 1;
  min-width: 0;
}

.result-card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.result-card-name {
  font-size: var(--text-base);
  font-weight: var(--weight-medium);
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: var(--space-2);
}

.result-card-match {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.result-card-score {
  font-size: var(--text-xs);
  font-weight: var(--weight-semibold);
  color: var(--accent);
  background: rgba(139, 92, 246, 0.12);
  padding: 2px 8px;
  border-radius: var(--radius-full);
}

.result-card-company {
  display: block;
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-top: 4px;
}

.result-card-tag {
  font-size: 10px;
  padding: 1px 8px;
  background: rgba(139, 92, 246, 0.10);
  color: var(--accent-light);
  border-radius: var(--radius-full);
}

.result-card-extra {
  display: block;
  font-size: 10px;
  color: var(--text-disabled);
  margin-top: 2px;
}
