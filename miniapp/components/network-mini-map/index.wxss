.network-mini-map {
  background: #fff;
  border-radius: 16px;
  padding: 16px;
  margin: 12px 16px;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
}

.map-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.map-title {
  font-size: 16px;
  font-weight: 600;
  color: #1a1a1a;
}

.map-count {
  font-size: 13px;
  color: #666;
}

.map-container {
  position: relative;
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.center-node {
  position: absolute;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.center-avatar {
  width: 64px;
  height: 64px;
  border-radius: 32px;
  overflow: hidden;
  border: 3px solid #1657ff;
  box-shadow: 0 4px 12px rgba(22, 87, 255, 0.3);
}

.center-avatar-image {
  width: 100%;
  height: 100%;
}

.center-name {
  font-size: 12px;
  color: #666;
  margin-top: 6px;
}

.paths-container {
  position: relative;
  width: 100%;
  height: 100%;
}

.path-line {
  position: absolute;
}

.path-node {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.2s ease;
}

.path-node:active {
  transform: scale(0.9);
}

.node-avatar {
  width: 36px;
  height: 36px;
  border-radius: 18px;
  border: 2px solid #fff;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
}

.node-name {
  font-size: 10px;
  color: #666;
  margin-top: 4px;
  white-space: nowrap;
  max-width: 60px;
  overflow: hidden;
  text-overflow: ellipsis;
}

.connection-line {
  position: absolute;
  top: 18px;
  width: 40px;
  height: 2px;
  background: linear-gradient(90deg, #1657ff, transparent);
  transform-origin: left center;
}

.ring-ring {
  position: absolute;
  border: 1px dashed rgba(22, 87, 255, 0.2);
  border-radius: 50%;
}

.ring-1 {
  width: 80px;
  height: 80px;
}

.ring-2 {
  width: 130px;
  height: 130px;
}

.ring-3 {
  width: 180px;
  height: 180px;
}

.map-footer {
  text-align: center;
  margin-top: 12px;
}

.footer-tip {
  font-size: 12px;
  color: #999;
}

.spring-press {
  touch-action: manipulation;
}
