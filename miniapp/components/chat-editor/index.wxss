/**
 * 对话式编辑样式 — ChatEditor
 * 深色主题 + 玻璃质输入栏 + 意图预览卡片 + 弹簧动效
 */

.chat-editor {
  font-size: var(--text-base, 28rpx);
  color: var(--text-primary, rgba(255,255,255,0.92));
}

.chat-editor.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

/* ── 输入栏 ── */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 16px;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom, 0px));
  background: rgba(15, 15, 19, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 0.5px solid var(--border-subtle, rgba(255,255,255,0.06));
}

.input-wrap {
  flex: 1;
  margin: 0 12rpx;
}

.text-input {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  background: var(--bg-glass-1, rgba(255,255,255,0.04));
  border-radius: 36rpx;
  font-size: var(--text-base, 28rpx);
  color: var(--text-primary, rgba(255,255,255,0.92));
  border: 1px solid var(--border-subtle, rgba(255,255,255,0.06));
  box-sizing: border-box;
}

.text-input:focus {
  border-color: var(--border-accent, rgba(139,92,246,0.25));
}

.text-input::placeholder {
  color: var(--text-tertiary, rgba(255,255,255,0.40));
}

.action-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--bg-glass-1, rgba(255,255,255,0.04));
  flex-shrink: 0;
  transition: all 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.action-btn:active {
  background: var(--bg-glass-2, rgba(255,255,255,0.07));
  transform: scale(0.9);
}

.action-icon {
  font-size: 32rpx;
}

.cmd-trigger {
  font-weight: 700;
  color: var(--text-accent, #a78bfa);
  font-size: 36rpx;
}

.voice-btn {
  font-size: 32rpx;
}

.voice-btn.recording {
  background: rgba(239, 68, 68, 0.15);
  border: 1px solid rgba(239, 68, 68, 0.3);
  animation: voicePulse 1s ease-in-out infinite;
}

@keyframes voicePulse {
  0%, 100% { box-shadow: 0 0 4px rgba(239, 68, 68, 0.3); }
  50% { box-shadow: 0 0 16px rgba(239, 68, 68, 0.6); }
}

.send-btn {
  background: var(--bg-glass-1, rgba(255,255,255,0.04));
}

.send-btn.active {
  background: var(--gradient-cyan-purple, linear-gradient(135deg, #06b6d4, #8b5cf6));
  color: #fff;
}

/* ── 快捷指令 ── */
.quick-commands {
  padding: 16rpx 16px;
  background: rgba(15, 15, 19, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 0.5px solid var(--border-subtle, rgba(255,255,255,0.06));
  max-height: 400rpx;
  overflow-y: auto;
}

.commands-header {
  margin-bottom: 12rpx;
}

.commands-title {
  font-size: var(--text-sm, 24rpx);
  color: var(--text-secondary, rgba(255,255,255,0.65));
  font-weight: 500;
}

.commands-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.command-item {
  padding: 12rpx 20rpx;
  background: var(--bg-glass-1, rgba(255,255,255,0.04));
  border-radius: 16rpx;
  border: 1px solid var(--border-subtle, rgba(255,255,255,0.06));
  transition: all 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.command-item:active {
  background: var(--bg-glass-2, rgba(255,255,255,0.07));
  border-color: var(--border-accent, rgba(139,92,246,0.25));
  transform: scale(0.96);
}

.command-cmd {
  font-size: var(--text-sm, 24rpx);
  color: var(--text-accent, #a78bfa);
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
}

.command-desc {
  font-size: var(--text-xs, 20rpx);
  color: var(--text-tertiary, rgba(255,255,255,0.40));
  display: block;
}

/* ── 意图预览浮层 ── */
.intent-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.intent-card {
  width: 620rpx;
  max-width: 88%;
  background: var(--bg-elevated, #0F0F13);
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  border: 1px solid var(--border-default, rgba(255,255,255,0.10));
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), 0 0 40px rgba(139, 92, 246, 0.1);
  animation: popupEnter 300ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes popupEnter {
  0% { opacity: 0; transform: scale(0.85) translateY(20px); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

.intent-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.intent-emoji {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.intent-title {
  font-size: var(--text-lg, 32rpx);
  font-weight: 600;
  color: var(--text-primary, rgba(255,255,255,0.92));
}

.intent-body {
  margin-bottom: 32rpx;
}

.intent-field {
  padding: 16rpx 0;
  border-bottom: 0.5px solid var(--border-subtle, rgba(255,255,255,0.06));
}

.intent-field:last-child {
  border-bottom: none;
}

.intent-field-label {
  font-size: var(--text-sm, 24rpx);
  color: var(--text-tertiary, rgba(255,255,255,0.40));
  display: inline;
}

.intent-field-value {
  font-size: var(--text-base, 28rpx);
  color: var(--text-primary, rgba(255,255,255,0.92));
  font-weight: 500;
  display: inline;
}

.intent-summary {
  font-size: var(--text-base, 28rpx);
  color: var(--text-secondary, rgba(255,255,255,0.65));
  line-height: 1.6;
  margin-top: 12rpx;
  display: block;
}

.intent-loader {
  text-align: center;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.loader-text {
  font-size: var(--text-base, 28rpx);
  color: var(--text-accent, #a78bfa);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

.intent-actions {
  display: flex;
  gap: 16rpx;
}

.btn-cancel {
  flex: 1;
  padding: 20rpx 0;
  background: var(--bg-glass-1, rgba(255,255,255,0.04));
  border-radius: 16rpx;
  font-size: var(--text-base, 28rpx);
  color: var(--text-secondary, rgba(255,255,255,0.65));
  border: 1px solid var(--border-subtle, rgba(255,255,255,0.06));
  text-align: center;
}

.btn-execute {
  flex: 1;
  padding: 20rpx 0;
  background: var(--gradient-cyan-purple, linear-gradient(135deg, #06b6d4, #8b5cf6));
  border-radius: 16rpx;
  font-size: var(--text-base, 28rpx);
  color: #fff;
  font-weight: 600;
  border: none;
  text-align: center;
}

/* ── 撤销条 ── */
.undo-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16px;
  background: rgba(15, 15, 19, 0.9);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 0.5px solid var(--border-subtle, rgba(255,255,255,0.06));
}

.undo-text {
  font-size: var(--text-sm, 24rpx);
  color: var(--text-tertiary, rgba(255,255,255,0.40));
}

.undo-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: var(--bg-glass-1, rgba(255,255,255,0.04));
  border-radius: 20rpx;
  border: 1px solid var(--border-subtle, rgba(255,255,255,0.06));
  transition: all 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.undo-btn:active {
  background: var(--bg-glass-2, rgba(255,255,255,0.07));
  transform: scale(0.96);
}

.undo-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.undo-label {
  font-size: var(--text-sm, 24rpx);
  color: var(--text-accent, #a78bfa);
  font-weight: 500;
}

/* ── 加载浮层 ── */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 150;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 64rpx;
  background: var(--bg-elevated, #0F0F13);
  border-radius: 24rpx;
  border: 1px solid var(--border-default, rgba(255,255,255,0.10));
}

.loading-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.loading-text {
  font-size: var(--text-base, 28rpx);
  color: var(--text-secondary, rgba(255,255,255,0.65));
}
