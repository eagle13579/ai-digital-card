# =============================================================================
# AI数智名片 — Docker Build Context Ignore List
# =============================================================================
# 排除文件，减小镜像体积，提升构建安全

# ── 版本控制 ───────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes
.gitmodules

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
*.whl

# ── 虚拟环境 ───────────────────────────────────────────────────────────────
.venv/
venv/
venv_new/
env/
.env/
*.venv

# ── 本地数据（不打包到镜像） ────────────────────────────────────────────────
data/
logs/
uploads/

# ── 配置（构建时通过 --env-file 或环境变量注入） ──────────────────────────────
.env
.env.*
*.local

# ── IDE / 编辑器 ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── 测试 / CI ──────────────────────────────────────────────────────────────
tests/
test_*.py
coverage/
htmlcov/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ── 文档 ───────────────────────────────────────────────────────────────────
*.md
*.rst
docs/

# ── 部署配置（docker-compose 等由编排层管理） ────────────────────────────────
deploy/
docker-compose*.yml

# ── 脚本（不打包到运行时镜像） ────────────────────────────────────────────────
scripts/
*.sh
*.bat

# ── 杂项 ───────────────────────────────────────────────────────────────────
nul
tmp/
temp/
*.log
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
