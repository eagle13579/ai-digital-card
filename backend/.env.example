# =============================================================================
# AI数智名片 — 后端环境变量配置模板
# =============================================================================
# 复制本文件为 .env 后填写真实值
#   cp .env.example .env
#
# 🔑 = 敏感密钥标记 — 这些值必须严格保密，切勿提交到版本控制系统
# ⚠️ = 生产环境建议使用环境变量或密钥管理服务
# =============================================================================

# ── 必填 ─────────────────────────────────────────────────────────────────────
# 🔑⚠️ JWT 签名密钥（256 位随机十六进制字符串）
# 生产环境务必使用强随机密钥： python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-256-bit-random-hex-key-here

# ── CORS ─────────────────────────────────────────────────────────────────────
# CORS 允许的来源（逗号分隔），生产环境只保留 https://liankebao.top 相关域名
CORS_ORIGINS=https://liankebao.top,https://api.liankebao.top,http://localhost:5173,http://localhost:8200

# ── 数据库 ───────────────────────────────────────────────────────────────────
# DATABASE_URL=sqlite+aiosqlite:///./data/digital_brochure.db
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/digital_brochure

# ── AI 能力 ──────────────────────────────────────────────────────────────────
# 🔑⚠️ DeepSeek API Key（必需供AI名片OCR+提取使用）
# DEEPSEEK_API_KEY=***
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# 🔑 Redis 密码（无密码留空）
# REDIS_PASSWORD=

# ═════════════════════════════════════════════════════════════════════════════
# 🔑 以下为敏感密钥区域 — 生产环境务必通过环境变量或密钥管理服务注入 🔑
# ═════════════════════════════════════════════════════════════════════════════

# ── CRM 集成 (Salesforce) ──────────────────────────────────────────────
# 🔑⚠️ Salesforce 凭据 — 全部缺失时自动降级为存根
# SF_INSTANCE_URL=https://your-instance.salesforce.com
# SF_CONSUMER_KEY=
# SF_CONSUMER_SECRET=
# SF_USERNAME=
# SF_PASSWORD=
# SF_SECURITY_TOKEN=

# ── CRM 集成 (HubSpot) ────────────────────────────────────────────────
# 🔑⚠️ HubSpot 凭据 — 缺失则降级存根
# HUBSPOT_ACCESS_TOKEN=
# HUBSPOT_BASE_URL=

# ── CRM 默认管道阶段配置 ──────────────────────────────────────────────
# CRM_DEFAULT_STAGES=[{"name":"潜在客户","color":"#d9d9d9","is_default":true},...]

# ── CRM 名片交换自动匹配 ─────────────────────────────────────────────
CRM_AUTO_MATCH_ON_EXCHANGE=true
CRM_AUTO_MATCH_ON_MATCH=true

# ── Sentry ───────────────────────────────────────────────────────────────────
# 🔑⚠️ Sentry DSN
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ── 邮件服务 (SMTP) ──────────────────────────────────────────────────────────
# 🔑⚠️ SMTP 凭据 — 全部缺失时自动降级为日志输出
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@aibizcard.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_USE_TLS=true
# SMTP_FROM=noreply@aibizcard.com
# SMTP_FROM_NAME=AI数智名片

# ── 日历集成 (Zoom) ────────────────────────────────────────────────────────
# 🔑⚠️ Zoom API 凭据 — 全部缺失时自动降级为日志输出
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_API_KEY=
# ZOOM_API_SECRET=

# ── 日历集成 (腾讯会议) ────────────────────────────────────────────────────
# 🔑⚠️ 腾讯会议凭据 — 全部缺失时自动降级为日志输出
# TENCENT_MEETING_APP_ID=
# TENCENT_MEETING_SDK_ID=
# TENCENT_MEETING_SECRET=

# ── 飞书集成 ────────────────────────────────────────────────────────────────
# 🔑⚠️ 飞书应用凭据 — 全部缺失时飞书机器人降级为日志输出
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# ═════════════════════════════════════════════════════════════════════════════
# 🔐 密钥加密配置 (SecretManager)
# ═════════════════════════════════════════════════════════════════════════════
# 生产环境通过此主密钥解密 .env.encrypted 中的真实密钥。
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_MASTER_KEY=your-256-bit-random-hex-key-here
