# AI数智名片 — 环境变量配置模板
# 复制本文件为 .env 并根据实际情况修改

# ── 必填 ─────────────────────────────────────────────────────────────────────
# JWT 签名密钥（256 位随机十六进制字符串）
# 生产环境务必使用强随机密钥： python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-256-bit-random-hex-key-here

# ── CORS ─────────────────────────────────────────────────────────────────────
# CORS 允许的来源（逗号分隔），生产环境只保留 https://liankebao.top 相关域名
CORS_ORIGINS=https://liankebao.top,https://api.liankebao.top,http://localhost:5173,http://localhost:8200

# ── 数据库 ───────────────────────────────────────────────────────────────────
# DATABASE_URL=sqlite+aiosqlite:///./data/digital_brochure.db
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/digital_brochure

# ── AI 能力 ──────────────────────────────────────────────────────────────────
# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ── Redis ────────────────────────────────────────────────────────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── CRM 集成 (Salesforce) ──────────────────────────────────────────────
# SF_* 是推荐前缀; SALESFORCE_* 向后兼容
# 全部缺失时自动降级为存根 (无需配置)
# SF_INSTANCE_URL=https://your-instance.salesforce.com
# SF_CONSUMER_KEY=
# SF_CONSUMER_SECRET=
# SF_USERNAME=
# SF_PASSWORD=
# SF_SECURITY_TOKEN=

# ── CRM 集成 (HubSpot) ────────────────────────────────────────────────
# HUBSPOT_ACCESS_TOKEN=       # Private App Token 或 OAuth Token
# HUBSPOT_BASE_URL=           # 可选，默认 https://api.hubapi.com/crm/v3

# ── CRM 默认管道阶段配置 ──────────────────────────────────────────────
# CRM_DEFAULT_STAGES 为 JSON 数组，用于初始化新用户的销售管道
# 可选值: 潜在客户, 初步接触, 需求确认, 方案/报价, 谈判中, 已成交, 已丢失
# 不配置时使用代码内置默认值
# CRM_DEFAULT_STAGES=[{"name":"潜在客户","color":"#d9d9d9","is_default":true},...]

# ── CRM 名片交换自动匹配 ─────────────────────────────────────────────
# CRM_AUTO_MATCH_ON_EXCHANGE=true   # 名片交换时自动创建/更新 CRM 联系人
# CRM_AUTO_MATCH_ON_MATCH=true      # 匹配引擎运行时自动创建 CRM 联系人

# ── Sentry ───────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ── 邮件服务 (SMTP) ──────────────────────────────────────────────────────────────
# 全部缺失时自动降级为日志输出 (无需配置即可正常运行)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@aibizcard.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_USE_TLS=true
# SMTP_FROM=noreply@aibizcard.com
# SMTP_FROM_NAME=AI数智名片
# 详细配置说明见 docs/ops/EMAIL_CONFIG.md

# ── 日历集成 (Zoom) ────────────────────────────────────────────────────────
# 推荐: Server-to-Server OAuth (ZOOM_ACCOUNT_ID + ZOOM_CLIENT_ID + ZOOM_CLIENT_SECRET)
# 向后兼容: ZOOM_API_KEY + ZOOM_API_SECRET (JWT)
# 全部缺失时自动降级为日志输出 (无需配置即可正常运行)
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_API_KEY=
# ZOOM_API_SECRET=
# 详细配置说明见 docs/integrations/CALENDAR_INTEGRATION.md

# ── 日历集成 (腾讯会议) ────────────────────────────────────────────────────
# TENCENT_MEETING_APP_ID + TENCENT_MEETING_SECRET 必须配对配置
# TENCENT_MEETING_SDK_ID 可选（默认同 App ID）
# 全部缺失时自动降级为日志输出 (无需配置即可正常运行)
# TENCENT_MEETING_APP_ID=
# TENCENT_MEETING_SDK_ID=
# TENCENT_MEETING_SECRET=
# 详细配置说明见 docs/integrations/CALENDAR_INTEGRATION.md
