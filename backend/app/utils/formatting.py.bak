"""
货币 / 日期 / 数字格式化工具。

优先使用 Babel 库进行 locale-aware 格式化；
Babel 不可用时回退到 locale 模块或纯手动实现。
"""

from __future__ import annotations

import locale as _locale
import math
from datetime import date, datetime
from typing import Optional

# ── 尝试导入 Babel ─────────────────────────────────────────────────────
try:
    import babel.numbers as _babel_numbers
    import babel.dates as _babel_dates

    _HAS_BABEL = True
except ImportError:
    _HAS_BABEL = False


# ── 语言代码 → locale 映射表 ────────────────────────────────────────────

LOCALE_MAP: dict[str, str] = {
    "zh": "zh_CN",
    "zh-cn": "zh_CN",
    "zh-CN": "zh_CN",
    "zh_hans": "zh_CN",
    "zh-Hans": "zh_CN",
    "zh-tw": "zh_TW",
    "zh-TW": "zh_TW",
    "zh_hk": "zh_HK",
    "zh-HK": "zh_HK",
    "en": "en_US",
    "en-us": "en_US",
    "en-US": "en_US",
    "en-gb": "en_GB",
    "en-GB": "en_GB",
    "ja": "ja_JP",
    "ja-jp": "ja_JP",
    "ja-JP": "ja_JP",
    "ko": "ko_KR",
    "ko-kr": "ko_KR",
    "ko-KR": "ko_KR",
    "fr": "fr_FR",
    "fr-fr": "fr_FR",
    "fr-FR": "fr_FR",
    "de": "de_DE",
    "de-de": "de_DE",
    "de-DE": "de_DE",
    "es": "es_ES",
    "es-es": "es_ES",
    "es-ES": "es_ES",
    "pt": "pt_BR",
    "pt-br": "pt_BR",
    "pt-BR": "pt_BR",
    "ru": "ru_RU",
    "ru-ru": "ru_RU",
    "ru-RU": "ru_RU",
    "ar": "ar_SA",
    "ar-sa": "ar_SA",
    "ar-SA": "ar_SA",
}

# ── 货币符号表 ─────────────────────────────────────────────────────────

CURRENCY_SYMBOLS: dict[str, str] = {
    "CNY": "¥",
    "USD": "$",
    "EUR": "€",
    "GBP": "£",
    "JPY": "¥",
    "KRW": "₩",
    "HKD": "HK$",
    "TWD": "NT$",
    "SGD": "S$",
    "AUD": "A$",
    "CAD": "C$",
    "INR": "₹",
    "RUB": "₽",
    "BRL": "R$",
}


def detect_locale_from_lang(lang_code: str) -> str:
    """语言代码到 locale 字符串的转换。

    Args:
        lang_code: 语言代码，如 ``"zh"``, ``"zh-CN"``, ``"en"``。

    Returns:
        对应的 locale 字符串，如 ``"zh_CN"``, ``"en_US"``。
        若无匹配则返回 ``"en_US"``。
    """
    return LOCALE_MAP.get(lang_code, "en_US")


# ── 货币格式化 ─────────────────────────────────────────────────────────


def format_currency(
    amount: float | int,
    currency: str = "CNY",
    locale: str = "zh-CN",
) -> str:
    """格式化货币金额。

    优先使用 Babel，不可用时手动格式化（千分位 + 货币符号）。

    Args:
        amount:   金额数值（元，非分）。
        currency: 货币代码，如 ``"CNY"``, ``"USD"``。
        locale:   locale 字符串，如 ``"zh-CN"``, ``"en-US"``。

    Returns:
        格式化后的货币字符串，如 ``"¥12,345.67"``。
    """
    if _HAS_BABEL:
        try:
            return _babel_numbers.format_currency(
                amount,
                currency,
                locale=detect_locale_from_lang(locale),
            )
        except Exception:
            pass  # fallthrough to manual

    return _manual_currency(amount, currency)


def _manual_currency(amount: float | int, currency: str) -> str:
    """手动格式化货币（千分位 + 货币符号）。"""
    symbol = CURRENCY_SYMBOLS.get(currency, currency)

    # 处理日元等无小数货币
    if currency in ("JPY", "KRW"):
        int_part = _thousands(int(round(amount)))
        return f"{symbol}{int_part}"

    formatted = _thousands(round(amount, 2))
    return f"{symbol}{formatted}"


# ── 日期格式化 ─────────────────────────────────────────────────────────

_DATE_STYLES: dict[str, str] = {
    "full": "%Y年%m月%d日 %A",
    "long": "%Y年%m月%d日",
    "medium": "%Y-%m-%d",
    "short": "%y-%m-%d",
}

_EN_DATE_STYLES: dict[str, str] = {
    "full": "%A, %B %d, %Y",
    "long": "%B %d, %Y",
    "medium": "%b %d, %Y",
    "short": "%m/%d/%y",
}


def format_date(
    dt: datetime | date | None,
    locale: str = "zh-CN",
    date_style: str = "medium",
) -> str:
    """格式化日期。

    优先使用 Babel，不可用时用 strftime 做简单格式化。

    Args:
        dt:         日期时间对象。若为 ``None`` 返回空字符串。
        locale:     语言 locale，如 ``"zh-CN"`` 或 ``"en-US"``。
        date_style: 日期详细程度。可选 ``"full"``, ``"long"``, ``"medium"``, ``"short"``。

    Returns:
        格式化后的日期字符串。
    """
    if dt is None:
        return ""

    # Babel 格式化
    if _HAS_BABEL:
        try:
            locale_str = detect_locale_from_lang(locale)
            return _babel_dates.format_date(dt, format=date_style, locale=locale_str)
        except Exception:
            pass

    # 手动回退
    is_chinese = locale.lower().startswith("zh")
    style_map = _DATE_STYLES if is_chinese else _EN_DATE_STYLES
    fmt = style_map.get(date_style, style_map["medium"])

    if isinstance(dt, datetime):
        return dt.strftime(fmt)
    return dt.strftime(fmt)


# ── 数字格式化 ─────────────────────────────────────────────────────────


def format_number(num: float | int, locale: str = "zh-CN") -> str:
    """格式化数字（千分位）。

    Args:
        num:    待格式化的数字。
        locale: locale 字符串。

    Returns:
        千分位格式的字符串，如 ``"12,345,678"``。
    """
    if _HAS_BABEL:
        try:
            return _babel_numbers.format_number(num, locale=detect_locale_from_lang(locale))
        except Exception:
            pass

    return _thousands(num)


# ── 内部工具函数 ─────────────────────────────────────────────────────


def _thousands(value: float | int | str) -> str:
    """添加千分位分隔符。"""
    if isinstance(value, str):
        value = float(value)

    # 分离整数部分和小数部分
    if isinstance(value, float) and not value.is_integer():
        str_val = f"{value:.2f}"
    else:
        str_val = str(int(value))

    if "." in str_val:
        int_part, dec_part = str_val.split(".")
    else:
        int_part, dec_part = str_val, ""

    # 只在整数部分加千分位（从左到右每3位加逗号）
    # 处理负号
    if int_part.startswith("-"):
        sign = "-"
        int_part = int_part[1:]
    else:
        sign = ""

    # 从右向左每 3 位插入逗号
    parts = []
    while len(int_part) > 3:
        parts.insert(0, int_part[-3:])
        int_part = int_part[:-3]
    parts.insert(0, int_part)

    result = sign + ",".join(parts)
    if dec_part:
        result += "." + dec_part
    return result
