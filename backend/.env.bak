# AI数智名片 API — 独立部署后端
# DeepSeek API Key (必需供AI名片OCR+提取使用)
DEEPSEEK_API_KEY=your-deepseek-api-key
# 数据库连接（PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///D:/AI数智名片/backend/data/digital_brochure.db
# JWT密钥
JWT_SECRET=change-this-to-a-secure-random-secret-key-ai-digital-card
# 链客宝桥接（可选）
CHAINKE_API_URL=http://localhost:8000
# 上传目录
UPLOAD_DIR=./uploads
# 向量搜索后端 (m3e | numpy | openai | deepseek)
EMBEDDING_PROVIDER=m3e
