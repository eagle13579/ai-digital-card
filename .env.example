# =============================================================================
# AI 数智名片 (AI Digital Business Card) — 环境变量配置模板
# =============================================================================
# 复制此文件为 .env 后填写真实值:
#   cp .env.example .env
#
# 🔑 = 敏感密钥标记 — 这些值必须严格保密，切勿提交到版本控制系统
# ⚠️ = 生产环境建议使用环境变量或密钥管理服务（如 Vault, AWS Secrets Manager）
# =============================================================================

# ── 应用基础 ────────────────────────────────────────────────────────────────
APP_NAME=AI数智名片
DATABASE_URL=sqlite+aiosqlite:///./data/digital_brochure.db
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/digital_brochure

# ── JWT 认证 ────────────────────────────────────────────────────────────────
# 🔑⚠️ JWT 签名密钥 — 生产环境使用 256 位随机密钥
# 生成: openssl rand -hex 32 或 python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-256-bit-key

# JWT 非对称签名（RS256，优先于 HS256）
JWT_ALGORITHM=RS256
RSA_PRIVATE_KEY_PATH=./data/jwt_rsa_private.pem
RSA_PUBLIC_KEY_PATH=./data/jwt_rsa_public.pem

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080          # 7 天 (60*24*7)

# ── AI 能力 ─────────────────────────────────────────────────────────────────
# 🔑⚠️ DeepSeek API 密钥
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ── 文件上传 ────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
VIDEO_MAX_SIZE=104857600                   # 100MB
VIDEO_ALLOWED_EXTENSIONS=mp4,webm
VIDEO_ALLOWED_MIME_TYPES=video/mp4,video/webm
VIDEO_UPLOAD_DIR=./uploads/videos

# ── 异步任务队列 ────────────────────────────────────────────────────────────
TASK_QUEUE_MAX_WORKERS=4
TASK_QUEUE_MAX_SIZE=0                      # 0 = 无限；生产环境建议设 1000

# ── Sentry 异常监控 ─────────────────────────────────────────────────────────
# 🔑⚠️ 从 https://sentry.io 获取 DSN
SENTRY_DSN=

# ── 外部集成 ────────────────────────────────────────────────────────────────
CHAINKE_API_URL=http://localhost:8000
CORS_ORIGINS=https://liankebao.top,https://api.liankebao.top,http://localhost:5173,http://localhost:8200
BASE_URL=http://localhost:8000             # 对外公开的基础 URL（前端地址）

# ── 链客宝会员桥接 ──────────────────────────────────────────────────────────
# 🔑⚠️ 调用链客宝 API 的认证令牌
CHAINKE_AUTH_TOKEN=
MEMBERSHIP_FREE_QUOTA=0
MEMBERSHIP_GOLD_QUOTA=20
MEMBERSHIP_DIAMOND_QUOTA=60
MEMBERSHIP_BOARD_QUOTA=200

# ═════════════════════════════════════════════════════════════════════════════
# 🔑 以下为敏感密钥区域 — 生产环境务必通过环境变量或密钥管理服务注入  🔑
# ═════════════════════════════════════════════════════════════════════════════

# ── 微信小程序 ──────────────────────────────────────────────────────────────
WECHAT_MINI_APPID=                         # 🔑 微信小程序 AppID
WECHAT_MINI_SECRET=                        # 🔑⚠️ 微信小程序 AppSecret

# ── 微信支付 ────────────────────────────────────────────────────────────────
WECHAT_MCH_ID=                             # 🔑 微信商户号
WECHAT_PAY_API_KEY=                        # 🔑⚠️ 微信支付 API V2 密钥
WECHAT_PAY_V3_KEY=                         # 🔑⚠️ 微信支付 API V3 密钥

# ── 支付宝 ──────────────────────────────────────────────────────────────────
ALIPAY_APP_ID=                             # 🔑 支付宝应用ID
ALIPAY_PRIVATE_KEY=                        # 🔑⚠️ 支付宝应用私钥
ALIPAY_PUBLIC_KEY=                         # 🔑 支付宝公钥

# ── 向量搜索 / Embedding ────────────────────────────────────────────────────
USE_VECTOR_SEARCH=true
USE_HYDE=true                              # 是否启用 HyDE 检索增强
EMBEDDING_PROVIDER=m3e                     # m3e | numpy | openai | deepseek
EMBEDDING_DIM=768                          # m3e=768, openai 3-small=1536, deepseek=1024
# 🔑 API Key（本地 m3e 不需要，OpenAI/DeepSeek 需要）
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
VECTOR_TOP_K=50

# ── Redis 缓存 ──────────────────────────────────────────────────────────────
REDIS_HOST=localhost                       # docker 中为 redis
REDIS_PORT=6379
REDIS_DB=0
# 🔑 Redis 密码（无密码留空）
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20
REDIS_CACHE_TTL=300                        # 默认缓存过期时间（秒）

# ── SSO / OAuth2 ────────────────────────────────────────────────────────────
# 🔑⚠️ Google OAuth2
SSO_GOOGLE_CLIENT_ID=
SSO_GOOGLE_CLIENT_SECRET=
# 🔑⚠️ GitHub OAuth2
SSO_GITHUB_CLIENT_ID=
SSO_GITHUB_CLIENT_SECRET=

# ── 企业 OIDC ───────────────────────────────────────────────────────────────
# 🔑⚠️ 企业 OIDC 集成
SSO_OIDC_AUTHORIZE_URL=
SSO_OIDC_TOKEN_URL=
SSO_OIDC_USERINFO_URL=
SSO_OIDC_CLIENT_ID=
SSO_OIDC_CLIENT_SECRET=
SSO_OIDC_SCOPES=openid,email,profile

# ── 邮件服务 (SMTP) ─────────────────────────────────────────────────────────
# 🔑⚠️ SMTP 凭据 — 全部缺失时自动降级为日志输出
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=noreply@aibizcard.com
SMTP_FROM_NAME=AI数智名片

# ── IM 机器人 (Slack) ───────────────────────────────────────────────────────
# 🔑⚠️ Slack Bot Token
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── IM 机器人 (飞书) ────────────────────────────────────────────────────────
# 🔑⚠️ 飞书应用凭据 — 为空则降级到日志输出
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_NAME=AI数字名片助手

# ── IM 机器人 (钉钉) ────────────────────────────────────────────────────────
# 🔑⚠️ 钉钉机器人凭据 — 为空则降级到日志输出
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# ── 日历集成 (Zoom) ─────────────────────────────────────────────────────────
# 🔑⚠️ Zoom API 凭据 — 全部缺失时自动降级为日志输出
# 推荐: Server-to-Server OAuth
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# 向后兼容: JWT
ZOOM_API_KEY=
ZOOM_API_SECRET=

# ── 日历集成 (腾讯会议) ─────────────────────────────────────────────────────
# 🔑⚠️ 腾讯会议凭据 — 全部缺失时自动降级为日志输出
TENCENT_MEETING_APP_ID=
TENCENT_MEETING_SDK_ID=
TENCENT_MEETING_SECRET=
# 向后兼容
TENCENT_WECHAT_APP_ID=
TENCENT_WECHAT_SECRET=

# ── CRM 集成 (Salesforce) ──────────────────────────────────────────────────
# 🔑⚠️ Salesforce 凭据 — 全部缺失时自动降级为存根
# SF_INSTANCE_URL=https://your-instance.salesforce.com
# SF_CONSUMER_KEY=
# SF_CONSUMER_SECRET=
# SF_USERNAME=
# SF_PASSWORD=
# SF_SECURITY_TOKEN=

# ── CRM 集成 (HubSpot) ─────────────────────────────────────────────────────
# 🔑⚠️ HubSpot 凭据 — 缺失则降级存根
# HUBSPOT_ACCESS_TOKEN=
# HUBSPOT_BASE_URL=

# ── CRM 管道与自动匹配 ──────────────────────────────────────────────────────
# CRM_DEFAULT_STAGES=
CRM_AUTO_MATCH_ON_EXCHANGE=true
CRM_AUTO_MATCH_ON_MATCH=true
