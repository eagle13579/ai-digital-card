# ================================================================
# AI 数智名片 (AI Digital Business Card) — 环境变量配置
# ================================================================
# 复制此文件为 .env (或 .env.production) 后填写真实值
#   cp .env.example .env
# ================================================================

# ── 应用基础 ────────────────────────────────────────────────────────
APP_NAME=AI数智名片
DATABASE_URL=sqlite+aiosqlite:///./data/digital_brochure.db

# !! 必须修改 !! 生产环境使用 256 位随机密钥
# 生成: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-256-bit-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080          # 7 天 (60*24*7)

# ── AI 能力 ─────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ── 文件上传 ────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── 视频上传 ────────────────────────────────────────────────────────
VIDEO_MAX_SIZE=104857600                   # 100MB
VIDEO_ALLOWED_EXTENSIONS=mp4,webm
VIDEO_ALLOWED_MIME_TYPES=video/mp4,video/webm
VIDEO_UPLOAD_DIR=./uploads/videos

# ── Sentry 异常监控 ─────────────────────────────────────────────────
# 从 https://sentry.io 获取 DSN
SENTRY_DSN=

# ── 外部集成 ────────────────────────────────────────────────────────
CHAINKE_API_URL=http://localhost:8000
CORS_ORIGINS=https://liankebao.top,https://api.liankebao.top,http://localhost:5173,http://localhost:8200

# ── 链客宝会员桥接 ──────────────────────────────────────────────────
CHAINKE_AUTH_TOKEN=
MEMBERSHIP_FREE_QUOTA=0
MEMBERSHIP_GOLD_QUOTA=20
MEMBERSHIP_DIAMOND_QUOTA=60
MEMBERSHIP_BOARD_QUOTA=200

# ── 微信小程序 ──────────────────────────────────────────────────────
WECHAT_MINI_APPID=
WECHAT_MINI_SECRET=

# ── 微信支付 ────────────────────────────────────────────────────────
WECHAT_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_V3_KEY=

# ── 支付宝 ──────────────────────────────────────────────────────────
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# ── 向量搜索 ────────────────────────────────────────────────────────
USE_VECTOR_SEARCH=true
EMBEDDING_PROVIDER=m3e                   # m3e | numpy | openai | deepseek
EMBEDDING_DIM=768                        # m3e=768, openai 3-small=1536, deepseek=1024
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
VECTOR_TOP_K=50

# ── Redis 缓存 ──────────────────────────────────────────────────────
REDIS_HOST=localhost                     # docker 中为 redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20
REDIS_CACHE_TTL=300                      # 默认缓存过期时间（秒）

# ── CRM 集成 (Salesforce) ──────────────────────────────────────────────
# SF_* 是推荐前缀; SALESFORCE_* 向后兼容
# 全部缺失时自动降级为存根 (无需配置，静默降级)
# 配置指引: docs/operations/CRM_SETUP_SOP.md 第2节
# SF_INSTANCE_URL=https://your-instance.salesforce.com    # 实例 URL (必需)
# SF_CONSUMER_KEY=                                        # Connected App Consumer Key (必需)
# SF_CONSUMER_SECRET=                                     # Connected App Consumer Secret (必需)
# SF_USERNAME=                                            # API 专用账号邮箱 (必需)
# SF_PASSWORD=                                            # 账号密码 (必需)
# SF_SECURITY_TOKEN=                                      # 安全令牌 (可选，增强安全)

# ── CRM 集成 (HubSpot) ────────────────────────────────────────────────
# 配置指引: docs/operations/CRM_SETUP_SOP.md 第3节
# HUBSPOT_ACCESS_TOKEN=       # Private App Token 或 OAuth Token (必需，缺失则降级存根)
# HUBSPOT_BASE_URL=           # 可选，默认 https://api.hubapi.com/crm/v3

# ── CRM 管道与自动匹配 ────────────────────────────────────────────────
# CRM_DEFAULT_STAGES=         # JSON 数组，初始化销售管道阶段（可选，使用代码内置默认）
# CRM_AUTO_MATCH_ON_EXCHANGE=true   # 名片交换时自动创建/更新 CRM 联系人
# CRM_AUTO_MATCH_ON_MATCH=true      # 匹配引擎运行时自动创建 CRM 联系人

# ── 分享 ────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000           # 对外公开的基础 URL（前端地址）

# ── SSO / OAuth2 ───────────────────────────────────────────────────
SSO_GOOGLE_CLIENT_ID=
SSO_GOOGLE_CLIENT_SECRET=
SSO_GITHUB_CLIENT_ID=
SSO_GITHUB_CLIENT_SECRET=

# ── 企业 OIDC ───────────────────────────────────────────────────────
SSO_OIDC_AUTHORIZE_URL=
SSO_OIDC_TOKEN_URL=
SSO_OIDC_USERINFO_URL=
SSO_OIDC_CLIENT_ID=
SSO_OIDC_CLIENT_SECRET=
SSO_OIDC_SCOPES=openid,email,profile
