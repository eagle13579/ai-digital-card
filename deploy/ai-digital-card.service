[Unit]
Description=AI数字名片 Backend
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/ai-digital-card/backend
ExecStart=/var/www/ai-digital-card/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8201 --workers 2 --log-level info
Restart=always
RestartSec=5
EnvironmentFile=/var/www/ai-digital-card/backend/.env

[Install]
WantedBy=multi-user.target
