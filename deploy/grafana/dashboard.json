{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "2.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [ { "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" }, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" } ] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "tags": ["ai-card", "observability"],
  "title": "AI数字名片 — 可观测性仪表盘",
  "uid": "ai-card-observability",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "HTTP RPS & 错误率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20, "stacking": { "mode": "none" }, "axisPlacement": "auto", "axisLabel": "RPS", "showPoints": "never" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0 } ] },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "错误率" }, "properties": [ { "id": "unit", "value": "percentunit" }, { "id": "custom.axisPlacement", "value": "right" }, { "id": "custom.axisLabel", "value": "错误率" }, { "id": "color", "value": { "fixed": "red" } } ] }
        ]
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum(rate(ncard_http_requests_total[1m]))", "legendFormat": "总RPS", "refId": "A" },
        { "expr": "sum(rate(ncard_http_requests_total{status=~\"5..\"}[1m])) / sum(rate(ncard_http_requests_total[1m]))", "legendFormat": "错误率", "refId": "B" }
      ]
    },
    {
      "id": 2,
      "title": "请求延迟 (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "axisPlacement": "auto", "axisLabel": "延迟", "showPoints": "never" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1.0 }, { "color": "red", "value": 2.0 } ] },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P99" }, "properties": [ { "id": "color", "value": { "fixed": "red" } }, { "id": "custom.lineWidth", "value": 3 } ] },
          { "matcher": { "id": "byName", "options": "P95" }, "properties": [ { "id": "color", "value": { "fixed": "orange" } } ] },
          { "matcher": { "id": "byName", "options": "P50" }, "properties": [ { "id": "color", "value": { "fixed": "green" } } ] }
        ]
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(ncard_http_request_duration_seconds_bucket[1m])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(ncard_http_request_duration_seconds_bucket[1m])) by (le))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(ncard_http_request_duration_seconds_bucket[1m])) by (le))", "legendFormat": "P99", "refId": "C" }
      ]
    },
    {
      "id": 3,
      "title": "数据库查询耗时 & 慢查询",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 15, "axisPlacement": "auto", "axisLabel": "查询耗时", "showPoints": "never" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 1.0 } ] },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "慢查询计数" }, "properties": [ { "id": "unit", "value": "cps" }, { "id": "custom.axisPlacement", "value": "right" }, { "id": "custom.axisLabel", "value": "慢查询/s" }, { "id": "color", "value": { "fixed": "purple" } }, { "id": "custom.lineWidth", "value": 2 } ] }
        ]
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(ncard_db_query_duration_seconds_bucket[1m])) by (le))", "legendFormat": "DB P95耗时", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum(rate(ncard_db_query_duration_seconds_bucket[1m])) by (le))", "legendFormat": "DB P99耗时", "refId": "B" },
        { "expr": "rate(ncard_db_slow_queries_total[1m])", "legendFormat": "慢查询计数", "refId": "C" }
      ]
    },
    {
      "id": 4,
      "title": "活跃用户数",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20, "axisPlacement": "auto", "axisLabel": "用户数", "showPoints": "never", "stacking": { "mode": "none" } },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom", "calcs": ["mean", "max", "last"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "ncard_active_users_total", "legendFormat": "活跃用户", "refId": "A" },
        { "expr": "sum(ncard_http_requests_total{status=~\"2..\"}[5m]) / 300", "legendFormat": "5min平均活跃(估算)", "refId": "B" }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"] },
  "templating": {
    "list": [
      {
        "current": { "text": "Prometheus", "selected": false },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  }
}
