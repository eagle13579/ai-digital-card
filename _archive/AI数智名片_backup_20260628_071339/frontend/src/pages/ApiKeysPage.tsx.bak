import { useState, useEffect, useCallback } from 'react';
import { api } from '../api/client';
import { Key, Plus, Trash2, AlertTriangle, Copy, Check, X, BarChart3, RefreshCw } from 'lucide-react';

// ============================================================
// Types
// ============================================================
interface ApiKeyItem {
  id: number;
  masked_key: string;
  name: string;
  permissions: string[];
  rate_limit: number;
  is_active: boolean;
  last_used_at: string | null;
  created_at: string;
}

interface ApiKeyCreateResult {
  id: number;
  key: string;
  name: string;
  permissions: string[];
  rate_limit: number;
  is_active: boolean;
  created_at: string;
  warning: string;
}

interface ApiKeyUsageItem {
  key_id: number;
  key_name: string;
  date: string;
  request_count: number;
}

interface ApiKeyUsageResponse {
  usage: ApiKeyUsageItem[];
  total: number;
}

// ============================================================
// 创建弹窗
// ============================================================
function CreateKeyModal({
  open,
  onClose,
  onCreated,
}: {
  open: boolean;
  onClose: () => void;
  onCreated: () => void;
}) {
  const [name, setName] = useState('');
  const [rateLimit, setRateLimit] = useState(1000);
  const [creating, setCreating] = useState(false);
  const [result, setResult] = useState<ApiKeyCreateResult | null>(null);
  const [copied, setCopied] = useState(false);
  const [error, setError] = useState('');

  const handleCreate = async () => {
    setCreating(true);
    setError('');
    const res = await api.post<ApiKeyCreateResult>('/api/api-keys', {
      name: name || '默认 Key',
      permissions: ['read'],
      rate_limit: rateLimit,
    });
    setCreating(false);
    if (res.code === 201 || (res.data && (res.data as any).key)) {
      setResult(res.data as ApiKeyCreateResult);
    } else {
      setError(res.message || '创建失败，请重试');
    }
  };

  const handleCopy = async () => {
    if (result?.key) {
      try {
        await navigator.clipboard.writeText(result.key);
        setCopied(true);
        setTimeout(() => setCopied(false), 2000);
      } catch {
        // fallback
        const ta = document.createElement('textarea');
        ta.value = result.key;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        setCopied(true);
        setTimeout(() => setCopied(false), 2000);
      }
    }
  };

  const handleClose = () => {
    if (result) {
      setResult(null);
      setName('');
      setRateLimit(1000);
      setCopied(false);
      setError('');
      onClose();
      onCreated();
    } else {
      setResult(null);
      setName('');
      setRateLimit(1000);
      setCopied(false);
      setError('');
      onClose();
    }
  };

  if (!open) return null;

  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/30 backdrop-blur-sm">
      <div className="bg-white rounded-2xl shadow-2xl max-w-md w-full mx-4 overflow-hidden">
        <div className="flex items-center justify-between px-6 py-4 border-b border-border-light">
          <h2 className="text-lg font-bold text-on-surface">
            {result ? 'API Key 已创建' : '创建新的 API Key'}
          </h2>
          <button onClick={handleClose} className="p-1 rounded-lg hover:bg-slate-100 text-text-muted">
            <X className="w-5 h-5" />
          </button>
        </div>

        <div className="px-6 py-4 space-y-4">
          {result ? (
            <>
              <div className="flex items-start gap-3 p-3 bg-amber-50 border border-amber-200 rounded-xl">
                <AlertTriangle className="w-5 h-5 text-amber-600 shrink-0 mt-0.5" />
                <p className="text-sm text-amber-700">
                  {result.warning}
                </p>
              </div>

              <div>
                <label className="block text-sm font-medium text-text-muted mb-1">API Key</label>
                <div className="relative">
                  <input
                    type="text"
                    readOnly
                    value={result.key}
                    className="w-full px-3 py-2.5 pr-12 bg-slate-50 border border-border-light rounded-xl text-sm font-mono text-on-surface"
                  />
                  <button
                    onClick={handleCopy}
                    className="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 rounded-lg hover:bg-slate-200 text-text-muted"
                    title="复制"
                  >
                    {copied ? <Check className="w-4 h-4 text-green-600" /> : <Copy className="w-4 h-4" />}
                  </button>
                </div>
              </div>

              <div className="grid grid-cols-2 gap-3">
                <div className="p-3 bg-slate-50 rounded-xl">
                  <div className="text-xs text-text-muted">名称</div>
                  <div className="text-sm font-medium text-on-surface truncate">{result.name}</div>
                </div>
                <div className="p-3 bg-slate-50 rounded-xl">
                  <div className="text-xs text-text-muted">速率限制</div>
                  <div className="text-sm font-medium text-on-surface">{result.rate_limit}/小时</div>
                </div>
              </div>
            </>
          ) : (
            <>
              {error && (
                <div className="p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700">
                  {error}
                </div>
              )}

              <div>
                <label className="block text-sm font-medium text-text-muted mb-1">名称</label>
                <input
                  type="text"
                  value={name}
                  onChange={(e) => setName(e.target.value)}
                  placeholder="例如：生产环境 Key"
                  className="w-full px-3 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
                />
              </div>

              <div>
                <label className="block text-sm font-medium text-text-muted mb-1">
                  速率限制（请求/小时）
                </label>
                <input
                  type="number"
                  value={rateLimit}
                  onChange={(e) => setRateLimit(Number(e.target.value))}
                  min={1}
                  max={10000}
                  className="w-full px-3 py-2.5 border border-border-light rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
                />
              </div>

              <div className="p-3 bg-blue-50 border border-blue-200 rounded-xl text-sm text-blue-700">
                <p className="font-medium mb-1">权限说明</p>
                <p>当前仅支持 read 权限。创建后请立即保存 Key，它只会显示一次。</p>
              </div>
            </>
          )}
        </div>

        <div className="px-6 py-4 border-t border-border-light flex justify-end gap-3">
          {result ? (
            <button
              onClick={handleClose}
              className="px-6 py-2.5 bg-primary text-white rounded-xl text-sm font-medium hover:bg-primary/90 transition-colors"
            >
              我已完成保存
            </button>
          ) : (
            <>
              <button
                onClick={handleClose}
                className="px-4 py-2.5 text-text-muted hover:text-on-surface text-sm font-medium transition-colors"
              >
                取消
              </button>
              <button
                onClick={handleCreate}
                disabled={creating}
                className="px-6 py-2.5 bg-primary text-white rounded-xl text-sm font-medium hover:bg-primary/90 disabled:opacity-50 transition-colors flex items-center gap-2"
              >
                {creating ? (
                  <>
                    <RefreshCw className="w-4 h-4 animate-spin" />
                    创建中...
                  </>
                ) : (
                  <>
                    <Plus className="w-4 h-4" />
                    创建 Key
                  </>
                )}
              </button>
            </>
          )}
        </div>
      </div>
    </div>
  );
}

// ============================================================
// 吊销确认弹窗
// ============================================================
function RevokeModal({
  item,
  open,
  onClose,
  onRevoked,
}: {
  item: ApiKeyItem | null;
  open: boolean;
  onClose: () => void;
  onRevoked: () => void;
}) {
  const [revoking, setRevoking] = useState(false);

  const handleRevoke = async () => {
    if (!item) return;
    setRevoking(true);
    await api.delete(`/api/api-keys/${item.id}`);
    setRevoking(false);
    onRevoked();
    onClose();
  };

  if (!open || !item) return null;

  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/30 backdrop-blur-sm">
      <div className="bg-white rounded-2xl shadow-2xl max-w-sm w-full mx-4 overflow-hidden">
        <div className="flex items-center justify-between px-6 py-4 border-b border-border-light">
          <h2 className="text-lg font-bold text-on-surface">吊销 API Key</h2>
          <button onClick={onClose} className="p-1 rounded-lg hover:bg-slate-100 text-text-muted">
            <X className="w-5 h-5" />
          </button>
        </div>

        <div className="px-6 py-4">
          <div className="flex items-start gap-3 p-3 bg-red-50 border border-red-200 rounded-xl">
            <AlertTriangle className="w-5 h-5 text-red-600 shrink-0 mt-0.5" />
            <div className="text-sm text-red-700">
              <p className="font-medium mb-1">确定要吊销此 API Key？</p>
              <p className="text-xs text-red-600/80">
                Key: {item.masked_key}<br />
                名称: {item.name}
              </p>
              <p className="mt-2">此操作不可撤销，使用该 Key 的应用将立即失去访问权限。</p>
            </div>
          </div>
        </div>

        <div className="px-6 py-4 border-t border-border-light flex justify-end gap-3">
          <button
            onClick={onClose}
            className="px-4 py-2.5 text-text-muted hover:text-on-surface text-sm font-medium transition-colors"
          >
            取消
          </button>
          <button
            onClick={handleRevoke}
            disabled={revoking}
            className="px-6 py-2.5 bg-red-600 text-white rounded-xl text-sm font-medium hover:bg-red-700 disabled:opacity-50 transition-colors flex items-center gap-2"
          >
            {revoking ? (
              <>
                <RefreshCw className="w-4 h-4 animate-spin" />
                吊销中...
              </>
            ) : (
              <>
                <Trash2 className="w-4 h-4" />
                确认吊销
              </>
            )}
          </button>
        </div>
      </div>
    </div>
  );
}

// ============================================================
// 用量图表（简易柱状图）
// ============================================================
function UsageChart({ usage }: { usage: ApiKeyUsageItem[] }) {
  if (!usage || usage.length === 0) {
    return (
      <div className="text-center py-8 text-text-muted text-sm">
        暂无用量数据
      </div>
    );
  }

  // 按 key 分组
  const byKey: Record<string, { name: string; data: { date: string; count: number }[] }> = {};
  for (const item of usage) {
    const key = `${item.key_id}`;
    if (!byKey[key]) byKey[key] = { name: item.key_name, data: [] };
    byKey[key].data.push({ date: item.date, count: item.request_count });
  }

  const maxCount = Math.max(...usage.map((u) => u.request_count), 1);

  return (
    <div className="space-y-6">
      {Object.entries(byKey).map(([keyId, group]) => (
        <div key={keyId}>
          <h4 className="text-sm font-medium text-on-surface mb-2">{group.name}</h4>
          <div className="space-y-1">
            {group.data.map((d) => (
              <div key={d.date} className="flex items-center gap-3">
                <span className="text-xs text-text-muted w-24 shrink-0">{d.date}</span>
                <div className="flex-1 bg-slate-100 rounded-full h-5 overflow-hidden">
                  <div
                    className="h-full bg-gradient-to-r from-primary to-purple-500 rounded-full transition-all duration-500"
                    style={{ width: `${(d.count / maxCount) * 100}%` }}
                  />
                </div>
                <span className="text-xs font-medium text-text-muted w-12 text-right">
                  {d.count}
                </span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  );
}

// ============================================================
// 主组件
// ============================================================
export default function ApiKeysPage() {
  const [keys, setKeys] = useState<ApiKeyItem[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState('');
  const [showCreate, setShowCreate] = useState(false);
  const [revokeTarget, setRevokeTarget] = useState<ApiKeyItem | null>(null);
  const [showUsage, setShowUsage] = useState(false);
  const [usageData, setUsageData] = useState<ApiKeyUsageResponse | null>(null);
  const [usageDays, setUsageDays] = useState(7);
  const [usageLoading, setUsageLoading] = useState(false);

  const loadKeys = useCallback(async () => {
    setLoading(true);
    setError('');
    const res = await api.get<ApiKeyItem[]>('/api/api-keys');
    if (res.code === 200 && res.data) {
      setKeys(res.data);
    } else {
      setError(res.message || '加载失败');
    }
    setLoading(false);
  }, []);

  const loadUsage = useCallback(async (days: number) => {
    setUsageLoading(true);
    const res = await api.get<ApiKeyUsageResponse>(`/api/api-keys/usage?days=${days}`);
    if (res.code === 200 && res.data) {
      setUsageData(res.data);
    }
    setUsageLoading(false);
  }, []);

  useEffect(() => {
    loadKeys();
  }, [loadKeys]);

  const handleToggleUsage = () => {
    if (!showUsage) {
      loadUsage(usageDays);
    }
    setShowUsage(!showUsage);
  };

  return (
    <div className="max-w-4xl mx-auto space-y-6">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold text-on-surface">API Key 管理</h1>
          <p className="text-sm text-text-muted mt-1">
            管理你的 API 访问密钥，对接第三方应用和服务
          </p>
        </div>
        <div className="flex items-center gap-3">
          <button
            onClick={handleToggleUsage}
            className="px-4 py-2.5 border border-border-light rounded-xl text-sm font-medium text-text-muted hover:text-on-surface hover:bg-slate-50 transition-colors flex items-center gap-2"
          >
            <BarChart3 className="w-4 h-4" />
            {showUsage ? '隐藏用量' : '查看用量'}
          </button>
          <button
            onClick={() => setShowCreate(true)}
            className="px-4 py-2.5 bg-primary text-white rounded-xl text-sm font-medium hover:bg-primary/90 transition-colors flex items-center gap-2"
          >
            <Plus className="w-4 h-4" />
            创建 Key
          </button>
        </div>
      </div>

      {/* Error */}
      {error && (
        <div className="p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 flex items-center gap-2">
          <AlertTriangle className="w-4 h-4 shrink-0" />
          {error}
          <button onClick={loadKeys} className="ml-auto text-red-600 hover:text-red-800 underline text-xs">
            重试
          </button>
        </div>
      )}

      {/* Usage section */}
      {showUsage && (
        <div className="bg-white rounded-2xl border border-border-light p-6">
          <div className="flex items-center justify-between mb-4">
            <h3 className="text-base font-bold text-on-surface flex items-center gap-2">
              <BarChart3 className="w-5 h-5 text-primary" />
              用量统计
            </h3>
            <div className="flex items-center gap-2">
              <span className="text-sm text-text-muted">近</span>
              <select
                value={usageDays}
                onChange={(e) => {
                  const d = Number(e.target.value);
                  setUsageDays(d);
                  loadUsage(d);
                }}
                className="px-2 py-1 border border-border-light rounded-lg text-sm"
              >
                <option value={7}>7 天</option>
                <option value={14}>14 天</option>
                <option value={30}>30 天</option>
              </select>
            </div>
          </div>

          {usageLoading ? (
            <div className="text-center py-8">
              <RefreshCw className="w-6 h-6 animate-spin mx-auto text-text-muted" />
              <p className="text-sm text-text-muted mt-2">加载中...</p>
            </div>
          ) : (
            <>
              <div className="text-right mb-4">
                <span className="text-sm text-text-muted">总请求数: </span>
                <span className="text-lg font-bold text-on-surface">{usageData?.total ?? 0}</span>
              </div>
              <UsageChart usage={usageData?.usage ?? []} />
            </>
          )}
        </div>
      )}

      {/* API Keys list */}
      <div className="bg-white rounded-2xl border border-border-light overflow-hidden">
        <div className="px-6 py-4 border-b border-border-light flex items-center justify-between">
          <h3 className="text-base font-bold text-on-surface flex items-center gap-2">
            <Key className="w-5 h-5 text-primary" />
            我的 API Keys
          </h3>
          <span className="text-xs text-text-muted bg-slate-100 px-2 py-1 rounded-lg">
            {keys.length} 个密钥
          </span>
        </div>

        {loading ? (
          <div className="p-8 text-center">
            <RefreshCw className="w-6 h-6 animate-spin mx-auto text-text-muted" />
            <p className="text-sm text-text-muted mt-2">加载中...</p>
          </div>
        ) : keys.length === 0 ? (
          <div className="p-8 text-center">
            <Key className="w-12 h-12 mx-auto text-text-muted/30 mb-3" />
            <p className="text-sm text-text-muted">还没有 API Key</p>
            <p className="text-xs text-text-muted/60 mt-1">创建第一个 Key 来开始集成</p>
          </div>
        ) : (
          <div className="divide-y divide-border-light">
            {keys.map((key) => (
              <div key={key.id} className="px-6 py-4 flex items-center gap-4 hover:bg-slate-50/50 transition-colors">
                <div className={`w-2 h-2 rounded-full shrink-0 ${key.is_active ? 'bg-green-500' : 'bg-red-400'}`} />
                <div className="flex-1 min-w-0">
                  <div className="flex items-center gap-2">
                    <span className="text-sm font-medium text-on-surface">{key.name}</span>
                    {!key.is_active && (
                      <span className="text-xs bg-red-50 text-red-600 px-1.5 py-0.5 rounded-lg">已吊销</span>
                    )}
                  </div>
                  <div className="flex items-center gap-3 mt-1">
                    <code className="text-xs font-mono text-text-muted bg-slate-100 px-2 py-0.5 rounded">
                      {key.masked_key}
                    </code>
                    <span className="text-xs text-text-muted">
                      {key.rate_limit}/时
                    </span>
                    <span className="text-xs text-text-muted">
                      {key.permissions.join(', ')}
                    </span>
                  </div>
                  <div className="text-xs text-text-muted/60 mt-1">
                    {key.last_used_at
                      ? `最后使用: ${new Date(key.last_used_at).toLocaleString('zh-CN')}`
                      : '从未使用'}
                    {' · '}
                    创建于 {new Date(key.created_at).toLocaleDateString('zh-CN')}
                  </div>
                </div>
                {key.is_active && (
                  <button
                    onClick={() => setRevokeTarget(key)}
                    className="p-2 rounded-xl text-text-muted hover:text-red-600 hover:bg-red-50 transition-colors"
                    title="吊销"
                  >
                    <Trash2 className="w-4 h-4" />
                  </button>
                )}
              </div>
            ))}
          </div>
        )}
      </div>

      {/* Modals */}
      <CreateKeyModal
        open={showCreate}
        onClose={() => setShowCreate(false)}
        onCreated={loadKeys}
      />
      <RevokeModal
        item={revokeTarget}
        open={!!revokeTarget}
        onClose={() => setRevokeTarget(null)}
        onRevoked={loadKeys}
      />
    </div>
  );
}
