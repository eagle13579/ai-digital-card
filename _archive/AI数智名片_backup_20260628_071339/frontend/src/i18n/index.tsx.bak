import React, { createContext, useContext, useState, useCallback, useEffect, useMemo } from 'react';
import zh from './zh';
import en from './en';
import ja from './ja';
import ko from './ko';
import es from './es';
import fr from './fr';
import de from './de';
import pt from './pt';
import ru from './ru';
import ar from './ar';
import th from './th';
import vi from './vi';

// ============================================================
// 语言包类型
// ============================================================
type LangPack = Record<string, string>;

// 支持的语言列表
export const SUPPORTED_LOCALES = [
  'zh', 'en', 'ja', 'ko', 'es', 'fr', 'de', 'pt', 'ru', 'ar', 'th', 'vi',
] as const;
export type SupportedLocale = (typeof SUPPORTED_LOCALES)[number];

const packs: Record<SupportedLocale, LangPack> = {
  zh, en, ja, ko, es, fr, de, pt, ru, ar, th, vi,
};

// 语言显示名称映射
export const LOCALE_LABELS: Record<SupportedLocale, string> = {
  zh: '中文',
  en: 'English',
  ja: '日本語',
  ko: '한국어',
  es: 'Español',
  fr: 'Français',
  de: 'Deutsch',
  pt: 'Português',
  ru: 'Русский',
  ar: 'العربية',
  th: 'ไทย',
  vi: 'Tiếng Việt',
};

// 语言对应的 html lang 属性
const LOCALE_HTML_LANG: Record<SupportedLocale, string> = {
  zh: 'zh-CN',
  en: 'en',
  ja: 'ja',
  ko: 'ko',
  es: 'es',
  fr: 'fr',
  de: 'de',
  pt: 'pt',
  ru: 'ru',
  ar: 'ar',
  th: 'th',
  vi: 'vi',
};

// ============================================================
// 简单模板插值: t('card.viewCount', { n: 42 })
// ============================================================
function interpolate(template: string, vars?: Record<string, string | number>): string {
  if (!vars) return template;
  return template.replace(/\{(\w+)\}/g, (_, key) => {
    const val = vars[key];
    return val != null ? String(val) : `{${key}}`;
  });
}

// ============================================================
// 检测浏览器语言
// ============================================================
function detectBrowserLang(): SupportedLocale {
  if (typeof navigator === 'undefined') return 'zh';
  const lang = navigator.language || (navigator as any).userLanguage || '';
  const short = lang.slice(0, 2);
  if (short === 'zh') return 'zh';
  if (SUPPORTED_LOCALES.includes(short as SupportedLocale)) {
    return short as SupportedLocale;
  }
  // 尝试匹配更具体的（如 pt-BR → pt）
  for (const code of SUPPORTED_LOCALES) {
    if (lang.startsWith(code)) return code as SupportedLocale;
  }
  return 'en';
}

// ============================================================
// Context
// ============================================================
interface I18nContextValue {
  locale: SupportedLocale;
  setLocale: (lang: SupportedLocale) => void;
  t: (key: string, vars?: Record<string, string | number>) => string;
}

const I18nContext = createContext<I18nContextValue>({
  locale: 'zh',
  setLocale: () => {},
  t: (key) => key,
});

// ============================================================
// Provider
// ============================================================
export function I18nProvider({ children }: { children: React.ReactNode }) {
  const [locale, setLocaleState] = useState<SupportedLocale>(() => detectBrowserLang());

  const setLocale = useCallback((lang: SupportedLocale) => {
    setLocaleState(lang);
    if (typeof document !== 'undefined') {
      document.documentElement.lang = LOCALE_HTML_LANG[lang] || lang;
      document.documentElement.dir = RTL_LANGS.includes(lang as any) ? 'rtl' : 'ltr';
    }
    try {
      localStorage.setItem('aibizcard_locale', lang);
    } catch {}
  }, []);

  useEffect(() => {
    try {
      const saved = localStorage.getItem('aibizcard_locale') as SupportedLocale | null;
      if (saved && SUPPORTED_LOCALES.includes(saved as any)) {
        setLocaleState(saved);
      }
    } catch {}
  }, []);

  // 初始化/同步 dir 属性
  useEffect(() => {
    if (typeof document !== 'undefined') {
      document.documentElement.dir = RTL_LANGS.includes(locale as any) ? 'rtl' : 'ltr';
    }
  }, [locale]);

  const t = useCallback(
    (key: string, vars?: Record<string, string | number>): string => {
      const pack = packs[locale];
      const template = pack[key];
      if (template === undefined) {
        if (process.env.NODE_ENV === 'development') {
          console.warn(`[i18n] Missing translation key: "${key}" for locale "${locale}"`);
        }
        return key;
      }
      return interpolate(template, vars);
    },
    [locale],
  );

  const value = useMemo(() => ({ locale, setLocale, t }), [locale, setLocale, t]);

  return <I18nContext.Provider value={value}>{children}</I18nContext.Provider>;
}

// ============================================================
// Hooks
// ============================================================
export function useT() {
  const ctx = useContext(I18nContext);
  return ctx.t;
}

export function useLocale() {
  const ctx = useContext(I18nContext);
  return { locale: ctx.locale, setLocale: ctx.setLocale };
}

export function useI18n() {
  return useContext(I18nContext);
}
