version: '3.8'

services:
  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: ai-digital-card-backend
    ports:
      - "8201:8201"
    environment:
      - DATABASE_URL=sqlite:///./data/digital_brochure.db
      - JWT_SECRET=change-this-to-a-secure-random-secret-key
      - CORS_ORIGINS=*
      - DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY:-}
    volumes:
      - ./backend/data:/app/data
      - ./backend/uploads:/app/uploads
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8201/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  nginx:
    image: nginx:alpine
    container_name: ai-digital-card-nginx
    ports:
      - "8200:8200"
    volumes:
      - ./deploy/nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./frontend/dist:/var/www/ai-digital-card/frontend/dist:ro
    depends_on:
      - backend
    restart: unless-stopped
